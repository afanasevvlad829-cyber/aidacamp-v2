---
import { mainShifts, shortShifts, allShifts } from '../data/shifts';
import ShiftCard from './shifts/ShiftCard.astro';
import ShortShiftCard from './shifts/ShortShiftCard.astro';
import ShiftBookModal from './shifts/ShiftBookModal.astro';
import ShiftCalendarModal from './shifts/ShiftCalendarModal.astro';
import ShiftInfoModal from './shifts/ShiftInfoModal.astro';
---

<section id="shifts" class="mx-auto max-w-[1312px] px-[2px] pt-10 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1"><div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div><h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Смены</h2></div>

    <!-- Mobile: tab nav + horizontal carousel -->
    <div class="mt-4 md:hidden">
      <div class="flex gap-2 pb-2" data-shifts-tabs>
        {allShifts.map((shift, i) => {
          const num = shift.name.replace('Смена ', '');
          return (
            <button
              type="button"
              data-shifts-tab={i}
              class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[12px] font-semibold transition-colors ${i === 0 ? 'bg-primary-light text-white' : 'bg-slate-100 text-slate-700'}`}
            >
              {num}
            </button>
          );
        })}
      </div>

      <div class="mt-3 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden" data-shifts-carousel>
        {allShifts.map((shift) => (
          <ShiftCard shift={shift} variant="mobile" />
        ))}
      </div>
      <!-- Dots indicator -->
      <div class="mt-3 flex justify-center gap-1.5 md:hidden" data-shifts-dots>
        {allShifts.map((_, i) => (
          <span class={`h-1.5 w-1.5 rounded-full transition-colors ${i === 0 ? 'bg-primary-light' : 'bg-slate-300'}`} data-shifts-dot={i}></span>
        ))}
      </div>
    </div>

    <!-- Desktop: 2-col grid + short shifts sidebar -->
    <div class="mt-6 hidden md:flex md:gap-6">
      <!-- Left: Main shifts (2 col grid) -->
      <div class="grid flex-1 grid-cols-2 gap-4">
        {mainShifts.map((shift) => (
          <ShiftCard shift={shift} variant="desktop" />
        ))}
      </div>

      <!-- Right: Short shifts -->
      <div class="w-[320px] shrink-0">
        <div class="rounded-[20px] border border-slate-200 bg-slate-50 p-5">
          <p class="text-[12px] font-semibold uppercase tracking-[0.08em] text-accent-green">Короткие смены</p>
          <p class="text-[12px] text-slate-400 mt-2 mb-1">Для тех, кто сомневается ехать ли надолго</p>
          <div class="mt-3 grid gap-3">
            {shortShifts.map((shift) => (
              <ShortShiftCard shift={shift} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<ShiftBookModal />
<ShiftCalendarModal />
<ShiftInfoModal />

<script>
  import { trackGoal } from '../scripts/analytics';
  import { MAILRU_PIXEL_ID } from '../data/tracking';
  import { renderCalendar } from '../scripts/shift-calendar';
  import { shiftInfo } from '../data/shifts';

  function initShifts() {
    // === MOBILE CAROUSEL TABS ===
    const carousel = document.querySelector<HTMLElement>('[data-shifts-carousel]');
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-shifts-tab]');
    const dots = document.querySelectorAll<HTMLElement>('[data-shifts-dot]');

    if (carousel && tabs.length) {
      const cards = Array.from(carousel.children) as HTMLElement[];

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const idx = parseInt(tab.dataset.shiftsTab || '0', 10);
          cards[idx]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        });
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = cards.indexOf(entry.target as HTMLElement);
            tabs.forEach((t, ti) => {
              t.classList.toggle('bg-primary-light', ti === idx);
              t.classList.toggle('text-white', ti === idx);
              t.classList.toggle('bg-slate-100', ti !== idx);
              t.classList.toggle('text-slate-700', ti !== idx);
            });
            dots.forEach((d, di) => {
              d.classList.toggle('bg-primary-light', di === idx);
              d.classList.toggle('bg-slate-300', di !== idx);
            });
          }
        });
      }, { root: carousel, threshold: 0.6 });

      cards.forEach((card) => observer.observe(card));
    }

    // === BOOKING MODAL ===
    const bookModal = document.getElementById('shiftBookModal') as HTMLDialogElement | null;
    if (!bookModal) return;

    const bookName = bookModal.querySelector('[data-book-shift-name]');
    const bookDates = bookModal.querySelector('[data-book-shift-dates]');
    const bookDuration = bookModal.querySelector('[data-book-shift-duration]');
    const bookPrice = bookModal.querySelector('[data-book-shift-price]');
    const bookPhone = bookModal.querySelector<HTMLInputElement>('[data-book-phone]');
    const bookConsent = bookModal.querySelector<HTMLInputElement>('[data-book-consent]');
    const bookSubmit = bookModal.querySelector<HTMLButtonElement>('[data-book-submit]');
    const bookError = bookModal.querySelector<HTMLElement>('[data-book-error]');
    const ageBtns = bookModal.querySelectorAll<HTMLButtonElement>('[data-book-age]');

    let selectedAge = '10-12';

    ageBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        ageBtns.forEach((b) => {
          b.classList.remove('bg-primary', 'text-white', 'font-semibold');
          b.classList.add('border', 'border-slate-200', 'text-slate-700', 'font-medium');
        });
        btn.classList.remove('border', 'border-slate-200', 'text-slate-700', 'font-medium');
        btn.classList.add('bg-primary', 'text-white', 'font-semibold');
        selectedAge = btn.dataset.bookAge || '10-12';
      });
    });

    if (bookPhone) {
      bookPhone.addEventListener('input', () => {
        let digits = bookPhone.value.replace(/\D/g, '');
        if (digits.startsWith('8')) digits = '7' + digits.slice(1);
        if (!digits.startsWith('7')) digits = '7' + digits;
        digits = digits.slice(0, 11);

        let formatted = '+7';
        if (digits.length > 1) formatted += ' (' + digits.slice(1, 4);
        if (digits.length >= 4) formatted += ') ' + digits.slice(4, 7);
        if (digits.length >= 7) formatted += '-' + digits.slice(7, 9);
        if (digits.length >= 9) formatted += '-' + digits.slice(9, 11);

        bookPhone.value = formatted;
        validateBookForm();
      });
    }

    function isPhoneValid() {
      const digits = (bookPhone?.value || '').replace(/\D/g, '');
      return digits.length === 11;
    }

    function validateBookForm() {
      const valid = isPhoneValid() && (bookConsent?.checked ?? false);
      if (bookSubmit) {
        bookSubmit.disabled = !valid;
        bookSubmit.classList.toggle('opacity-50', !valid);
      }
    }

    bookConsent?.addEventListener('change', validateBookForm);

    document.querySelectorAll('[data-shift-book]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (bookName) bookName.textContent = el.dataset.shiftBookName || '';
        if (bookDates) bookDates.textContent = el.dataset.shiftBookDates || '';
        if (bookDuration) bookDuration.textContent = el.dataset.shiftBookDuration || '';
        if (bookPrice) bookPrice.textContent = el.dataset.shiftBookPrice || '';
        if (bookError) bookError.classList.add('hidden');
        bookModal.showModal();
        trackGoal('shift_book_click', { shift: el.dataset.shiftBookName });
      });
    });

    bookModal.querySelector('[data-shift-book-close]')?.addEventListener('click', () => bookModal.close());
    bookModal.addEventListener('click', (e) => { if (e.target === bookModal) bookModal.close(); });

    bookSubmit?.addEventListener('click', async () => {
      if (!isPhoneValid()) {
        if (bookError) {
          bookError.textContent = 'Введите корректный номер телефона';
          bookError.classList.remove('hidden');
        }
        return;
      }
      if (!bookConsent?.checked) {
        if (bookError) {
          bookError.textContent = 'Необходимо согласие на обработку данных';
          bookError.classList.remove('hidden');
        }
        return;
      }

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            phone: bookPhone?.value || '',
            age: selectedAge,
            shift: bookName?.textContent || '',
            source: new URLSearchParams(window.location.search).get('utm_source') || '',
          }),
        });
        await res.json();
        if (typeof _tmr !== 'undefined') {
          _tmr.push({ type: 'reachGoal', id: MAILRU_PIXEL_ID, value: 6375, goal: 'lead'});
        }
      } catch {}

      bookModal.close();
      const referralModal = document.getElementById('referralModal') as HTMLDialogElement | null;
      referralModal?.showModal();
    });

    // === CALENDAR MODAL ===
    const calendarModal = document.getElementById('shiftCalendarModal') as HTMLDialogElement | null;
    const calendarTitle = calendarModal?.querySelector('[data-calendar-title]');
    const calendarGrid = calendarModal?.querySelector('[data-calendar-grid]');

    document.querySelectorAll('[data-shift-calendar]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        if (calendarGrid && calendarTitle) {
          renderCalendar(
            el.dataset.start || '',
            el.dataset.end || '',
            el.dataset.shiftName || '',
            calendarGrid,
            calendarTitle,
          );
        }
        calendarModal?.showModal();
      });
    });

    calendarModal?.querySelector('[data-calendar-close]')?.addEventListener('click', () => calendarModal.close());
    calendarModal?.addEventListener('click', (e) => { if (e.target === calendarModal) calendarModal.close(); });

    // === INFO MODAL ===
    const infoModal = document.getElementById('shiftInfoModal') as HTMLDialogElement | null;
    const infoTitle = infoModal?.querySelector('[data-info-title]');
    const infoDates = infoModal?.querySelector('[data-info-dates]');
    const infoPrice = infoModal?.querySelector('[data-info-price]');
    const infoBody = infoModal?.querySelector('[data-info-body]');

    document.querySelectorAll('[data-shift-info]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.shiftInfo || '';
        const info = shiftInfo[id];
        if (!info || !infoModal) return;
        if (infoTitle) infoTitle.textContent = (btn as HTMLElement).dataset.shiftTitle || id;
        if (infoDates) infoDates.textContent = `${info.dates} · ${info.duration}`;
        if (infoPrice) infoPrice.textContent = info.price;
        if (infoBody) infoBody.innerHTML = info.html;
        infoModal.showModal();
      });
    });

    infoModal?.querySelector('[data-info-close]')?.addEventListener('click', () => infoModal.close());
    infoModal?.addEventListener('click', (e) => { if (e.target === infoModal) infoModal.close(); });
  }

  document.addEventListener('astro:page-load', initShifts);
  initShifts();
</script>
