<!-- Collapsed bubble -->
<div
  id="sticky-bubble"
  class="hidden fixed bottom-5 right-4 z-50 md:hidden w-12 h-12 rounded-full bg-slate-900/80 backdrop-blur-md shadow-[0_4px_20px_rgba(0,0,0,0.3)] flex items-center justify-center cursor-pointer border border-white/10"
>
  <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
</div>

<script>
  function initStickyCta() {
    const hero = document.getElementById('hero');
    const bar = document.getElementById('sticky-bar');
    const bubble = document.getElementById('sticky-bubble');
    const closeBtn = document.getElementById('sticky-close');
    if (!hero || !bar || !bubble || !closeBtn) return;

    let isExpanded = true;
    let heroVisible = true;

    // Show/hide based on hero visibility
    const obs = new IntersectionObserver(([e]) => {
      heroVisible = e.isIntersecting;
      updateVisibility();
    }, { threshold: 0.1 });
    obs.observe(hero);

    function updateVisibility() {
      if (heroVisible) {
        // Hero visible — hide both
        bar.classList.add('hidden');
        bubble.classList.add('hidden');
      } else if (isExpanded) {
        bar.classList.remove('hidden');
        bubble.classList.add('hidden');
      } else {
        bar.classList.add('hidden');
        bubble.classList.remove('hidden');
      }
    }

    // Collapse to bubble
    closeBtn.addEventListener('click', () => {
      isExpanded = false;
      updateVisibility();
    });

    // Expand from bubble
    bubble.addEventListener('click', () => {
      isExpanded = true;
      updateVisibility();
    });
  }

  document.addEventListener('astro:page-load', initStickyCta);
  initStickyCta();
</script>
