---
import { PHONE_MAIN_HREF, PHONE_MOBILE, PHONE_MOBILE_HREF, WHATSAPP_URL, TELEGRAM_URL } from '../data/contacts';
---
<!-- Sticky CTA — mobile: bottom bar / desktop: right-side bubble -->

<!-- ===== MOBILE: Expanded bar ===== -->
<div
  id="sticky-bar"
  class="fixed bottom-0 inset-x-0 z-50 hidden lg:hidden bg-slate-900/20 backdrop-blur-md border-t border-white/10 flex items-center justify-around py-3 px-4"
>
  <a
    href={PHONE_MAIN_HREF}
    class="flex flex-col items-center gap-1 text-white text-[11px] font-medium"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
    Позвонить
  </a>
  <a
    href={WHATSAPP_URL}
    target="_blank"
    rel="noopener"
    class="flex flex-col items-center gap-1 text-white text-[11px] font-medium"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.685-1.228A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.239 0-4.308-.724-5.993-1.953l-.42-.304-2.785.73.744-2.717-.334-.443A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
    WhatsApp
  </a>
  <a
    href={TELEGRAM_URL}
    target="_blank"
    rel="noopener"
    class="flex flex-col items-center gap-1 text-white text-[11px] font-medium"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    Telegram
  </a>
  <button
    id="sticky-close"
    type="button"
    class="flex flex-col items-center gap-1 text-white/50 text-[11px] hover:text-white transition-colors"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    свернуть
  </button>
</div>

<!-- ===== MOBILE: Collapsed bubble ===== -->
<div
  id="sticky-bubble"
  class="hidden fixed bottom-5 right-4 z-50 lg:hidden w-12 h-12 rounded-full bg-slate-900/80 backdrop-blur-md shadow-[0_4px_20px_rgba(0,0,0,0.3)] flex items-center justify-center cursor-pointer border border-white/10"
>
  <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
</div>

<!-- ===== DESKTOP: Right-side bubble with expand ===== -->
<div
  id="desktop-sticky"
  class="fixed right-5 bottom-6 z-50 hidden lg:flex"
  data-desktop-sticky
>
  <!-- Collapsed: single round button -->
  <button
    type="button"
    id="desktop-bubble-toggle"
    class="relative flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white shadow-[0_4px_24px_rgba(236,124,0,0.4)] transition-all duration-300 hover:scale-105 hover:shadow-[0_6px_28px_rgba(236,124,0,0.5)]"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
  </button>

  <!-- Expanded panel -->
  <div
    id="desktop-bubble-panel"
    class="absolute bottom-[68px] right-0 hidden w-[220px] origin-bottom-right scale-95 rounded-[16px] bg-white p-4 opacity-0 shadow-[0_12px_40px_rgba(15,23,42,0.18)] transition-all duration-200"
  >
    <p class="text-[13px] font-semibold text-slate-900">Свяжитесь с нами</p>
    <div class="mt-3 space-y-2">
      <a
        href={PHONE_MAIN_HREF}
        class="flex items-center gap-3 rounded-[10px] px-3 py-2.5 text-[13px] font-medium text-slate-700 transition hover:bg-slate-50"
      >
        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
        +7 (495) 128-44-29
      </a>
      <a
        href={PHONE_MOBILE_HREF}
        class="flex items-center gap-3 rounded-[10px] px-3 py-2.5 text-[13px] font-medium text-slate-700 transition hover:bg-slate-50"
      >
        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
        {PHONE_MOBILE}
      </a>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 rounded-[10px] px-3 py-2.5 text-[13px] font-medium text-slate-700 transition hover:bg-green-50"
      >
        <svg class="h-4 w-4 shrink-0 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.685-1.228A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.239 0-4.308-.724-5.993-1.953l-.42-.304-2.785.73.744-2.717-.334-.443A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
        WhatsApp
      </a>
      <a
        href={TELEGRAM_URL}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 rounded-[10px] px-3 py-2.5 text-[13px] font-medium text-slate-700 transition hover:bg-blue-50"
      >
        <svg class="h-4 w-4 shrink-0 text-[#2AABEE]" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Telegram
      </a>
    </div>
  </div>
</div>

<script>
  function initStickyCta() {
    const hero = document.getElementById('hero');
    const bar = document.getElementById('sticky-bar');
    const bubble = document.getElementById('sticky-bubble');
    const closeBtn = document.getElementById('sticky-close');
    const desktopSticky = document.getElementById('desktop-sticky');
    const desktopToggle = document.getElementById('desktop-bubble-toggle');
    const desktopPanel = document.getElementById('desktop-bubble-panel');

    if (!hero) return;

    // --- Mobile sticky ---
    if (bar && bubble && closeBtn) {
      let isExpanded = true;
      let heroVisible = true;

      const obs = new IntersectionObserver(([e]) => {
        heroVisible = e.isIntersecting;
        updateMobileVisibility();
      }, { threshold: 0.1 });
      obs.observe(hero);

      function updateMobileVisibility() {
        if (heroVisible) {
          bar.classList.add('hidden');
          bubble.classList.add('hidden');
        } else if (isExpanded) {
          bar.classList.remove('hidden');
          bubble.classList.add('hidden');
        } else {
          bar.classList.add('hidden');
          bubble.classList.remove('hidden');
        }
      }

      closeBtn.addEventListener('click', () => {
        isExpanded = false;
        updateMobileVisibility();
      });

      bubble.addEventListener('click', () => {
        isExpanded = true;
        updateMobileVisibility();
      });
    }

    // --- Desktop sticky ---
    if (desktopSticky && desktopToggle && desktopPanel) {
      let panelOpen = false;

      const desktopObs = new IntersectionObserver(([e]) => {
        const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
        if (e.isIntersecting || !isDesktop) {
          desktopSticky.classList.add('hidden');
        } else {
          desktopSticky.classList.remove('hidden');
        }
      }, { threshold: 0.1 });
      desktopObs.observe(hero);

      desktopToggle.addEventListener('click', () => {
        panelOpen = !panelOpen;
        if (panelOpen) {
          desktopPanel.classList.remove('hidden');
          requestAnimationFrame(() => {
            desktopPanel.classList.remove('scale-95', 'opacity-0');
            desktopPanel.classList.add('scale-100', 'opacity-100');
          });
        } else {
          desktopPanel.classList.add('scale-95', 'opacity-0');
          desktopPanel.classList.remove('scale-100', 'opacity-100');
          setTimeout(() => desktopPanel.classList.add('hidden'), 200);
        }
      });

      // Close panel on outside click
      document.addEventListener('click', (e) => {
        if (panelOpen && !desktopSticky.contains(e.target as Node)) {
          panelOpen = false;
          desktopPanel.classList.add('scale-95', 'opacity-0');
          desktopPanel.classList.remove('scale-100', 'opacity-100');
          setTimeout(() => desktopPanel.classList.add('hidden'), 200);
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initStickyCta);
  initStickyCta();
</script>
