<!-- Sticky CTA bar — mobile only, appears when Hero leaves viewport -->
<div
  id="sticky-cta"
  class="fixed bottom-0 inset-x-0 z-50 hidden md:hidden bg-orange-500 text-white flex items-center justify-around py-3 px-4 shadow-[0_-4px_20px_rgba(249,115,22,0.3)]"
>
  <a
    href="tel:+74951284429"
    class="flex flex-col items-center gap-0.5 text-[11px] font-medium"
  >
    <span class="text-[20px]">📞</span>Позвонить
  </a>
  <a
    href="https://wa.me/79688086455"
    target="_blank"
    rel="noopener"
    class="flex flex-col items-center gap-0.5 text-[11px] font-medium"
  >
    <span class="text-[20px]">💬</span>WhatsApp
  </a>
  <a
    href="https://t.me/Progaschool"
    target="_blank"
    rel="noopener"
    class="flex flex-col items-center gap-0.5 text-[11px] font-medium"
  >
    <span class="text-[20px]">✈️</span>Telegram
  </a>
</div>

<script>
  const hero = document.getElementById('hero');
  const cta = document.getElementById('sticky-cta');
  if (hero && cta) {
    const obs = new IntersectionObserver(([e]) => {
      cta.classList.toggle('hidden', e.isIntersecting);
    }, { threshold: 0.1 });
    obs.observe(hero);
  }
</script>
