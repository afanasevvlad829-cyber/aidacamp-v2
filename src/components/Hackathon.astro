---
const roles = ['Разработчик', 'Дизайнер', 'Маркетолог', 'Финансовый директор', 'Стратег', 'Тестировщик'];

const steps = [
  {
    icon: 'bulb',
    title: 'Идея и паспорт',
    text: 'Брейншторм, паспорт проекта: для кого, какую проблему решает, чем отличается',
  },
  {
    icon: 'dollar',
    title: 'Покупка ресурсов',
    text: 'Рабочее место, интернет, консультации экспертов — всё за игровую валюту. Ресурсы ограничены',
  },
  {
    icon: 'cpu',
    title: 'Разработка и AI',
    text: 'Прототип, техзадание, AI для логотипа и текстов. Тестировщики ищут слабые места',
  },
  {
    icon: 'chart',
    title: 'Питч перед инвесторами',
    text: 'Два тура инвестиций. Финальная защита — 5 минут на питч и вопросы жюри',
  },
];

const outcomes = [
  'Опыт командной работы с распределёнными ролями',
  'Понимание что такое продукт, бюджет и питч',
  'Ощущение что сделал что-то настоящее — не учебное задание',
];
---

<section id="hackathon" class="mx-auto max-w-[1312px] px-[2px] pt-8 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
      <h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Хакатон: один день — настоящий стартап</h2>
    </div>

    <p class="mt-3 text-[15px] leading-[1.6] text-slate-600">Хакатон — это отдельное событие внутри смены. Не продолжение проекта, а другой формат: команда, стартап, инвесторы.</p>

    <!-- Блок 1: Роли -->
    <div class="mt-6">
      <h3 class="text-[17px] font-semibold text-slate-900">Команда собирается с нуля</h3>
      <p class="mt-2 text-[14px] text-slate-600">Роли распределяются сразу:</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {roles.map((role) => (
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[13px] text-slate-700">{role}</span>
        ))}
      </div>
    </div>

    <!-- Блок 2: Степпер -->
    <div class="mt-8">
      <!-- Mobile: vertical -->
      <div class="space-y-0 md:hidden">
        {steps.map((step, i) => (
          <div class="flex gap-3">
            <div class="flex flex-col items-center">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#ec7c00] text-[13px] font-bold text-white">{i + 1}</div>
              {i < steps.length - 1 && <div class="w-px flex-1 bg-slate-200 my-1"></div>}
            </div>
            <div class={`${i < steps.length - 1 ? 'pb-5' : 'pb-0'}`}>
              <div class="flex items-center gap-2">
                {step.icon === 'bulb' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>}
                {step.icon === 'dollar' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>}
                {step.icon === 'cpu' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" /></svg>}
                {step.icon === 'chart' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" /></svg>}
                <h4 class="text-[16px] font-semibold text-slate-900">{step.title}</h4>
              </div>
              <p class="mt-1.5 text-[14px] leading-[1.6] text-slate-600">{step.text}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Desktop: horizontal -->
      <div class="hidden md:grid md:grid-cols-4 md:gap-0">
        {steps.map((step, i) => (
          <div class="relative flex flex-col items-center text-center">
            <div class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full bg-[#ec7c00] text-[14px] font-bold text-white">{i + 1}</div>
            {i < steps.length - 1 && <div class="absolute top-5 left-[calc(50%+20px)] h-px w-[calc(100%-40px)] bg-slate-200"></div>}
            <div class="mt-3 flex items-center justify-center gap-1.5">
              {step.icon === 'bulb' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>}
              {step.icon === 'dollar' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>}
              {step.icon === 'cpu' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" /></svg>}
              {step.icon === 'chart' && <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" /></svg>}
              <h4 class="text-[15px] font-semibold text-slate-900">{step.title}</h4>
            </div>
            <p class="mt-1.5 px-2 text-[13px] leading-[1.55] text-slate-600">{step.text}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Блок 3: Итог -->
    <div class="mt-8 rounded-xl bg-slate-900 p-5 md:p-6">
      <h3 class="text-[18px] font-semibold text-white">Что остаётся после</h3>
      <div class="mt-4 space-y-3">
        {outcomes.map((item) => (
          <div class="flex items-start gap-2.5">
            <svg class="h-5 w-5 shrink-0 text-white mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
            <p class="text-[14px] leading-[1.55] text-slate-300">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
