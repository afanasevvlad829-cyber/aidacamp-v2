---
---

<dialog id="shiftBookModal" class="m-0 h-full w-full max-w-none border-0 outline-none bg-black/50 p-4 backdrop:bg-black/50">
  <div class="relative mx-auto mt-[8vh] w-full max-w-[420px] rounded-[20px] bg-white p-5 shadow-[0_20px_50px_rgba(15,23,42,0.25)]">
    <button type="button" data-shift-book-close aria-label="Закрыть" class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 text-slate-500 outline-none focus:outline-none focus:ring-0 focus-visible:outline-none">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>

    <!-- Shift info -->
    <div class="rounded-[14px] bg-slate-50 p-3">
      <p class="text-[16px] font-semibold text-slate-900" data-book-shift-name></p>
      <p class="mt-0.5 text-[13px] text-slate-500"><span data-book-shift-dates></span> · <span data-book-shift-duration></span></p>
      <p class="mt-1 text-[20px] font-bold text-slate-900" data-book-shift-price></p>
    </div>

    <!-- Age -->
    <p class="mt-4 text-[12px] font-semibold uppercase tracking-[0.08em] text-slate-500">Возраст</p>
    <div class="mt-2 flex gap-2" data-book-age-group>
      <button type="button" data-book-age="7-10" class="flex-1 rounded-xl border border-slate-200 py-2.5 text-sm font-medium text-slate-700 transition">7–10 лет</button>
      <button type="button" data-book-age="10-12" class="flex-1 rounded-xl bg-primary py-2.5 text-sm font-semibold text-white transition">10–12 лет</button>
      <button type="button" data-book-age="13-14" class="flex-1 rounded-xl border border-slate-200 py-2.5 text-sm font-medium text-slate-700 transition">13–14 лет</button>
    </div>

    <!-- Phone -->
    <p class="mt-4 text-[12px] font-semibold uppercase tracking-[0.08em] text-slate-500">Ваш телефон</p>
    <input
      type="tel"
      data-book-phone
      placeholder="+7 (___) ___-__-__"
      class="mt-2 w-full rounded-xl border border-slate-200 px-4 py-3 text-[15px] text-slate-700 outline-none focus:border-primary focus:ring-1 focus:ring-primary"
    />

    <!-- Consent -->
    <label class="mt-3 flex items-start gap-2 cursor-pointer">
      <input type="checkbox" data-book-consent class="mt-0.5 h-4 w-4 rounded border-slate-300 text-primary accent-primary" />
      <span class="text-[12px] leading-[1.4] text-slate-500">Согласен(а) на <a href="/legal" class="underline">обработку персональных данных</a></span>
    </label>

    <!-- Submit -->
    <button
      type="button"
      data-book-submit
      disabled
      class="mt-4 w-full rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-white opacity-50 transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0 disabled:cursor-not-allowed disabled:opacity-50"
    >
      Отправить заявку
    </button>

    <!-- Validation error -->
    <p data-book-error class="mt-2 hidden text-center text-[12px] text-red-500"></p>
  </div>
</dialog>
