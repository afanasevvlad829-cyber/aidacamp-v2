---
const phoneTime = [
  '5 минут — 50 р.',
  '30 минут — 300 р.',
  '60 минут — 600 р. (весь дневной бюджет)',
];

const events = [
  'Фильм на вечер — 3 000 р.',
  'Костёр с зефирками — 5 000 р.',
  'Отбой на час позже — 4 000 р.',
  'Ночь с телефонами — 20 000 р.',
];
---

<section id="economy" class="mx-auto max-w-[1312px] px-[2px] pt-8 md:px-4">
  <div class="bg-[#f7f5f2] p-[18px]">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
      <h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Телефон здесь зарабатывают</h2>
    </div>

    <!-- Блок 1: Вводный текст -->
    <div class="mt-5">
      <h3 class="text-[18px] font-semibold leading-[1.3] text-slate-900">Лагерь без телефонов — это не запрет. Это система.</h3>
      <p class="mt-3 text-[15px] leading-[1.65] text-slate-600">При заезде телефоны сдаются вожатому. Каждый день каждый участник получает 600 игровых рублей. 10 рублей — одна минута телефонного времени. Хочешь позвонить домой — пожалуйста. Хочешь накопить — копи. Хочешь потратить на что-то другое — есть варианты.</p>
      <p class="mt-3 text-[15px] leading-[1.65] text-slate-600">Дополнительно зарабатывают за активность, инициативу, помощь другим, победы в конкурсах. Штрафы — за нарушения и беспорядок. Все расчёты прозрачны: прайс на видном месте, казначей ведёт учёт.</p>
    </div>

    <!-- Блок 2: На что тратят -->
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <!-- Телефонное время -->
      <div class="rounded-[16px] border border-slate-200 bg-white p-4 md:p-5">
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
          <h4 class="text-[16px] font-semibold text-slate-900">Телефонное время</h4>
        </div>
        <ul class="mt-3 space-y-2">
          {phoneTime.map((item) => (
            <li class="flex items-start gap-2 text-[14px] leading-[1.5] text-slate-600">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-[#ec7c00]"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Коллективные события -->
      <div class="rounded-[16px] border border-slate-200 bg-white p-4 md:p-5">
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
          <h4 class="text-[16px] font-semibold text-slate-900">Коллективные события</h4>
        </div>
        <ul class="mt-3 space-y-2">
          {events.map((item) => (
            <li class="flex items-start gap-2 text-[14px] leading-[1.5] text-slate-600">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-[#ec7c00]"></span>
              {item}
            </li>
          ))}
        </ul>
        <p class="mt-3 text-[13px] text-slate-400">Чтобы купить — нужно договориться и скинуться. Первый урок про бюджет и коллективные решения.</p>
        <button
          type="button"
          id="economyVideoBtn"
          class="mt-3 inline-flex items-center gap-2 rounded-[12px] border border-slate-200 bg-slate-50 px-4 py-2.5 text-[14px] font-medium text-slate-700 transition hover:bg-slate-100"
        >
          <svg class="h-5 w-5 shrink-0 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
          </svg>
          На что копят дети в лагере
        </button>
      </div>
    </div>

    <!-- Блок 3: Цитата -->
    <div class="mt-6 rounded-r-xl border-l-4 border-orange-500 bg-orange-50 p-4">
      <p class="text-[15px] italic leading-[1.65] text-slate-700">К концу смены у большинства остаётся 5–10 минут телефона в день — и это их собственный выбор. Настолки, мафия, волейбол и работа над проектом оказываются интереснее ютуба.</p>
    </div>

    <!-- Блок 4: Плашка -->
    <div class="mt-5 flex items-start gap-2.5 rounded-xl border border-slate-200 bg-slate-50 p-4">
      <svg class="h-5 w-5 shrink-0 text-[#ec7c00] mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
      <p class="text-[14px] leading-[1.5] text-slate-600">Связь с ребёнком — через вожатого в любое время. Родители узнают о системе заранее.</p>
    </div>
  </div>
</section>

<dialog
  id="economyVideoModal"
  class="m-0 h-full w-full max-w-none border-0 outline-none bg-black/80 p-4 backdrop:bg-black/80"
>
  <div class="flex h-full items-center justify-center">
    <div class="relative w-full max-w-[800px]">
      <button
        type="button"
        id="economyVideoClose"
        aria-label="Закрыть"
        class="absolute -top-10 right-0 inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/20 text-white hover:bg-white/30"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="aspect-video w-full overflow-hidden rounded-[16px]">
        <iframe
          id="economyVideoIframe"
          src=""
          data-src="https://kinescope.io/embed/s1SCYKqLx6C94fMRumitHF"
          class="h-full w-full"
          frameborder="0"
          allow="autoplay; fullscreen"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</dialog>

<script>
  const btn = document.getElementById('economyVideoBtn');
  const modal = document.getElementById('economyVideoModal') as HTMLDialogElement;
  const iframe = document.getElementById('economyVideoIframe') as HTMLIFrameElement;
  const closeBtn = document.getElementById('economyVideoClose');

  btn?.addEventListener('click', () => {
    iframe.src = iframe.dataset.src || '';
    modal?.showModal();
  });

  function closeModal() {
    iframe.src = '';
    modal?.close();
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>
