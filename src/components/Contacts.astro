---
const socials = [
  { abbr: 'VK', label: 'ВКонтакте', href: 'https://vk.com/aidacamp' },
  { abbr: 'OK', label: 'Одноклассники', href: 'https://ok.ru/group/64689601773621' },
  { abbr: 'YT', label: 'YouTube', href: 'https://www.youtube.com/@aidacamp' },
  { abbr: 'RT', label: 'Rutube', href: 'https://rutube.ru/channel/53394996/' },
  { abbr: 'IG', label: 'Instagram', href: 'https://www.instagram.com/aida_codit' },
  { abbr: 'LI', label: 'LinkedIn', href: 'https://www.linkedin.com/company/it-лагерь-для-детей-айдакемп' },
  { abbr: 'TT', label: 'TikTok', href: 'https://www.tiktok.com/@aidacodit0' },
  { abbr: 'PI', label: 'Pinterest', href: 'https://ru.pinterest.com/pbalgoritmika/' },
  { abbr: 'YA', label: 'Yappy', href: 'https://yappy.media/n/acceptable.lizardxw' },
];
---

<section id="contacts" class="mx-auto max-w-[1312px] px-[2px] pt-6 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1"><div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div><h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Контакты и соцсети</h2></div>

    <!-- Map -->
    <div class="mt-4 overflow-hidden rounded-[18px] border border-slate-200">
      <iframe
        src="https://yandex.ru/map-widget/v1/?ll=37.160000%2C55.500000&z=8&pt=36.724185,55.265643,pm2rdm"
        width="100%"
        height="320"
        class="block w-full"
        frameborder="0"
        loading="lazy"
        title="Расположение АйДаКемп на карте"
      ></iframe>
    </div>
    <p class="mt-2 text-[13px] text-slate-500">
      66 км от Москвы · Наро-Фоминский городской округ · территория «Санаторий Изумруд»
    </p>

    <!-- Two columns: Contacts + Socials -->
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <!-- Left: Contacts -->
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate-500">Контакты</p>
        <div class="mt-3 grid gap-2">
          <a href="tel:+79688086455" class="flex items-center gap-3 rounded-[14px] border border-slate-200 bg-slate-50 px-4 py-3 text-[14px] font-medium text-slate-700" data-analytics-goal="phone_click">
            <span class="text-[16px]">📱</span> +7 (968) 808-64-55
          </a>
          <a href="tel:+74951284429" class="flex items-center gap-3 rounded-[14px] border border-slate-200 bg-slate-50 px-4 py-3 text-[14px] font-medium text-slate-700" data-analytics-goal="phone_click">
            <span class="text-[16px]">📞</span> +7 (495) 128-44-29
          </a>
          <a href="mailto:hello@codims.ru" class="flex items-center gap-3 rounded-[14px] border border-slate-200 bg-slate-50 px-4 py-3 text-[14px] font-medium text-slate-700">
            <span class="text-[16px]">✉️</span> hello@codims.ru
          </a>
          <a href="https://wa.me/79688086455" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-[14px] border border-slate-200 bg-slate-50 px-4 py-3 text-[14px] font-medium text-slate-700" data-analytics-goal="messenger_click">
            <span class="text-[16px]">💬</span> WhatsApp
          </a>
          <a href="https://t.me/Progaschool" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-[14px] border border-slate-200 bg-slate-50 px-4 py-3 text-[14px] font-medium text-slate-700" data-analytics-goal="messenger_click">
            <span class="text-[16px]">✈️</span> Telegram
          </a>
        </div>
      </div>

      <!-- Right: Socials -->
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate-500">Соцсети</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-[13px] font-medium text-slate-700 transition hover:bg-slate-100"
            >
              <span class="font-bold text-slate-500">{s.abbr}</span> {s.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { trackGoal } from '../scripts/analytics';

  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href^="tel:"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('phone_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href*="wa.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('whatsapp_click'));
  });
</script>
