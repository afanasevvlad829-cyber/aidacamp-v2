<script>
  import { trackGoal } from '../scripts/analytics';

  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href^="tel:"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('phone_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href*="wa.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('whatsapp_click'));
  });
</script>
