---
const socials = [
  { abbr: 'VK', label: 'ВКонтакте', href: 'https://vk.com/aidacamp' },
  { abbr: 'OK', label: 'Одноклассники', href: 'https://ok.ru/group/64689601773621' },
  { abbr: 'YT', label: 'YouTube', href: 'https://www.youtube.com/@aidacamp' },
  { abbr: 'RT', label: 'Rutube', href: 'https://rutube.ru/channel/53394996/' },
  { abbr: 'IG', label: 'Instagram', href: 'https://www.instagram.com/aida_codit' },
  { abbr: 'LI', label: 'LinkedIn', href: 'https://www.linkedin.com/company/it-лагерь-для-детей-айдакемп' },
  { abbr: 'TT', label: 'TikTok', href: 'https://www.tiktok.com/@aidacodit0' },
  { abbr: 'PI', label: 'Pinterest', href: 'https://ru.pinterest.com/pbalgoritmika/' },
  { abbr: 'YA', label: 'Yappy', href: 'https://yappy.media/n/acceptable.lizardxw' },
];
---

<section id="contacts" class="mx-auto max-w-[1312px] px-[2px] pt-6 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
      <h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Контакты и соцсети</h2>
    </div>

    <div class="overflow-hidden rounded-[18px] border border-slate-200">
      <iframe
        src="https://yandex.ru/map-widget/v1/?ll=37.160000%2C55.500000&z=8&pt=36.724185,55.265643,pm2rdm"
        width="100%"
        height="260"
        class="block w-full"
        frameborder="0"
        loading="lazy"
        title="Расположение АйДаКемп на карте"
      ></iframe>
    </div>
    <p class="mt-1.5 text-[12px] text-slate-400">
      66 км от Москвы · Наро-Фоминский городской округ · территория «Санаторий Изумруд»
    </p>

    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-400 mb-2">Телефоны</p>
        <div class="space-y-1.5">
          <a href="tel:+79688086455" class="flex items-center gap-2 text-[14px] font-medium text-slate-700 hover:text-orange-500 transition-colors" data-analytics-goal="phone_click">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +7 (968) 808-64-55
          </a>
          <a href="tel:+74951284429" class="flex items-center gap-2 text-[14px] font-medium text-slate-700 hover:text-orange-500 transition-colors" data-analytics-goal="phone_click">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +7 (495) 128-44-29
          </a>
          <a href="mailto:hello@codims.ru" class="flex items-center gap-2 text-[14px] text-slate-500 hover:text-orange-500 transition-colors">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            hello@codims.ru
          </a>
        </div>
      </div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-400 mb-2">Мессенджеры</p>
        <div class="space-y-1.5">
          <a href="https://wa.me/79688086455" target="_blank" rel="noopener" class="flex items-center gap-2 text-[14px] font-medium text-slate-700 hover:text-orange-500 transition-colors" data-analytics-goal="whatsapp_click">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
            WhatsApp
          </a>
          <a href="https://t.me/Progaschool" target="_blank" rel="noopener" class="flex items-center gap-2 text-[14px] font-medium text-slate-700 hover:text-orange-500 transition-colors" data-analytics-goal="telegram_click">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
            Telegram
          </a>
        </div>
      </div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-400 mb-2">Соцсети</p>
        <div class="flex flex-wrap gap-1.5">
          {socials.slice(0, 3).map((s) => (
            <a href={s.href} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[12px] font-medium text-slate-600 transition hover:bg-slate-100">
              <span class="font-bold text-slate-400">{s.abbr}</span> {s.label}
            </a>
          ))}
          <details class="w-full mt-0.5">
            <summary class="cursor-pointer text-[12px] font-medium text-slate-400 hover:text-slate-600 list-none">Ещё соцсети ▾</summary>
            <div class="mt-1.5 flex flex-wrap gap-1.5">
              {socials.slice(3).map((s) => (
                <a href={s.href} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[12px] font-medium text-slate-600 transition hover:bg-slate-100">
                  <span class="font-bold text-slate-400">{s.abbr}</span> {s.label}
                </a>
              ))}
            </div>
          </details>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { trackGoal } from '../scripts/analytics';

  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href^="tel:"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('phone_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href*="wa.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('whatsapp_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('#contacts a[href*="t.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('telegram_click'));
  });
</script>
