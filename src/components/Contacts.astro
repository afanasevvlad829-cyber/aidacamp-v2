              <span class="font-bold text-slate-500">{s.abbr}</span> {s.label}
            </a>
          ))}
        </div>
        <!-- Desktop: rest visible -->
        <div class="mt-2 hidden flex-wrap gap-2 md:flex">
          {socials.slice(3).map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-[13px] font-medium text-slate-700 transition hover:bg-slate-100"
            >
              <span class="font-bold text-slate-500">{s.abbr}</span> {s.label}
            </a>
          ))}
        </div>
        <!-- Mobile: rest under dropdown -->
        <details class="mt-2 md:hidden">
          <summary class="cursor-pointer text-[13px] font-medium text-slate-500">Ещё соцсети ▾</summary>
          <div class="mt-2 flex flex-wrap gap-2">
            {socials.slice(3).map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-[13px] font-medium text-slate-700 transition hover:bg-slate-100"
