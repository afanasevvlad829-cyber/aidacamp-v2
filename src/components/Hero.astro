---
import LeadForm from './LeadForm.astro';
---

<section id="hero" class="relative mx-auto w-full overflow-hidden bg-[#f7f5f2] md:max-w-[1440px]">
  <!-- ===== MOBILE HERO ===== -->
  <div class="relative w-full bg-[#0d1a2b] md:hidden">
    <!-- Photo with gradient fade to dark -->
    <div class="relative">
      <img
        src="/images/hero-custom-2026-04-07.avif"
        alt=""
        aria-hidden="true"
        class="w-full aspect-[4/3] object-cover object-[center_20%]"
      />
      <!-- Side gradient -->
      <div class="absolute inset-0 bg-[linear-gradient(92deg,rgba(6,10,18,0.72)_0%,rgba(6,10,18,0.46)_42%,rgba(6,10,18,0.2)_70%,rgba(6,10,18,0.06)_100%)]"></div>
      <!-- Bottom fade to dark -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0d1a2b]"></div>

      <!-- Text over photo -->
      <div class="absolute bottom-6 left-5 right-5">
        <p class="text-[13px] tracking-[0.2px] text-white/80">
          <span class="text-orange-400">★ 5.0</span> на Яндекс Картах · 6 лет работы · 1200+ детей
        </p>
        <h1 class="mt-1 text-[36px] font-bold leading-[1.1] tracking-[-0.03em] text-white">
          Лагерь где<br /> ребёнок<br /> <span class="text-[#f5a624]">уедет с проектом</span>
        </h1>
        <p class="mt-2 text-[13px] text-white/60">
          Python · AI · Minecraft — проект за смену
        </p>
      </div>
    </div>

    <!-- Form area — same dark bg, seamless -->
    <div class="bg-[#0d1a2b] px-4 pb-6 pt-4">
      <!-- Info bar -->
      <div class="mb-4 flex items-center justify-between rounded-[12px] bg-white/10 px-4 py-2.5 text-[12px] text-white/80">
        <span>от 48 000 ₽ за 7 дней</span>
        <span>✓ Ответим за 10 мин</span>
      </div>
      <!-- White card with form -->
      <LeadForm variant="mobile" />
    </div>
  </div>

  <!-- ===== DESKTOP HERO ===== -->
  <div class="relative hidden h-[620px] overflow-hidden bg-[#0f1c2e] w-full md:block md:max-w-[1440px]">
    <img
      src="/images/hero-custom-2026-04-07.avif"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
    />

    <!-- Desktop Overlays -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,9,18,0.78)_0%,rgba(5,9,18,0.62)_26%,rgba(5,9,18,0.34)_48%,rgba(5,9,18,0.12)_66%,rgba(5,9,18,0.02)_82%,rgba(5,9,18,0)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,10,18,0)_52%,rgba(6,10,18,0.22)_74%,rgba(6,10,18,0.42)_100%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(140%_120%_at_50%_50%,rgba(0,0,0,0)_58%,rgba(0,0,0,0.12)_84%,rgba(0,0,0,0.24)_100%)] mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(236,124,0,0.09)_0%,rgba(236,124,0,0.04)_30%,rgba(236,124,0,0)_62%)] mix-blend-soft-light"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent pointer-events-none"></div>
    </div>

    <!-- Desktop Text Content -->
    <div class="absolute left-14 top-[192px] w-[640px] flex-col flex max-w-[55%]">
      <div class="absolute left-[-6px] top-[-24px] h-[320px] w-[520px] rounded-[24px] bg-gradient-to-r from-[rgba(5,10,20,0.36)] via-[rgba(5,10,20,0.14)] to-transparent"></div>
      <div class="relative z-10">
        <p class="text-[12px] tracking-[0.4px] text-white/64 [text-shadow:0px_1px_2px_rgba(0,0,0,0.28)]">
          66 км от Москвы · смены июнь–август
        </p>
        <div class="h-2"></div>
        <h1 class="w-[460px] text-[56px] font-bold leading-[1.05] tracking-[-0.03em] text-white lg:text-[64px] [text-shadow:0px_4px_12px_rgba(0,0,0,0.52)]">
          AI-лагерь 7–14:<br /><span class="text-[#f5a624]">проект за смену</span>
        </h1>
        <p class="mt-2 h-[44px] w-[590px] text-[15px] leading-[1.6] text-white/72">
          Python, AI, Minecraft — ребёнок уедет с готовым проектом и презентацией
        </p>
        <div class="mt-[10px] flex gap-[10px]">
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Python</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Minecraft</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">AI</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Бассейн</span>
        </div>
        <p class="mt-3 text-[15px] text-white/80 [text-shadow:0px_1px_2px_rgba(0,0,0,0.42)]">
          <span class="text-orange-400">★ 5.0</span> на Яндекс Картах · 6 лет работы · 1200+ детей
        </p>
      </div>
    </div>

    <!-- Desktop Bottom Bar -->
    <div class="absolute inset-x-0 bottom-0 z-20 flex h-12 items-center justify-between bg-[#f7f5f2] px-8">
      <p class="text-[13px] text-[#545454]">от 48 000 ₽ за 7 дней · проживание, питание, программа включены · Трансфер — опция</p>
      <div class="flex gap-6 text-[12px] text-[#787878]">
        <span>✓ Фиксация цены 72 ч</span>
        <span>✓ Ответим за 10 мин</span>
      </div>
    </div>
  </div>

  <!-- Booking Section — Desktop -->
  <section id="booking" class="relative mx-auto hidden w-full md:block md:max-w-[1440px]" data-booking-root>
    <LeadForm variant="desktop" />
  </section>
</section>

<!-- Validation Modal -->
<dialog
  id="bookingReminderModal"
  class="fixed inset-0 m-auto w-[min(92vw,420px)] rounded-[18px] border-0 outline-none bg-white p-0 shadow-[0_20px_60px_rgba(15,23,42,0.25)] backdrop:bg-black/40"
>
  <div class="p-5">
    <h3 class="text-[18px] font-semibold text-slate-900">Проверьте данные</h3>
    <p class="mt-2 text-[14px] text-slate-600">Чтобы продолжить, заполните телефон и подтвердите согласие на обработку персональных данных.</p>
    <ul class="mt-3 list-disc pl-5 text-[13px] text-slate-500">
      <li>Телефон в формате +7 (XXX) XXX-XX-XX</li>
      <li>Галочка согласия обязательна</li>
    </ul>
    <button type="button" data-booking-reminder-close class="mt-4 inline-flex rounded-[10px] bg-[#ec7c00] px-4 py-2 text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0">Понятно</button>
  </div>
</dialog>

<!-- Referral Modal (shown after form submit) -->
<dialog
  id="referralModal"
  class="fixed inset-0 m-auto w-[min(92vw,420px)] rounded-[20px] border-0 outline-none bg-white p-0 shadow-[0_20px_60px_rgba(15,23,42,0.25)] backdrop:bg-black/40"
>
  <div class="p-6">
    <div class="text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
        <svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h3 class="mt-3 text-[20px] font-bold text-slate-900">Заявка отправлена!</h3>
      <p class="mt-2 text-[14px] leading-[1.5] text-slate-500">Мы перезвоним в течение 10 минут. А пока — расскажите друзьям про лагерь:</p>
    </div>

    <div class="mt-5 space-y-2">
      <a
        href="https://wa.me/?text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20%D0%9F%D0%BE%D1%81%D0%BC%D0%BE%D1%82%D1%80%D0%B8%20%D0%BB%D0%B0%D0%B3%D0%B5%D1%80%D1%8C%20%D0%90%D0%B9%D0%94%D0%B0%D0%9A%D0%B5%D0%BC%D0%BF%20%E2%80%94%20aidacamp.ru"
        target="_blank"
        rel="noopener"
        class="flex w-full items-center justify-center gap-2 rounded-[12px] bg-[#25D366] px-4 py-3 text-[14px] font-semibold text-white transition hover:brightness-110"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.685-1.228A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.239 0-4.308-.724-5.993-1.953l-.42-.304-2.785.73.744-2.717-.334-.443A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
        Отправить в WhatsApp
      </a>
      <a
        href="https://t.me/share/url?url=https%3A%2F%2Faidacamp.ru&text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20%D0%9F%D0%BE%D1%81%D0%BC%D0%BE%D1%82%D1%80%D0%B8%20%D0%BB%D0%B0%D0%B3%D0%B5%D1%80%D1%8C%20%D0%90%D0%B9%D0%94%D0%B0%D0%9A%D0%B5%D0%BC%D0%BF"
        target="_blank"
        rel="noopener"
        class="flex w-full items-center justify-center gap-2 rounded-[12px] bg-[#2AABEE] px-4 py-3 text-[14px] font-semibold text-white transition hover:brightness-110"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Отправить в Telegram
      </a>
      <button
        type="button"
        data-referral-copy
        class="flex w-full items-center justify-center gap-2 rounded-[12px] border border-slate-200 px-4 py-3 text-[14px] font-semibold text-slate-700 transition hover:bg-slate-50"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        Скопировать ссылку
      </button>
    </div>

    <div class="flex items-center gap-3 mt-3">
      <img src="/images/merch-hoodi.avif"
           alt="Фирменная толстовка АйДаКемп"
           class="w-20 h-20 object-cover object-top rounded-[12px] shrink-0">
      <div class="text-[12px] text-slate-600 leading-[1.5]">
        <p>👕 <strong>Первый раз</strong> → футболка Junior</p>
        <p class="mt-1">🧥 <strong>Второй раз</strong> → толстовка #Junior</p>
        <p class="mt-1 text-orange-600 font-medium">
          def aidacamp2026(): return "summer = code + fun"
        </p>
      </div>
    </div>

    <button
      type="button"
      data-referral-close
      class="mt-4 w-full text-center text-[13px] text-slate-400 transition hover:text-slate-600"
    >
      Пропустить
    </button>
  </div>
</dialog>

<script>
  function initModal() {
    const modal = document.getElementById('bookingReminderModal') as HTMLDialogElement | null;
    if (!modal) return;

    modal.querySelector('[data-booking-reminder-close]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  }

  function initReferralModal() {
    const modal = document.getElementById('referralModal') as HTMLDialogElement | null;
    if (!modal) return;

    modal.querySelector('[data-referral-close]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal.querySelector('[data-referral-copy]')?.addEventListener('click', () => {
      navigator.clipboard.writeText('https://aidacamp.ru').then(() => {
        const btn = modal.querySelector('[data-referral-copy]');
        if (btn) {
          btn.textContent = 'Скопировано!';
          setTimeout(() => {
            btn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Скопировать ссылку';
          }, 2000);
        }
      });
    });
  }

  document.addEventListener('astro:page-load', () => { initModal(); initReferralModal(); });
  initModal();
  initReferralModal();
</script>
