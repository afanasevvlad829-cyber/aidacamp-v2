---
import LeadForm from './LeadForm.astro';
---

<section id="hero" class="relative mx-auto w-full overflow-hidden bg-[#f7f5f2] md:max-w-[1440px]">
  <!-- Background Image -->
  <div class="relative h-[560px] overflow-hidden bg-[#0d1a2b] w-full md:h-[620px] md:max-w-[1440px] md:bg-[#0f1c2e]">
    <img
      src="/images/hero-custom-2026-04-07.avif"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
    />

    <!-- Mobile Overlays -->
    <div class="absolute inset-0 bg-[linear-gradient(92deg,rgba(6,10,18,0.72)_0%,rgba(6,10,18,0.46)_42%,rgba(6,10,18,0.2)_70%,rgba(6,10,18,0.06)_100%)] md:hidden"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,10,18,0.04)_0%,rgba(6,10,18,0.16)_54%,rgba(6,10,18,0.52)_100%)] md:hidden"></div>

    <!-- Desktop Overlays -->
    <div class="absolute inset-0 hidden md:block">
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,9,18,0.78)_0%,rgba(5,9,18,0.62)_26%,rgba(5,9,18,0.34)_48%,rgba(5,9,18,0.12)_66%,rgba(5,9,18,0.02)_82%,rgba(5,9,18,0)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,10,18,0)_52%,rgba(6,10,18,0.22)_74%,rgba(6,10,18,0.42)_100%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(140%_120%_at_50%_50%,rgba(0,0,0,0)_58%,rgba(0,0,0,0.12)_84%,rgba(0,0,0,0.24)_100%)] mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(236,124,0,0.09)_0%,rgba(236,124,0,0.04)_30%,rgba(236,124,0,0)_62%)] mix-blend-soft-light"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent pointer-events-none"></div>
    </div>

    <!-- Mobile Text Content -->
    <p class="absolute left-5 top-[268px] text-[13px] tracking-[0.2px] text-white/72 md:hidden">
      6 лет · 1200+ детей · ★ 5.0 Карты
    </p>
    <h1 class="absolute left-5 top-[292px] w-[355px] text-[50px] font-bold leading-[1.05] tracking-[-0.03em] text-white md:hidden">
      Лагерь где<br /> ребёнок<br /> <span class="text-[#f5a624]">уедет с проектом</span>
    </h1>
    <div class="absolute left-5 top-[462px] flex items-center gap-[6px] md:hidden">
      <span class="rounded-[20px] border border-white/20 bg-white/13 px-[10px] py-[5px] text-[11px] text-white/85">Python</span>
      <span class="rounded-[20px] border border-white/20 bg-white/13 px-[10px] py-[5px] text-[11px] text-white/85">AI</span>
      <span class="rounded-[20px] border border-white/20 bg-white/13 px-[10px] py-[5px] text-[11px] text-white/85">Бассейн</span>
      <span class="text-[13px] text-white/70">66 км от Москвы</span>
    </div>

    <!-- Desktop Text Content -->
    <div class="absolute left-14 top-[192px] hidden w-[640px] flex-col md:flex md:max-w-[55%]">
      <div class="absolute left-[-6px] top-[-24px] h-[320px] w-[520px] rounded-[24px] bg-gradient-to-r from-[rgba(5,10,20,0.36)] via-[rgba(5,10,20,0.14)] to-transparent"></div>
      <div class="relative z-10">
        <p class="text-[12px] tracking-[0.4px] text-white/64 [text-shadow:0px_1px_2px_rgba(0,0,0,0.28)]">
          66 км от Москвы · смены июнь–август
        </p>
        <div class="h-2"></div>
        <h1 class="w-[460px] text-[56px] font-bold leading-[1.05] tracking-[-0.03em] text-white [text-shadow:0px_4px_12px_rgba(0,0,0,0.52)]">
          AI-лагерь 7–14:<br /><span class="text-[#f5a624]">проект за смену</span>
        </h1>
        <p class="mt-2 h-[44px] w-[590px] text-[15px] leading-[1.6] text-white/72">
          Python, AI, Minecraft — ребёнок уедет с готовым проектом и презентацией
        </p>
        <div class="mt-[10px] flex gap-[10px]">
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Python</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Minecraft</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">AI</span>
          <span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">Бассейн</span>
        </div>
        <p class="mt-3 text-[13px] text-white/58 [text-shadow:0px_1px_2px_rgba(0,0,0,0.42)]">
          6 лет работы · 1200+ детей · ★ 5.0 Яндекс Карты
        </p>
      </div>
    </div>

    <!-- Desktop Bottom Bar -->
    <div class="absolute inset-x-0 bottom-0 z-20 hidden h-12 items-center justify-between bg-[#f7f5f2] px-8 md:flex">
      <p class="text-[13px] text-[#545454]">от 48 000 ₽ за 7 дней · проживание, питание, программа включены · Трансфер — опция</p>
      <div class="flex gap-6 text-[12px] text-[#787878]">
        <span>✓ Фиксация цены 72 ч</span>
        <span>✓ Ответим за 10 мин</span>
      </div>
    </div>
  </div>

  <!-- Booking Section -->
  <section id="booking" class="relative mx-auto hidden w-full md:block md:max-w-[1440px]" data-booking-root>
    <LeadForm variant="desktop" />
  </section>
</section>

<!-- Validation Modal -->
<dialog
  id="bookingReminderModal"
  class="fixed inset-0 m-auto w-[min(92vw,420px)] rounded-[18px] border-0 outline-none bg-white p-0 shadow-[0_20px_60px_rgba(15,23,42,0.25)] backdrop:bg-black/40"
>
  <div class="p-5">
    <h3 class="text-[18px] font-semibold text-slate-900">Проверьте данные</h3>
    <p class="mt-2 text-[14px] text-slate-600">Чтобы продолжить, заполните телефон и подтвердите согласие на обработку персональных данных.</p>
    <ul class="mt-3 list-disc pl-5 text-[13px] text-slate-500">
      <li>Телефон в формате +7 (XXX) XXX-XX-XX</li>
      <li>Галочка согласия обязательна</li>
    </ul>
    <button type="button" data-booking-reminder-close class="mt-4 inline-flex rounded-[10px] bg-[#ec7c00] px-4 py-2 text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0">Понятно</button>
  </div>
</dialog>

<script>
  function initModal() {
    const modal = document.getElementById('bookingReminderModal') as HTMLDialogElement | null;
    if (!modal) return;

    modal.querySelector('[data-booking-reminder-close]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  }

  document.addEventListener('astro:page-load', initModal);
  initModal();
</script>
