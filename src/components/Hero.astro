        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.685-1.228A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.239 0-4.308-.724-5.993-1.953l-.42-.304-2.785.73.744-2.717-.334-.443A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          Отправить в WhatsApp
        </a>
        <a
          href="https://t.me/share/url?url=https%3A%2F%2Faidacamp.ru&text=%D0%9F%D1%80%D0%B8%D0%B2%D0%B5%D1%82!%20%D0%9F%D0%BE%D1%81%D0%BC%D0%BE%D1%82%D1%80%D0%B8%20%D0%BB%D0%B0%D0%B3%D0%B5%D1%80%D1%8C%20%D0%90%D0%B9%D0%94%D0%B0%D0%9A%D0%B5%D0%BC%D0%BF"
          target="_blank"
          rel="noopener"
          class="flex w-full items-center justify-center gap-2 rounded-[12px] bg-[#2AABEE] px-4 py-2.5 text-[14px] font-semibold text-white transition hover:brightness-110"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Отправить в Telegram
        </a>
        <button
          type="button"
          data-referral-copy
          class="flex w-full items-center justify-center gap-2 rounded-[12px] border border-slate-200 px-4 py-2.5 text-[14px] font-semibold text-slate-700 transition hover:bg-slate-50"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Скопировать ссылку
        </button>
      </div>

      <button
        type="button"
        data-referral-close
        class="mt-3 w-full text-center text-[13px] text-slate-400 transition hover:text-slate-600"
      >
        Пропустить
      </button>
    </div>

    <!-- Right column: merch (desktop: side-by-side, mobile: below) -->
    <div class="mt-4 rounded-[16px] bg-orange-50 p-3 lg:mt-0 lg:w-[280px] lg:shrink-0 lg:flex lg:flex-col lg:rounded-[16px] lg:overflow-hidden lg:bg-slate-50">
      <button type="button" data-merch-lightbox class="block w-full cursor-pointer">
        <img src="/images/merch-hoodie.avif"
             alt="Фирменный мерч АйДаКемп"
             class="w-full rounded-[12px] object-cover object-top aspect-[3/4] lg:rounded-none lg:aspect-auto lg:max-h-[300px]"
             loading="eager" decoding="async" width="400" height="400">
      </button>
      <div class="p-2 lg:p-3">
        <p class="text-[13px] font-semibold text-slate-900">Со знакомыми дети адаптируются быстрее</p>
        <p class="mt-1 text-[12px] text-slate-500">Приведи друга — подарим фирменный мерч обоим</p>
      </div>
    </div>
  </div>
</dialog>

<script>
  function initModal() {
    const modal = document.getElementById('bookingReminderModal') as HTMLDialogElement | null;
    if (!modal) return;

    modal.querySelector('[data-booking-reminder-close]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  }

  function initReferralModal() {
    const modal = document.getElementById('referralModal') as HTMLDialogElement | null;
    if (!modal) return;

    modal.querySelector('[data-referral-close]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal.querySelector('[data-referral-copy]')?.addEventListener('click', () => {
      navigator.clipboard.writeText('https://aidacamp.ru').then(() => {
        const btn = modal.querySelector('[data-referral-copy]');
        if (btn) {
          btn.textContent = 'Скопировано!';
          setTimeout(() => {
            btn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Скопировать ссылку';
          }, 2000);
        }
      });
    });

    // Merch photo lightbox
    modal.querySelector('[data-merch-lightbox]')?.addEventListener('click', () => {
      const lightbox = document.getElementById('galleryLightbox') as HTMLDialogElement | null;
      const lbImg = lightbox?.querySelector<HTMLImageElement>('[data-gallery-lightbox-img]');
      if (lightbox && lbImg) {
        lbImg.src = '/images/merch-hoodie.avif';
        lbImg.alt = 'Фирменный мерч АйДаКемп';
        const counter = lightbox.querySelector('[data-gallery-counter]');
        if (counter) counter.textContent = '';
        lightbox.showModal();
      }
    });
  }

  function initResponseTime() {
    const now = new Date();
    const msk = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Moscow' }));
    const hour = msk.getHours();

    let shortText: string;
    let stepsText: string;
    let modalText: string;

    if (hour >= 20) {
      // Вечер/ночь — завтра
      shortText = 'Свяжемся завтра с 11 до 12';
      stepsText = 'Оставьте заявку → свяжемся завтра с 11 до 12 → забронируем место · Фото детей каждый день в чат';
      modalText = 'Заявка принята! Свяжемся с вами завтра с 11 до 12. А пока — расскажите друзьям:';
    } else if (hour < 11) {
      // До 11 — сегодня
      shortText = 'Свяжемся сегодня с 11 до 12';
      stepsText = 'Оставьте заявку → свяжемся сегодня с 11 до 12 → забронируем место · Фото детей каждый день в чат';
      modalText = 'Заявка принята! Свяжемся с вами сегодня с 11 до 12. А пока — расскажите друзьям:';
    } else {
      // Рабочее время 11-19
      shortText = 'Свяжемся в течение 10 минут';
      stepsText = 'Оставьте заявку → свяжемся в течение 10 мин → забронируем место · Фото детей каждый день в чат';
      modalText = 'Свяжемся в течение 10 минут. А пока — расскажите друзьям про лагерь:';
    }

    document.querySelectorAll('[data-response-time]').forEach((el) => {
      el.textContent = shortText;
    });

    document.querySelectorAll('[data-response-time-steps]').forEach((el) => {
      el.textContent = stepsText;
    });

    const sub = document.getElementById('referralSubtext');
    if (sub) sub.textContent = modalText;
  }

  function checkHash() {
    if (window.location.hash === '#referral') {
      const modal = document.getElementById('referralModal') as HTMLDialogElement | null;
      modal?.showModal();
    }
  }

  document.addEventListener('astro:page-load', () => { initModal(); initReferralModal(); initResponseTime(); checkHash(); });
  initModal();
  initReferralModal();
  initResponseTime();
  checkHash();
</script>
