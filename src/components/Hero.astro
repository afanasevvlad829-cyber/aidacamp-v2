---
import LeadForm from './LeadForm.astro';
---

<section id="hero" class="relative mx-auto w-full bg-[#f7f5f2] lg:max-w-[1440px]">
  <!-- ===== MOBILE HERO ===== -->
  <div class="relative w-full bg-[#0d1a2b] lg:hidden">
    <!-- Photo with gradient fade to dark -->
    <div class="relative">
      <img
        src="/images/hero-custom-2026-04-07.avif"
        alt=""
        aria-hidden="true"
        class="w-full aspect-[4/3] object-cover object-[center_20%]"
        loading="eager"
        fetchpriority="high"
        width="1536"
        height="1024"
      />
      <!-- Side gradient -->
      <div class="absolute inset-0 bg-[linear-gradient(92deg,rgba(6,10,18,0.72)_0%,rgba(6,10,18,0.46)_42%,rgba(6,10,18,0.2)_70%,rgba(6,10,18,0.06)_100%)]"></div>
      <!-- Bottom fade to dark -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0d1a2b]"></div>

      <!-- Text over photo -->
      <div class="absolute bottom-6 left-5 right-5">
        <p class="text-[13px] tracking-[0.2px] text-white/80">
          <span class="text-orange-400">★ 5.0</span> на Яндекс Картах · 6 лет работы · 1200+ детей
        </p>
        <h1 id="hero-title-mobile" class="mt-1 text-[36px] font-bold leading-[1.1] tracking-[-0.03em] text-white">
          Летний лагерь<br /> в Подмосковье<br /> <span class="text-[#f5a624]">для детей</span>
        </h1>
        <p id="hero-subtitle-mobile" class="mt-2 text-[13px] text-white/60">
          Python · AI · Minecraft — проект за смену
        </p>
      </div>
    </div>

    <!-- Form area — same dark bg, seamless -->
    <div class="bg-[#0d1a2b] px-4 pb-6 pt-4">
      <!-- Info bar -->
      <div class="mb-4 flex items-center justify-between rounded-[12px] bg-white/10 px-4 py-2.5 text-[12px] text-white/80">
        <span>от 48 000 ₽ за 7 дней · 60% возвращаются снова</span>
        <span>✓ <span data-response-time>Ответим за 10 мин</span></span>
      </div>
      <!-- White card with form -->
      <LeadForm variant="mobile" />
    </div>
  </div>

  <!-- ===== DESKTOP HERO ===== -->
  <div class="relative hidden h-[620px] overflow-hidden bg-[#07101e] w-full lg:block lg:max-w-[1440px]">
    <!-- Photo full-bleed -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-custom-2026-04-07.avif"
        alt=""
        aria-hidden="true"
        class="absolute left-[-200px] h-full w-[1725px] object-cover"
        loading="eager"
        fetchpriority="high"
        width="1536"
        height="1024"
      />
    </div>

    <!-- Overlay: left (text readability) -->
    <div class="pointer-events-none absolute inset-y-0 left-0 w-[900px] bg-[linear-gradient(90deg,rgba(7,16,30,0.97)_0%,rgba(7,16,30,0.88)_38%,rgba(7,16,30,0.55)_62%,rgba(7,16,30,0.18)_82%,rgba(7,16,30,0)_100%)]"></div>
    <!-- Overlay: top vignette -->
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[220px] bg-[linear-gradient(180deg,rgba(7,16,30,0.55)_0%,rgba(7,16,30,0.12)_60%,rgba(7,16,30,0)_100%)]"></div>
    <!-- Overlay: right vignette -->
    <div class="pointer-events-none absolute inset-y-0 right-0 w-[320px] bg-[linear-gradient(90deg,rgba(7,16,30,0)_0%,rgba(7,16,30,0.25)_70%,rgba(7,16,30,0.55)_100%)]"></div>
    <!-- Overlay: bottom (transition to form) -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-[200px] bg-[linear-gradient(180deg,rgba(7,16,30,0)_0%,rgba(7,16,30,0.45)_70%,rgba(7,16,30,0.72)_100%)]"></div>

    <!-- Desktop Text Content -->
    <div class="absolute left-16 top-[78px] z-10">
      <p class="text-[11px] text-white/45">66 км от Москвы · смены июнь–август</p>
      <h1 id="hero-title" class="mt-[20px] w-[700px] text-[44px] font-bold leading-[52px] tracking-[-0.03em] text-white">
        Летний лагерь в Подмосковье<br /><span class="text-[#f5a624]">для детей 7–14 л��т</span>
      </h1>
      <p id="hero-subtitle" class="mt-3 w-[680px] text-[15px] leading-[1.6] text-white/65">
        Python, AI, Minecraft — ребёнок уедет с готовым проектом и презентацие��
      </p>
      <!-- Tags -->
      <div id="hero-badges" class="mt-3 flex gap-2">
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Python</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Minecraft</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">AI</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Бассейн</span>
      </div>
      <!-- Rating -->
      <p class="mt-3 text-[13px] text-white/50">
        <span class="mr-1 inline-flex items-center rounded-[5px] bg-[rgba(245,166,36,0.18)] px-1.5 py-0.5 text-[13px] font-bold text-[#f5a624]">★ 5.0</span>
        на Яндекс Картах �� 6 лет работы · 1200+ детей
      </p>
      <!-- Italic lines -->
      <p class="mt-[37px] text-[18px] italic text-white/82">45 мест в смене. 14 дней — ваши.</p>
      <p class="mt-[26px] text-[18px] italic text-white/82">Вы ведь тоже заслужили лето.</p>
      <!-- Agree button (placeholder — filled in commit 4) -->
      <button
        type="button"
        id="hero-agree-btn"
        class="absolute left-[286px] top-[275px] flex h-[26px] w-[104px] items-center justify-center rounded-[13px] border border-[rgba(245,166,36,0.45)] bg-[rgba(245,166,36,0.20)] text-[11px] font-semibold text-white/88 transition-colors hover:bg-[rgba(245,166,36,0.35)]"
      >Согласны? 👍 <span id="hero-agree-count">300</span></button>
    </div>

    <!-- Horizontal Booking Form -->
    <div class="absolute inset-x-6 -bottom-9 z-30 flex h-[72px] items-center gap-4 rounded-2xl bg-white/97 px-6 shadow-[0px_2px_8px_rgba(7,16,30,0.10),0px_8px_40px_rgba(7,16,30,0.28)]">
      <!-- A. Label -->
      <div class="w-[170px] shrink-0">
        <p class="text-[11px] font-semibold text-[rgba(109,123,138,0.65)]">Группа · возраст и уровень</p>
      </div>
      <!-- B. Age segmented control -->
      <div class="flex h-9 w-[180px] shrink-0 items-center rounded-[9px] border border-[rgba(58,72,92,0.12)] p-[2px]" role="radiogroup" aria-label="Возраст" data-hero-age-control>
        <button type="button" role="radio" aria-checked="false" data-hero-age-btn data-age-value="7–9 лет" class="flex h-8 flex-1 items-center justify-center rounded-[7px] text-[12px] font-semibold text-[rgba(109,123,138,0.65)] transition-all hover:text-[rgba(58,72,92,0.85)]">7–9</button>
        <button type="button" role="radio" aria-checked="false" data-hero-age-btn data-age-value="10–12 лет" class="flex h-8 flex-1 items-center justify-center rounded-[7px] text-[12px] font-semibold text-[rgba(109,123,138,0.65)] transition-all hover:text-[rgba(58,72,92,0.85)]">10–12</button>
        <button type="button" role="radio" aria-checked="false" data-hero-age-btn data-age-value="13–14 лет" class="flex h-8 flex-1 items-center justify-center rounded-[7px] text-[12px] font-semibold text-[rgba(109,123,138,0.65)] transition-all hover:text-[rgba(58,72,92,0.85)]">13–14</button>
      </div>
      <!-- C. Phone -->
      <input
        name="phone"
        type="tel"
        inputmode="tel"
        autocomplete="tel"
        maxlength="18"
        placeholder="+7 (___) ___-__-__"
        data-hero-phone-input
        class="h-9 w-[185px] shrink-0 rounded-[10px] border border-[rgba(58,72,92,0.15)] px-3 text-[13px] text-[#111827] outline-none placeholder:text-[rgba(109,123,138,0.45)] focus:border-[#ec7c00]"
      />
      <!-- D. Submit button -->
      <button
        type="button"
        data-hero-submit-btn
        disabled
        class="h-[38px] w-[128px] shrink-0 rounded-[10px] bg-[rgba(58,72,92,0.20)] text-[14px] font-semibold text-[rgba(58,72,92,0.35)] transition-all disabled:cursor-not-allowed"
      >Спросить...</button>
      <!-- E. Divider -->
      <div class="h-10 w-px shrink-0 bg-[rgba(58,72,92,0.10)]"></div>
      <!-- F. Right info -->
      <div class="flex min-w-0 flex-1 flex-col justify-center gap-0.5">
        <p class="text-[9px] text-[rgba(109,123,138,0.60)]">✓ Договор · ✓ Лицензия Минобра · ✓ Без скрытых доплат</p>
        <p class="text-[11px] font-medium text-[rgba(58,72,92,0.75)]">от 48 000 ₽ · питание и проживание включены</p>
        <label class="flex items-center gap-1 text-[9px] text-[rgba(109,123,138,0.50)]">
          <input type="checkbox" data-hero-consent class="h-3 w-3 rounded border border-slate-300 accent-[#ec7c00]" />
          Согласен с обработкой персональных данных
        </label>
      </div>
    </div>
  </div>

  <!-- Booking Section — Desktop (hidden, keeps data-booking-root for form mechanics) -->
  <section id="booking" class="relative mx-auto hidden w-full lg:block lg:max-w-[1440px]" data-booking-root>
    <LeadForm variant="desktop" />
  </section>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var content = params.get('utm_content');

      var variants = {
        nophone: {
          title: 'Телефон здесь зарабатывают',
          subtitle: 'Экранное время — за участие и инициативу, не выдаётся автоматически'
        },
        price: {
          title: 'IT-лагерь 7–14 лет от 48 900₽',
          subtitle: '7 дней: программирование, хакатон, бассейн — всё включено'
        },
        age: {
          title: 'Лагерь для детей 7–14 лет',
          subtitle: 'Учатся программировать и защищают свой проект'
        },
        parents: {
          title: 'Ребёнок вернётся с проектом',
          subtitle: 'Не просто лагерь — дети создают игры и приложения'
        },
        competitors: {
          title: 'Лучший IT-лагерь Подмосковья',
          subtitle: '66 км от Москвы, хакатон в финале каждой смены'
        }
      };

      var source = params.get('utm_source');

      var sourceVariants = {
        codims: {
          title: 'Попробовать IT за одно лето — и подтянуть информатику к сентябрю',
          subtitle: 'Берём с нуля. Опыт не нужен — за смену ребёнок создаст реальный проект и придёт в сентябрь с преимуществом',
          badge: 'Берём с нуля · опыт не нужен'
        }
      };

      var v = null;
      if (content && variants[content]) {
        v = variants[content];
      } else if (source && sourceVariants[source]) {
        v = sourceVariants[source];
      }

      if (v) {
        var titleEl = document.getElementById('hero-title');
        var titleMob = document.getElementById('hero-title-mobile');
        var subtitleEl = document.getElementById('hero-subtitle');
        var subtitleMob = document.getElementById('hero-subtitle-mobile');
        if (titleEl) titleEl.textContent = v.title;
        if (titleMob) titleMob.textContent = v.title;
        if (subtitleEl) subtitleEl.textContent = v.subtitle;
        if (subtitleMob) subtitleMob.textContent = v.subtitle;

        if (v.badge) {
          var badgesEl = document.getElementById('hero-badges');
          if (badgesEl) {
            badgesEl.innerHTML = '<span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">' + v.badge + '</span>';
          }
        }
      }
    })();
  </script>
</section>

<!-- Hero horizontal form logic -->
<script>
  import { trackGoal } from '../scripts/analytics';

  function initHeroForm() {
    const ageBtns = document.querySelectorAll<HTMLButtonElement>('[data-hero-age-btn]');
    const phoneInput = document.querySelector<HTMLInputElement>('[data-hero-phone-input]');
    const submitBtn = document.querySelector<HTMLButtonElement>('[data-hero-submit-btn]');
    const consentBox = document.querySelector<HTMLInputElement>('[data-hero-consent]');

    if (!submitBtn) return;

    let selectedAge = '';

    // Segmented control
    ageBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        ageBtns.forEach((b) => {
          b.classList.remove('bg-[#ec7c00]', 'text-white', 'font-bold');
          b.classList.add('text-[rgba(109,123,138,0.65)]', 'font-semibold');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.remove('text-[rgba(109,123,138,0.65)]', 'font-semibold');
        btn.classList.add('bg-[#ec7c00]', 'text-white', 'font-bold');
        btn.setAttribute('aria-checked', 'true');
        selectedAge = btn.dataset.ageValue || '';
        trackGoal('age_select', { age: selectedAge });
        updateHeroSubmit();
      });
    });

    // Phone formatting (same logic as LeadForm)
    function formatPhone(raw: string): string {
      let digits = raw.replace(/\D/g, '');
      if (digits.startsWith('8') && digits.length > 1) digits = '7' + digits.slice(1);
      if (!digits.startsWith('7') && digits.length > 0) digits = '7' + digits;
      digits = digits.slice(0, 11);
      if (digits.length === 0) return '';
      let out = '+7';
      if (digits.length > 1) out += ' (' + digits.slice(1, 4);
      if (digits.length >= 4) out += ') ' + digits.slice(4, 7);
      if (digits.length >= 7) out += '-' + digits.slice(7, 9);
      if (digits.length >= 9) out += '-' + digits.slice(9, 11);
      return out;
    }

    phoneInput?.addEventListener('input', () => {
      const pos = phoneInput.selectionStart || 0;
      const before = phoneInput.value.length;
      phoneInput.value = formatPhone(phoneInput.value);
      const after = phoneInput.value.length;
      phoneInput.setSelectionRange(pos + (after - before), pos + (after - before));
      updateHeroSubmit();
    });

    consentBox?.addEventListener('change', updateHeroSubmit);

    function isPhoneValid(): boolean {
      const digits = (phoneInput?.value || '').replace(/\D/g, '');
      return digits.length === 11 && digits.startsWith('7');
    }

    function updateHeroSubmit() {
      if (!submitBtn) return;
      const ageSelected = selectedAge !== '';
      if (ageSelected) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('bg-[rgba(58,72,92,0.20)]', 'text-[rgba(58,72,92,0.35)]');
        submitBtn.classList.add('bg-[#ec7c00]', 'text-white', 'shadow-[0px_4px_16px_rgba(236,124,0,0.35)]');
      } else {
        submitBtn.disabled = true;
        submitBtn.classList.add('bg-[rgba(58,72,92,0.20)]', 'text-[rgba(58,72,92,0.35)]');
        submitBtn.classList.remove('bg-[#ec7c00]', 'text-white', 'shadow-[0px_4px_16px_rgba(236,124,0,0.35)]');
      }
    }

    // Submit — proxy to the hidden LeadForm
    submitBtn.addEventListener('click', async () => {
      if (!selectedAge) return;

      // Validate phone + consent
      if (!isPhoneValid() || !consentBox?.checked) {
        const modal = document.getElementById('bookingReminderModal') as HTMLDialogElement | null;
        modal?.showModal();
        return;
      }

      trackGoal('form_submit', { form: 'booking_hero_horizontal', age: selectedAge });

      try {
        await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            phone: phoneInput?.value || '',
            age: selectedAge,
            shift: '',
            source: new URLSearchParams(window.location.search).get('utm_source') || '',
          }),
        });
        if (typeof _tmr !== 'undefined') {
          _tmr.push({ type: 'reachGoal', id: 3755202, value: 6375, goal: 'lead' });
        }
      } catch {}

      const referralModal = document.getElementById('referralModal') as HTMLDialogElement | null;
      referralModal?.showModal();
    });
  }

  // --- Agree button with like animation ---
  function initAgreeBtn() {
    const btn = document.getElementById('hero-agree-btn');
    const countEl = document.getElementById('hero-agree-count');
    if (!btn || !countEl) return;

    const STORAGE_KEY = 'hero_agree_count';
    let count = parseInt(localStorage.getItem(STORAGE_KEY) || '300', 10);
    if (isNaN(count) || count < 300) count = 300;
    countEl.textContent = String(count);

    btn.addEventListener('click', () => {
      count++;
      localStorage.setItem(STORAGE_KEY, String(count));
      countEl.textContent = String(count);

      // Animate "+1 👍" floating up
      const floater = document.createElement('span');
      floater.textContent = '+1 👍';
      floater.style.cssText = 'position:absolute;left:50%;top:-4px;transform:translateX(-50%);font-size:13px;font-weight:600;color:#f5a624;pointer-events:none;opacity:1;transition:all 0.8s ease-out;';
      btn.style.position = 'relative';
      btn.appendChild(floater);
      requestAnimationFrame(() => {
        floater.style.top = '-28px';
        floater.style.opacity = '0';
      });
      setTimeout(() => floater.remove(), 800);
    });
  }

  document.addEventListener('astro:page-load', () => { initHeroForm(); initAgreeBtn(); });
  initHeroForm();
  initAgreeBtn();
</script>

<!-- Validation Modal -->
<dialog
