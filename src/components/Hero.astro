---
import LeadForm from './LeadForm.astro';
import ValidationModal from './hero/ValidationModal.astro';
import ReferralModal from './hero/ReferralModal.astro';
---

<section id="hero" class="relative mx-auto w-full overflow-hidden bg-surface-warm md:max-w-[1440px]">
  <!-- ===== MOBILE HERO ===== -->
  <div class="relative w-full bg-dark-navy md:hidden">
    <!-- Photo with gradient fade to dark -->
    <div class="relative">
      <img
        src="/images/hero-custom-2026-04-07.avif"
        alt=""
        aria-hidden="true"
        class="w-full aspect-[4/3] object-cover object-[center_20%]"
        loading="eager"
        fetchpriority="high"
        width="1536"
        height="1024"
      />
      <!-- Side gradient -->
      <div class="absolute inset-0 bg-[linear-gradient(92deg,rgba(6,10,18,0.72)_0%,rgba(6,10,18,0.46)_42%,rgba(6,10,18,0.2)_70%,rgba(6,10,18,0.06)_100%)]"></div>
      <!-- Bottom fade to dark -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-dark-navy"></div>

      <!-- Text over photo -->
      <div class="absolute bottom-6 left-5 right-5">
        <p class="text-[13px] tracking-[0.2px] text-white/80">
          <span class="text-orange-400">★ 5.0</span> на Яндекс Картах · 6 лет работы · 1200+ детей
        </p>
        <h1 id="hero-title-mobile" class="mt-1 text-[36px] font-bold leading-[1.1] tracking-[-0.03em] text-white">
          Летний лагерь в Подмосковье [7–14]
        </h1>
        <p id="hero-subtitle-mobile" class="mt-2 flex items-center gap-2 text-[13px] text-white/60">
          Вам — 14 дней для себя. Согласны?
          <button type="button" id="hero-agree-btn-mobile"
                  class="inline-flex h-[22px] items-center gap-1 rounded-[11px]
                         border border-[rgba(245,166,36,0.45)]
                         bg-[rgba(245,166,36,0.20)] px-2
                         text-[10px] font-semibold text-white/88
                         hover:bg-[rgba(245,166,36,0.35)] transition">
            <i class="bi bi-hand-thumbs-up-fill text-[10px]"></i>
            <span id="hero-agree-count-mobile">301</span>
          </button>
        </p>
      </div>
    </div>

    <!-- Form area — same dark bg, seamless -->
    <div class="bg-dark-navy px-4 pb-6 pt-4">
      <!-- Info bar -->
      <div class="mb-4 flex items-center justify-between rounded-[12px] bg-white/10 px-4 py-2.5 text-[12px] text-white/80">
        <span>от 48 000 ₽ за 7 дней</span>
        <span>✓ <span data-response-time>Ответим за 10 мин</span></span>
      </div>
      <!-- White card with form -->
      <LeadForm variant="mobile" />
    </div>
  </div>

  <!-- ===== DESKTOP HERO ===== -->
  <div class="relative hidden h-[520px] overflow-hidden bg-[#0f1c2e] w-full md:block md:max-w-[1440px]">
    <img
      src="/images/hero-custom-2026-04-07.avif"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
      loading="eager"
      fetchpriority="high"
      width="1536"
      height="1024"
    />

    <!-- Desktop Overlays -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,9,18,0.78)_0%,rgba(5,9,18,0.62)_26%,rgba(5,9,18,0.34)_48%,rgba(5,9,18,0.12)_66%,rgba(5,9,18,0.02)_82%,rgba(5,9,18,0)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,10,18,0)_52%,rgba(6,10,18,0.22)_74%,rgba(6,10,18,0.42)_100%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(140%_120%_at_50%_50%,rgba(0,0,0,0)_58%,rgba(0,0,0,0.12)_84%,rgba(0,0,0,0.24)_100%)] mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(236,124,0,0.09)_0%,rgba(236,124,0,0.04)_30%,rgba(236,124,0,0)_62%)] mix-blend-soft-light"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent pointer-events-none"></div>
    </div>

    <!-- Desktop Text Content -->
    <div class="absolute left-16 top-[78px] z-10">

      <!-- Геолокация -->
      <p class="text-[13px] text-white/50 whitespace-nowrap">
        66 км от Москвы · смены июнь–август
      </p>

      <!-- H1: 44px Bold, обе строки белые -->
      <h1 id="hero-title"
          class="mt-2 w-[700px] text-[44px] font-bold leading-[52px]
                 tracking-[-0.03em] text-white
                 [text-shadow:0px_4px_12px_rgba(0,0,0,0.35)]">
        Летний лагерь в Подмосковье [7–14]
      </h1>

      <p id="hero-subtitle" class="mt-2 text-[15px] text-white/65">
        Каждый уедет с проектом и новыми друзьями.
      </p>
      <p class="mt-1 flex items-center gap-3 text-[15px] text-white/65">
        Вам — 14 дней для себя. Согласны?
        <button type="button" id="hero-agree-btn"
                class="inline-flex h-[26px] items-center gap-1.5 rounded-[13px]
                       border border-[rgba(245,166,36,0.45)]
                       bg-[rgba(245,166,36,0.20)] px-3
                       text-[11px] font-semibold text-white/88
                       hover:bg-[rgba(245,166,36,0.35)] transition">
          <i class="bi bi-hand-thumbs-up-fill text-[12px]"></i>
          <span id="hero-agree-count">301</span>
        </button>
      </p>

      <!-- Теги -->
      <div id="hero-badges" class="mt-3 flex gap-2">
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Python</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Minecraft</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">AI</span>
        <span class="flex h-[26px] items-center rounded-full bg-white/12 px-3 text-[12px] text-white/85">Бассейн</span>
      </div>

      <!-- Рейтинг -->
      <p class="mt-3 text-[13px] text-white/50">
        <span class="mr-1 inline-flex items-center rounded-[5px] bg-[rgba(245,166,36,0.18)] px-1.5 py-0.5 text-[13px] font-bold text-[#f5a624]">★ 5.0</span>
        на Яндекс Картах · 6 лет работы · 1200+ детей
      </p>

      <!-- Ссылка к сменам -->
      <a
        href="#shifts"
        class="mt-5 inline-flex items-center gap-2 rounded-[14px] bg-[#ec7c00] hover:bg-[#d46e00] px-6 py-3 text-[15px] font-semibold text-white shadow-[0_4px_16px_rgba(236,124,0,0.35)] transition-all duration-200 hover:-translate-y-[1px] hover:shadow-[0_6px_20px_rgba(236,124,0,0.45)]"
      >
        Смены 2026
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </a>

    </div>

    <!-- Информационная полоса — bottom Hero -->
    <div class="absolute bottom-0 inset-x-0 z-20 border-t border-white/8 bg-black/25 backdrop-blur-sm">
      <div class="mx-auto max-w-[1312px] px-6 py-2.5">
        <a href="#shifts" class="block text-[11px] text-white/55 text-center leading-relaxed hover:text-white/75 transition-colors">
          от 48 000 ₽ за 7 дней · 60% возвращаются снова · проживание, питание, программа включены · Трансфер — опция
        </a>
      </div>
    </div>

  </div>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var content = params.get('utm_content');
      var source = params.get('utm_source');

      // utm_content variants (Директ + ВК)
      var variants = {
        // Директ
        nophone:     { title: 'Телефон здесь зарабатывают', subtitle: 'Экранное время — за участие и инициативу, не выдаётся автоматически' },
        price:       { title: 'IT-лагерь 7–14 лет от 48 900₽', subtitle: '7 дней: программирование, хакатон, бассейн — всё включено' },
        age:         { title: 'Лагерь для детей 7–14 лет', subtitle: 'Учатся программировать и защищают свой проект' },
        parents:     { title: 'Ребёнок вернётся с проектом', subtitle: 'Не просто лагерь — дети создают игры и приложения' },
        competitors: { title: 'Лучший IT-лагерь Подмосковья', subtitle: '66 км от Москвы, хакатон в финале каждой смены' },
        // ВК — PROBLEM
        telefon:     { title: 'Перестаёт сидеть в телефоне? IT-лагерь это исправит' },
        nichego:     { title: 'Ничего не хочет? В лагере это исчезает на 3-й день' },
        leto:        { title: 'Лето может пройти иначе — IT-лагерь под Москвой' },
        // ВК — INTENT
        lager:       { title: 'Летний лагерь под Москвой — IT, проекты, бассейн' },
        it_lager:    { title: 'IT-лагерь для детей — Python, Minecraft, свой проект' },
        chem_zanyat: { title: 'Чем занять ребёнка летом? IT-лагерь — проект за 7 дней' },
        // ВК — CRM
        next_step:   { title: 'Этим летом — не просто отдых. IT-лагерь для тех, кто знает нас' },
        polza:       { title: 'Лето с пользой для ребёнка — IT-лагерь 66 км от Москвы' },
        proekt:      { title: 'За 7 дней — свой проект. Бассейн, команда, настоящее лето' }
      };

      // utm_source variants
      var sourceVariants = {
        codims: {
          title: 'Попробовать IT за одно лето — и подтянуть информатику к сентябрю',
          subtitle: 'Берём с нуля. Опыт не нужен — за смену ребёнок создаст реальный проект и придёт в сентябрь с преимуществом',
          badge: 'Берём с нуля · опыт не нужен'
        }
      };

      var v = null;
      if (content && variants[content]) {
        v = variants[content];
      } else if (source && sourceVariants[source]) {
        v = sourceVariants[source];
      }

      if (v) {
        var titleEl = document.getElementById('hero-title');
        var titleMob = document.getElementById('hero-title-mobile');
        var subtitleEl = document.getElementById('hero-subtitle');
        var subtitleMob = document.getElementById('hero-subtitle-mobile');
        if (v.title) {
          if (titleEl) titleEl.textContent = v.title;
          if (titleMob) titleMob.textContent = v.title;
        }
        if (v.subtitle) {
          if (subtitleEl) subtitleEl.textContent = v.subtitle;
          if (subtitleMob) subtitleMob.textContent = v.subtitle;
        }
        if (v.badge) {
          var badgesEl = document.getElementById('hero-badges');
          if (badgesEl) {
            badgesEl.innerHTML = '<span class="rounded-[20px] border border-white/18 bg-white/12 px-[10px] py-1 text-[12px] text-white/85 [text-shadow:0px_2px_4px_rgba(0,0,0,0.34)]">' + v.badge + '</span>';
          }
        }
      }
    })();
  </script>
</section>

<ValidationModal />
<ReferralModal />

<script>
  import { initDialog } from '../scripts/dialog';

  function initModals() {
    initDialog('bookingReminderModal', '[data-booking-reminder-close]');

    const referralModal = initDialog('referralModal', '[data-referral-close]');
    referralModal?.querySelector('[data-referral-copy]')?.addEventListener('click', () => {
      navigator.clipboard.writeText('https://aidacamp.ru').then(() => {
        const btn = referralModal.querySelector('[data-referral-copy]');
        if (btn) {
          btn.textContent = 'Скопировано!';
          setTimeout(() => {
            btn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Скопировать ссылку';
          }, 2000);
        }
      });
    });
  }

  function initResponseTime() {
    const now = new Date();
    const msk = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Moscow' }));
    const hour = msk.getHours();
    const isNight = hour >= 20 || hour < 11;

    // Hero info bar + anywhere with data-response-time
    document.querySelectorAll('[data-response-time]').forEach((el) => {
      el.textContent = isNight ? 'Свяжемся с 11 до 12 МСК' : 'Перезвоним за 10 минут';
    });

    // Steps under form button
    document.querySelectorAll('[data-response-time-steps]').forEach((el) => {
      el.textContent = isNight
        ? 'Оставьте заявку → свяжемся с 11 до 12 МСК → забронируем место'
        : 'Оставьте заявку → перезвоним за 10 мин → забронируем место';
    });

    // Referral modal subtext
    const sub = document.getElementById('referralSubtext');
    if (sub) {
      sub.textContent = isNight
        ? 'Мы бы перезвонили за 10 минут, но сейчас ночь 🌙 Свяжемся с вами с 11 до 12 МСК. А пока — расскажите друзьям:'
        : 'Мы перезвоним в течение 10 минут. А пока — расскажите друзьям про лагерь:';
    }
  }

  function initAgreeButton() {
    const btns = [
      { btn: document.getElementById('hero-agree-btn'), count: document.getElementById('hero-agree-count') },
      { btn: document.getElementById('hero-agree-btn-mobile'), count: document.getElementById('hero-agree-count-mobile') },
    ].filter(x => x.btn && x.count) as { btn: HTMLElement; count: HTMLElement }[];

    if (!btns.length) return;

    // восстановить счётчик из localStorage
    const stored = localStorage.getItem('hero_agree_count');
    if (stored) btns.forEach(x => x.count.textContent = stored);

    let clicked = false;

    function handleClick(agreeBtn: HTMLElement) {
      if (clicked) return;
      clicked = true;

      if (typeof ym !== 'undefined') {
        ym(96499295, 'reachGoal', 'agree');
      }

      // увеличить счётчик на всех кнопках
      const newCount = parseInt(btns[0].count.textContent || '301') + 1;
      btns.forEach(x => x.count.textContent = String(newCount));
      localStorage.setItem('hero_agree_count', String(newCount));

      // анимация — пульс на кнопке
      agreeBtn.style.transition = 'transform 0.15s ease, background 0.15s ease';
      agreeBtn.style.transform = 'scale(1.18)';
      agreeBtn.style.background = 'rgba(245,166,36,0.38)';
      setTimeout(() => {
        agreeBtn.style.transform = 'scale(1)';
        agreeBtn.style.background = 'rgba(245,166,36,0.20)';
      }, 180);

      // всплывающий +1
      const pop = document.createElement('span');
      pop.textContent = '+1';
      pop.style.cssText = `
        position: absolute;
        font-size: 12px;
        font-weight: 600;
        color: #f5a624;
        pointer-events: none;
        white-space: nowrap;
        opacity: 1;
        transform: translateY(0px);
        transition: opacity 1.4s ease, transform 1.4s ease;
      `;

      agreeBtn.style.position = 'relative';
      agreeBtn.appendChild(pop);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          pop.style.opacity = '0';
          pop.style.transform = 'translateY(-30px)';
        });
      });

      setTimeout(() => pop.remove(), 1500);
    }

    btns.forEach(x => x.btn.addEventListener('click', () => handleClick(x.btn)));
  }

  document.addEventListener('astro:page-load', () => { initModals(); initResponseTime(); initAgreeButton(); });
  initModals();
  initResponseTime();
  initAgreeButton();
</script>
