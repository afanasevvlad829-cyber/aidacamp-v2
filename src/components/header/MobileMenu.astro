---
import { PHONE_MAIN_HREF, WHATSAPP_URL, TELEGRAM_URL } from '../../data/contacts';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden flex-col bg-[rgba(7,14,26,0.96)] backdrop-blur-lg"
>
  <div class="flex h-14 items-center justify-between px-4">
    <button
      type="button"
      id="mobile-menu-close"
      class="flex h-10 w-10 items-center justify-center rounded-xl text-white"
      aria-label="Закрыть меню"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <span class="text-sm font-semibold text-white">Меню</span>
    <div class="w-10"></div>
  </div>
  <div class="flex flex-1 flex-col gap-1 overflow-y-auto p-4">
    {items.map((item) => (
      <a
        href={item.href}
        class="mobile-nav-link rounded-xl px-4 py-4 text-[22px] font-semibold text-white/90 transition hover:bg-white/10"
        data-analytics-goal="nav_click"
        data-analytics-label={item.label}
      >
        {item.label}
      </a>
    ))}
  </div>
  <div class="border-t border-white/10 p-4">
    <a href={PHONE_MAIN_HREF} class="mb-2 block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white">
      +7 (495) 128-44-29
    </a>
    <div class="flex gap-2">
      <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex-1 rounded-xl border border-white/20 py-2.5 text-center text-sm font-medium text-white/90">WhatsApp</a>
      <a href={TELEGRAM_URL} target="_blank" rel="noopener" class="flex-1 rounded-xl border border-white/20 py-2.5 text-center text-sm font-medium text-white/90">Telegram</a>
    </div>
  </div>
</nav>
