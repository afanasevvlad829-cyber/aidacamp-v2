---
interface Props {
  sections: Array<{
    h2: string
    text: string
    list?: string[]
  }>
}

const { sections } = Astro.props;
---

<div class="mx-auto max-w-[1312px] px-4 pt-8 pb-10 md:pt-10 md:pb-16">
  {sections.map((section, i) => (
    <div class={i > 0 ? "mt-10 border-t border-slate-100 pt-10" : ""}>

      <!-- H2 with orange stripe -->
      <div class="flex items-center gap-2 mb-4">
        <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
        <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
          {section.h2}
        </h2>
      </div>

      <!-- Text -->
      {section.text && (
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px]">
          {section.text}
        </p>
      )}

      <!-- List (optional) -->
      {section.list && (
        <ul class="mt-4 flex flex-col gap-2">
          {section.list.map((item) => (
            <li class="flex items-start gap-2.5">
              <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
              <span class="text-[15px] text-slate-700">{item}</span>
            </li>
          ))}
        </ul>
      )}

    </div>
  ))}
</div>
