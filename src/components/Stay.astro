---
const rooms = [
  {
    title: 'Комнаты размещения',
    image: '/images/stay/stay-room-01.avif',
    alt: 'Комнаты проживания в лагере АйДаКемп — 2-4 человека',
    description: 'Светлые комнаты и спокойный бытовой режим.',
  },
  {
    title: 'Санузлы и бытовые зоны',
    image: '/images/stay/stay-bathroom-01.avif',
    alt: 'Санузлы и бытовые зоны в лагере АйДаКемп',
    description: 'Чистые бытовые зоны и регулярный контроль.',
  },
  {
    title: 'Общие пространства',
    image: '/images/stay/stay-lounge-01.avif',
    alt: 'Общие пространства для отдыха в лагере АйДаКемп',
    description: 'Пространства для отдыха и командных занятий.',
  },
];
---

<section id="stay" class="mx-auto max-w-[1312px] px-[2px] pt-6 md:px-4">
  <div class="bg-surface-warm p-[18px]">
    <div class="flex items-center gap-2 mb-1"><div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div><h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Размещение</h2></div>
    <p class="text-[13px] text-slate-500 mt-1">2–4 человека в комнате · Охрана 24/7 · 5-разовое питание</p>

    <p class="mt-4 text-[11px] font-medium text-slate-400 mt-0.5 md:hidden">свайп →</p>
    <div class="mt-1 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden md:grid md:grid-cols-3 md:gap-4 md:overflow-visible md:pb-0" data-stay-track>
      {rooms.map((room, i) => (
        <article class="min-w-[90vw] snap-start overflow-hidden rounded-[22px] shadow-[0_6px_18px_rgba(15,23,42,0.08)] md:min-w-0">
          <button type="button" data-stay-open data-stay-index={i} class="group relative block h-[260px] w-full overflow-hidden text-left">
            <img src={room.image} alt={room.alt} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" width="600" height="260" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="text-[18px] font-semibold text-white">{room.title}</h3>
              <p class="mt-1 text-[13px] leading-[1.5] text-white/80">{room.description}</p>
            </div>
          </button>
        </article>
      ))}
    </div>
    <!-- Dots indicator (mobile) -->
    <div class="mt-3 flex justify-center gap-1.5 md:hidden" data-stay-dots>
      {rooms.map((_, i) => (
        <span class={`h-1.5 w-1.5 rounded-full transition-colors ${i === 0 ? 'bg-primary-light' : 'bg-slate-300'}`} data-stay-dot={i}></span>
      ))}
    </div>
  </div>
</section>

<!-- Stay lightbox -->
<dialog id="stayLightbox" class="m-0 h-full w-full max-w-none border-0 outline-none bg-black/90 p-4 backdrop:bg-black/90">
  <div class="flex h-full items-center justify-center">
    <!-- Close -->
    <button type="button" data-stay-close aria-label="Закрыть" class="absolute right-4 top-4 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white outline-none focus:outline-none focus:ring-0 focus-visible:outline-none">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>

    <!-- Prev (desktop only) -->
    <button type="button" data-stay-prev aria-label="Назад" class="absolute left-4 top-1/2 z-10 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white md:flex">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
    </button>

    <!-- Next (desktop only) -->
    <button type="button" data-stay-next aria-label="Вперёд" class="absolute right-4 top-1/2 z-10 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white md:flex">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </button>

    <div class="flex flex-col items-center">
      <img id="stayLightboxImg" src="" alt="" class="max-h-[80vh] max-w-full rounded-[18px] object-contain" width="800" height="600" />
      <p id="stayLightboxCaption" class="mt-3 text-center text-[14px] text-white/80"></p>
      <p id="stayLightboxCounter" class="mt-1 text-center text-[12px] text-white/50"></p>
    </div>
  </div>
</dialog>

<script>
  function initStay() {
    // Mobile dots
    const stayTrack = document.querySelector<HTMLElement>('[data-stay-track]');
    const stayDots = document.querySelectorAll<HTMLElement>('[data-stay-dot]');
    if (stayTrack && stayDots.length) {
      const stayCards = Array.from(stayTrack.children) as HTMLElement[];
      const stayObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = stayCards.indexOf(entry.target as HTMLElement);
            stayDots.forEach((d, di) => {
              d.classList.toggle('bg-primary-light', di === idx);
              d.classList.toggle('bg-slate-300', di !== idx);
            });
          }
        });
      }, { root: stayTrack, threshold: 0.6 });
      stayCards.forEach((c) => stayObs.observe(c));
    }

    const modal = document.getElementById('stayLightbox') as HTMLDialogElement | null;
    const img = document.getElementById('stayLightboxImg') as HTMLImageElement | null;
    const caption = document.getElementById('stayLightboxCaption');
    const counter = document.getElementById('stayLightboxCounter');
    if (!modal || !img) return;

    const photos = [
      { src: '/images/stay/stay-room-01.avif', alt: 'Комнаты проживания в лагере АйДаКемп — 2-4 человека' },
      { src: '/images/stay/stay-bathroom-01.avif', alt: 'Санузлы и бытовые зоны в лагере АйДаКемп' },
      { src: '/images/stay/stay-lounge-01.avif', alt: 'Общие пространства для отдыха в лагере АйДаКемп' },
    ];

    let current = 0;

    function show(index: number) {
      current = ((index % photos.length) + photos.length) % photos.length;
      img!.src = photos[current].src;
      img!.alt = photos[current].alt;
      if (caption) caption.textContent = photos[current].alt;
      if (counter) counter.textContent = `${current + 1} / ${photos.length}`;
    }

    // Open on card click
    document.querySelectorAll('[data-stay-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number((btn as HTMLElement).dataset.stayIndex);
        show(idx);
        modal.showModal();
      });
    });

    // Close
    function closeLightbox() {
      img!.src = '';
      modal.close();
    }

    modal.querySelector('[data-stay-close]')?.addEventListener('click', closeLightbox);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeLightbox(); });

    // Arrows
    modal.querySelector('[data-stay-prev]')?.addEventListener('click', () => show(current - 1));
    modal.querySelector('[data-stay-next]')?.addEventListener('click', () => show(current + 1));

    // Keyboard arrows
    modal.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    // Swipe on mobile
    let touchStartX = 0;
    modal.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    modal.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        show(diff > 0 ? current + 1 : current - 1);
      }
    });
  }

  document.addEventListener('astro:page-load', initStay);
  initStay();
</script>
