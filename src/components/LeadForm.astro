---
interface Props {
  variant: 'desktop' | 'mobile';
}

const { variant } = Astro.props;
const isDesktop = variant === 'desktop';

const containerClass = isDesktop
  ? 'absolute right-[24px] lg:right-[40px] top-[-440px] z-30 w-[320px] rounded-[28px] bg-white/95 backdrop-blur-sm p-[22px] shadow-[0_16px_48px_rgba(15,23,42,0.18)] xl:right-[calc((100%-1312px)/2+40px)]'
  : 'relative w-full rounded-[20px] bg-white px-5 pb-6 pt-4 shadow-[0_16px_48px_rgba(0,0,0,0.3)]';

const inputWidth = isDesktop ? 'w-[276px]' : 'w-full';
---

<form
  data-form={`booking_${variant}`}
  class={containerClass}
  novalidate
>
  <!-- Age Selection -->
  <p class="text-[12px] font-semibold uppercase tracking-[0.6px] text-[#4b5563]">Возраст</p>
  <input type="hidden" name="age" value="10–12" data-age-input />
  <div class={`mt-1 flex h-[34px] ${inputWidth} gap-[6px]`} role="radiogroup" aria-label="Возраст">
    <button
      type="button"
      role="radio"
      aria-checked="false"
      data-age-btn
      data-age-value="7–10 лет"
      data-analytics-goal="age_select"
      data-analytics-label={`7–10 лет-${variant}`}
      class="flex-1 rounded-[8px] border-[1.5px] border-[#e6e6e6] bg-white py-2 text-[13px] font-semibold text-[#333] transition"
    >
      7–10 лет
    </button>
    <button
      type="button"
      role="radio"
      aria-checked="true"
      data-age-btn
      data-age-value="10–12 лет"
      data-analytics-goal="age_select"
      data-analytics-label={`10–12 лет-${variant}`}
      class="flex-1 rounded-[8px] border-[1.5px] border-[#ec7c00] bg-[#ec7c00] py-2 text-[13px] font-semibold text-white transition"
    >
      10–12 лет
    </button>
    <button
      type="button"
      role="radio"
      aria-checked="false"
      data-age-btn
      data-age-value="13–14 лет"
      data-analytics-goal="age_select"
      data-analytics-label={`13–14 лет-${variant}`}
      class="flex-1 rounded-[8px] border-[1.5px] border-[#e6e6e6] bg-white py-2 text-[13px] font-semibold text-[#333] transition"
    >
      13–14 лет
    </button>
  </div>

  <!-- Phone Input -->
  <p class="mt-3 text-[12px] font-semibold uppercase tracking-[0.6px] text-[#4b5563]">Ваш телефон</p>
  <input
    name="phone"
    type="tel"
    inputmode="tel"
    autocomplete="tel"
    maxlength="18"
    placeholder="+7 (___) ___-__-__"
    data-phone-input
    class={`mt-2 h-[42px] ${inputWidth} rounded-[8px] border-[1.5px] border-[#e6e6e6] bg-white px-[14px] text-[13px] text-[#111827] outline-none transition placeholder:text-[#919cab] focus:border-[#ec7c00]`}
  />

  <!-- Consent -->
  <label class={`mt-3 flex ${inputWidth} items-start gap-2 text-[12px] leading-[1.35] text-[#4b5563]`}>
    <input type="checkbox" data-consent class="mt-[2px] h-4 w-4 rounded border border-slate-300 accent-[#ec7c00]" />
    <span>Согласен(а) на <a href="/legal#privacy" class="text-[#ec7c00] underline">обработку персональных данных</a></span>
  </label>

  <!-- Submit -->
  <button
    type="submit"
    data-submit-btn
    data-analytics-goal="form_open"
    data-analytics-extra-goal="booking_cta_click,hero_cta_click,hero_variant_form_open_new"
    data-analytics-label={`booking_${variant}_cta`}
    class={`mt-3 h-[44px] ${inputWidth} rounded-[10px] bg-[#ec7c00] text-[13px] font-semibold text-white transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0 disabled:cursor-not-allowed disabled:bg-[#f2b178]`}
    disabled
  >
    Забронировать место
  </button>
  <p class={`${inputWidth} text-[12px] text-slate-400 text-center mt-2`} data-response-time-steps>Оставьте заявку → свяжемся в течение 10 мин → забронируем место · Фото детей каждый день в чат</p>

  <!-- Trust -->
  <p class={`mt-1 ${inputWidth} text-center text-[13px] text-[#8c8c8c]`}>
    Лицензия и договор · Без скрытых доплат
  </p>

  {!isDesktop && (
    <div class="mt-3 flex w-full justify-between text-[12px] text-[#999]">
      <span>✓ Без оплаты</span>
      <span>✓ Договор</span>
      <span>✓ Трансфер — опция</span>
    </div>
  )}
</form>

<script>
  import { trackGoal } from '../scripts/analytics';

  function initForms() {
    document.querySelectorAll<HTMLFormElement>('[data-form]').forEach((form) => {
      const ageInput = form.querySelector<HTMLInputElement>('[data-age-input]');
      const phoneInput = form.querySelector<HTMLInputElement>('[data-phone-input]');
      const consent = form.querySelector<HTMLInputElement>('[data-consent]');
      const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit-btn]');
      const ageBtns = form.querySelectorAll<HTMLButtonElement>('[data-age-btn]');

      // Age selection
      ageBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          ageBtns.forEach((b) => {
            b.classList.remove('border-[#ec7c00]', 'bg-[#ec7c00]', 'text-white');
            b.classList.add('border-[#e6e6e6]', 'bg-white', 'text-[#333]');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.remove('border-[#e6e6e6]', 'bg-white', 'text-[#333]');
          btn.classList.add('border-[#ec7c00]', 'bg-[#ec7c00]', 'text-white');
          btn.setAttribute('aria-checked', 'true');
          if (ageInput) ageInput.value = btn.dataset.ageValue || '';
          trackGoal('age_select', { age: btn.dataset.ageValue });
        });
      });

      // Phone formatting
      function formatPhone(raw: string): string {
        let digits = raw.replace(/\D/g, '');
        if (digits.startsWith('8') && digits.length > 1) digits = '7' + digits.slice(1);
        if (!digits.startsWith('7') && digits.length > 0) digits = '7' + digits;
        digits = digits.slice(0, 11);

        if (digits.length === 0) return '';
        let out = '+7';
        if (digits.length > 1) out += ' (' + digits.slice(1, 4);
        if (digits.length >= 4) out += ') ' + digits.slice(4, 7);
        if (digits.length >= 7) out += '-' + digits.slice(7, 9);
        if (digits.length >= 9) out += '-' + digits.slice(9, 11);
        return out;
      }

      phoneInput?.addEventListener('input', () => {
        const pos = phoneInput.selectionStart || 0;
        const before = phoneInput.value.length;
        phoneInput.value = formatPhone(phoneInput.value);
        const after = phoneInput.value.length;
        phoneInput.setSelectionRange(pos + (after - before), pos + (after - before));
        updateSubmit();
      });

      consent?.addEventListener('change', updateSubmit);

      function isPhoneValid(): boolean {
        const digits = (phoneInput?.value || '').replace(/\D/g, '');
        return digits.length === 11 && digits.startsWith('7');
      }

      function updateSubmit() {
        if (submitBtn) {
          submitBtn.disabled = !(isPhoneValid() && consent?.checked);
        }
      }

      // Form submit
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!isPhoneValid() || !consent?.checked) {
          const modal = document.getElementById('bookingReminderModal') as HTMLDialogElement | null;
          modal?.showModal();
          return;
        }

        trackGoal('form_submit', {
          form: form.dataset.form,
          age: ageInput?.value,
        });

        try {
          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              phone: phoneInput?.value || '',
              age: ageInput?.value || '',
              shift: '',
              source: new URLSearchParams(window.location.search).get('utm_source') || '',
            }),
          });
          await res.json();
          // VK/Mail.ru pixel — реальная конверсия
          if (typeof _tmr !== 'undefined') {
            _tmr.push({ type: 'reachGoal', id: 3755202, value: 6375, goal: 'lead'});
          }
        } catch {}

        const referralModal = document.getElementById('referralModal') as HTMLDialogElement | null;
        referralModal?.showModal();
      });
    });
  }

  // Support Astro view transitions
  document.addEventListener('astro:page-load', initForms);
  initForms();
</script>
