---
const schedule = [
  { time: '8:00', text: 'Подъём, завтрак' },
  { time: '9:30', text: 'Первый блок: программирование и работа над проектом' },
  { time: '12:00', text: 'Спорт, бассейн или чемпионат лагеря' },
  { time: '13:30', text: 'Обед' },
  { time: '15:00', text: 'Второй блок: продолжение проекта' },
  { time: '18:00', text: 'Свободное время' },
  { time: '19:00', text: 'Ужин' },
  { time: '20:30', text: 'Вечерняя активность' },
  { time: '22:00', text: 'Отбой' },
];

const ageCards = [
  {
    icon: 'users',
    title: '7–9 лет',
    text: 'Первые игры: персонаж, движение, счёт, простые механики',
  },
  {
    icon: 'code',
    title: '10–12 лет',
    text: 'Игры с уровнями, логикой и системой взаимодействия',
  },
  {
    icon: 'cpu',
    title: '13–14 лет',
    text: 'Проекты с элементами AI: вариативное поведение, генерация событий',
  },
];
---

<section id="journey" class="mx-auto max-w-[1312px] px-[2px] pt-8 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
      <h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Как проходит смена</h2>
    </div>

    <!-- Tabs -->
    <div class="mt-5 flex gap-2">
      <button type="button" data-journey-tab="program" class="flex-1 rounded-lg px-4 py-2.5 text-[14px] font-semibold transition md:flex-none md:px-6 bg-[#ec7c00] text-white">Программа</button>
      <button type="button" data-journey-tab="day" class="flex-1 rounded-lg px-4 py-2.5 text-[14px] font-semibold transition md:flex-none md:px-6 bg-slate-100 text-slate-700">День в лагере</button>
    </div>

    <!-- Tab 1: Программа -->
    <div data-journey-panel="program" class="mt-6">
      <h3 class="text-[20px] font-bold leading-[1.2] text-slate-900 md:text-[24px]">Мы не играем в игры — мы их создаём</h3>
      <p class="mt-2 text-[15px] leading-[1.5] text-slate-600 md:text-[16px]">Приезжают без опыта. Уезжают с игрой.</p>
      <p class="mt-3 text-[14px] leading-[1.65] text-slate-600 md:text-[15px]">С первого дня — практика. Не теория, не видеоуроки, а реальная работа: персонаж, движение, механика, уровень. К середине смены уже есть что запустить и показать. К финалу — готовый проект, сделанный своими руками.</p>

      <div class="mt-6 grid gap-3 md:grid-cols-3 md:gap-4">
        {ageCards.map((card) => (
          <div class="rounded-[16px] border border-slate-200 bg-slate-50 p-4 md:p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[#fff2e3]">
              {card.icon === 'users' && (
                <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
              )}
              {card.icon === 'code' && (
                <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>
              )}
              {card.icon === 'cpu' && (
                <svg class="h-5 w-5 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" /></svg>
              )}
            </div>
            <h4 class="mt-3 text-[16px] font-semibold text-slate-900">{card.title}</h4>
            <p class="mt-1.5 text-[14px] leading-[1.6] text-slate-600">{card.text}</p>
          </div>
        ))}
      </div>

      <p class="mt-4 text-[13px] text-slate-400">Опыт программирования не нужен. Нужно только желание что-то сделать.</p>
    </div>

    <!-- Tab 2: День в лагере -->
    <div data-journey-panel="day" class="mt-6 hidden">
      <div class="flex flex-col-reverse gap-6 md:flex-row md:gap-8">
        <!-- Левая колонка: расписание -->
        <div class="md:w-[55%]">
          <div class="space-y-0">
            {schedule.map((item, i) => (
              <div class="flex gap-3 md:gap-4">
                <div class="flex flex-col items-center">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#fff2e3]">
                    <svg class="h-4 w-4 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                  </div>
                  {i < schedule.length - 1 && <div class="w-px flex-1 bg-slate-200 my-1"></div>}
                </div>
                <div class={`pb-4 ${i === schedule.length - 1 ? 'pb-0' : ''}`}>
                  <span class="text-[14px] font-semibold text-slate-900">{item.time}</span>
                  <p class="mt-0.5 text-[14px] leading-[1.5] text-slate-600">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Правая колонка: что происходит на занятиях -->
        <div class="md:w-[45%]">
          <h3 class="text-[17px] font-semibold text-slate-900">Что происходит на занятиях</h3>
          <p class="mt-3 text-[14px] leading-[1.65] text-slate-600 md:text-[15px]">Первый день — не урок. Детей делят на группы по возрасту и уровню, проводят короткое тестирование — не экзамен, а просто чтобы понять с чего начинать. Кто-то уже писал код, кто-то ни разу не открывал редактор. Обе ситуации нормальные.</p>
          <p class="mt-3 text-[14px] leading-[1.65] text-slate-600 md:text-[15px]">Дальше — выбор проекта. Не «все делаем Марио», не «сегодня по учебнику страница 12». Каждый выбирает то, что хочет сделать сам: погоня, стрелялка, платформер, история с выбором. Технически все эти игры устроены одинаково — персонаж, движение, механика, условия победы. Но один делает рыцаря, другой — космический корабль, третий — кота который собирает рыбу.</p>
          <p class="mt-3 text-[14px] leading-[1.65] text-slate-600 md:text-[15px]">Каждый день — конкретный шаг вперёд. Добавили механику, проверили, сломалось — починили, добавили следующую. К середине смены уже есть что запустить. К финалу — готовый проект, который можно показать дома.</p>

          <div class="mt-4 space-y-2">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 shrink-0 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
              <span class="text-[13px] text-slate-700">7–9 лет — первые игры, движение и счёт</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 shrink-0 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
              <span class="text-[13px] text-slate-700">10–12 лет — уровни, логика, механики</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 shrink-0 text-[#ec7c00]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
              <span class="text-[13px] text-slate-700">13–14 лет — AI-элементы, сложная структура</span>
            </div>
          </div>

          <a href="#shifts" class="mt-4 inline-block text-[13px] text-orange-500 underline underline-offset-2">Подробная программа по каждой смене →</a>
        </div>
      </div>

      <div class="mt-5 flex items-start gap-2.5 rounded-xl border border-slate-200 bg-slate-50 p-3.5">
        <svg class="h-5 w-5 shrink-0 text-[#ec7c00] mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
        <p class="text-[13px] leading-[1.5] text-slate-600">Телефоны сдаются при заезде. Доступ — за заработанное время.</p>
      </div>
    </div>
  </div>
</section>

<script>
  function initJourneyTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-journey-tab]');
    const panels = document.querySelectorAll<HTMLElement>('[data-journey-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.journeyTab;
        tabs.forEach((t) => {
          const isActive = t.dataset.journeyTab === target;
          t.classList.toggle('bg-[#ec7c00]', isActive);
          t.classList.toggle('text-white', isActive);
          t.classList.toggle('bg-slate-100', !isActive);
          t.classList.toggle('text-slate-700', !isActive);
        });
        panels.forEach((p) => {
          p.classList.toggle('hidden', p.dataset.journeyPanel !== target);
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initJourneyTabs);
  initJourneyTabs();
</script>
