---
const videos = [
  {
    url: 'https://kinescope.io/embed/qmLxu2S7uaS44CKkhoV1Jj',
    title: 'IT-лагерь — это не "сидеть за компьютером". Вот что происходит на самом деле',
    thumb: '/images/videos/video-01.avif',
    alt: 'IT-лагерь АйДаКемп — не просто сидеть за компьютером',
  },
  {
    url: 'https://kinescope.io/embed/tJAaAnvCYYJ5vRz7uyUepj',
    title: 'За неделю в лагере он меняется больше, чем за год дома',
    thumb: '/images/videos/video-02.avif',
    alt: 'За неделю в лагере ребёнок меняется больше, чем за год дома',
  },
  {
    url: 'https://kinescope.io/embed/naDfzrei9duApz3AnaencH',
    title: 'Не хочу в лагерь… Через 3 дня: хочу ещё',
    thumb: '/images/videos/video-03.avif',
    alt: 'Не хочу в лагерь — через 3 дня: хочу ещё',
  },
  {
    url: 'https://kinescope.io/embed/eTmCgZHcwhcWQQs3HLCz1S',
    title: 'Ребёнок сам откажется от телефона за 3 дня',
    thumb: '/images/videos/video-04.avif',
    alt: 'Ребёнок сам откажется от телефона за 3 дня в АйДаКемп',
  },
  {
    url: 'https://kinescope.io/embed/s1SCYKqLx6C94fMRumitHF',
    title: 'Зачем детям копить деньги в лагере',
    thumb: '/images/videos/video-05.avif',
    alt: 'Зачем детям копить деньги в лагере АйДаКемп',
  },
];
---

<section id="videos" class="mx-auto max-w-[1312px] px-[2px] pt-10 md:px-4" data-videos-root>
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1"><div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div><h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Видео</h2></div>

    <!-- Desktop: all 5 visible with side arrows -->
    <div class="relative mt-5">
      <!-- Prev arrow -->
      <button type="button" data-vid-prev aria-label="Назад" class="absolute -left-3 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white/90 text-slate-500 shadow-sm md:flex">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <!-- Next arrow -->
      <button type="button" data-vid-next aria-label="Вперёд" class="absolute -right-3 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white/90 text-slate-500 shadow-sm md:flex">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>

      <!-- Mobile: main video + thumbnails -->
      <div class="md:hidden">
        <button
          type="button"
          data-video-open
          data-video-url={videos[0].url}
          data-video-title={videos[0].title}
          data-vid-index="0"
          class="group w-full"
          data-vid-main
        >
          <div class="relative overflow-hidden rounded-[18px]">
            <img src={videos[0].thumb} alt={videos[0].alt} class="aspect-[9/16] w-full object-cover" loading="lazy" width="360" height="640" data-vid-main-img />
            <div class="absolute inset-0 flex items-center justify-center bg-black/20">
              <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/90 text-primary-light">
                <svg class="ml-1 h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
              </div>
            </div>
          </div>
          <p class="mt-2 text-left text-[14px] font-medium leading-[1.4] text-slate-700" data-vid-main-title>{videos[0].title}</p>
        </button>
        <div class="mt-3 grid grid-cols-4 gap-2">
          {videos.slice(1).map((v, i) => (
            <button
              type="button"
              data-video-thumb
              data-video-url={v.url}
              data-video-title={v.title}
              data-video-thumb-src={v.thumb}
              data-vid-index={i + 1}
              class="group"
            >
              <div class="relative overflow-hidden rounded-[12px]">
                <img src={v.thumb} alt={v.alt} class="aspect-[9/16] w-full object-cover" loading="lazy" width="180" height="320" />
                <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                  <div class="flex h-7 w-7 items-center justify-center rounded-full bg-white/80 text-primary-light">
                    <svg class="ml-0.5 h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                  </div>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Desktop: 5-col grid -->
      <div data-vid-track class="hidden md:grid md:grid-cols-5 md:gap-4">
        {videos.map((v, i) => (
          <button
            type="button"
            data-video-open
            data-video-url={v.url}
            data-video-title={v.title}
            data-vid-index={i}
            class="group"
          >
            <div class="relative overflow-hidden rounded-[18px]">
              <img src={v.thumb} alt={v.alt} class="aspect-[9/16] w-full object-cover transition group-hover:scale-105" loading="lazy" width="360" height="640" />
              <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-primary-light">
                  <svg class="ml-1 h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                </div>
              </div>
            </div>
            <p class="mt-2 line-clamp-2 text-left text-[13px] leading-[1.4] text-slate-700">{v.title}</p>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Video modal — vertical aspect, Kinescope SDK -->
<dialog id="videoModal" class="m-0 h-full w-full max-w-none border-0 outline-none bg-black/90 p-4 backdrop:bg-black/90">
  <div class="flex h-full flex-col items-center justify-center">
    <button type="button" data-video-close aria-label="Закрыть" class="absolute right-4 top-4 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white outline-none focus:outline-none focus:ring-0 focus-visible:outline-none">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <div class="mx-auto w-full max-w-[360px]">
      <div id="playerContainer" class="w-full aspect-[9/16] rounded-[18px] overflow-hidden [&_iframe]:!w-full [&_iframe]:!h-full [&_iframe]:!absolute [&_iframe]:!inset-0 relative"></div>
    </div>
  </div>
</dialog>

<script>
  import { trackGoal } from '../scripts/analytics';

  function waitForKinescope(): Promise<void> {
    return new Promise((resolve) => {
      if ((window as any).Kinescope?.IframePlayer) { resolve(); return; }
      const check = setInterval(() => {
        if ((window as any).Kinescope?.IframePlayer) { clearInterval(check); resolve(); }
      }, 100);
    });
  }

  function initVideos() {
    const modal = document.getElementById('videoModal') as HTMLDialogElement | null;
    const container = document.getElementById('playerContainer') as HTMLElement | null;
    const track = document.querySelector<HTMLElement>('[data-vid-track]');
    let player: any = null;

    function extractVideoId(url: string): string {
      // https://kinescope.io/embed/VIDEO_ID → VIDEO_ID
      return url.split('/').pop() || '';
    }

    async function openVideo(url: string) {
      if (!modal || !container) return;
      modal.showModal();
      trackGoal('video_open');

      await waitForKinescope();
      const videoId = extractVideoId(url);
      const Kinescope = (window as any).Kinescope;

      player = await Kinescope.IframePlayer.create('playerContainer', {
        url: `https://kinescope.io/embed/${videoId}`,
        size: { width: '100%', height: '100%' },
        behaviour: { autoPlay: true },
      });

      player.on(Kinescope.PlayerEvent.PlaybackStateChanged, (state: string) => {
        if (state === 'playing') trackGoal('video_play');
      });
    }

    function closeVideo() {
      if (player) { player.destroy(); player = null; }
      modal?.close();
    }

    // Open video modal (desktop + mobile main)
    document.querySelectorAll('[data-video-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.videoUrl;
        if (url) openVideo(url);
      });
    });

    // Mobile thumbnails: click swaps into main + opens
    const mainBtn = document.querySelector<HTMLElement>('[data-vid-main]');
    const mainImg = document.querySelector<HTMLImageElement>('[data-vid-main-img]');
    const mainTitle = document.querySelector<HTMLElement>('[data-vid-main-title]');
    document.querySelectorAll('[data-video-thumb]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const url = el.dataset.videoUrl;
        if (url) openVideo(url);
        if (mainBtn && mainImg && mainTitle) {
          mainBtn.dataset.videoUrl = el.dataset.videoUrl || '';
          mainImg.src = el.dataset.videoThumbSrc || '';
          mainTitle.textContent = el.dataset.videoTitle || '';
        }
      });
    });

    modal?.querySelector('[data-video-close]')?.addEventListener('click', closeVideo);
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeVideo(); });

    // Desktop arrows: scroll the grid by one card width
    const prevBtn = document.querySelector<HTMLElement>('[data-vid-prev]');
    const nextBtn = document.querySelector<HTMLElement>('[data-vid-next]');
    if (track && prevBtn && nextBtn) {
      const cards = track.querySelectorAll('[data-video-open]');
      let offset = 0;
      const total = cards.length;

      function updateDesktopCarousel() {
        cards.forEach((card, i) => {
          const order = (i - offset + total) % total;
          (card as HTMLElement).style.order = String(order);
        });
      }

      prevBtn.addEventListener('click', () => {
        offset = (offset - 1 + total) % total;
        updateDesktopCarousel();
      });

      nextBtn.addEventListener('click', () => {
        offset = (offset + 1) % total;
        updateDesktopCarousel();
      });
    }
  }

  document.addEventListener('astro:page-load', initVideos);
  initVideos();
</script>
