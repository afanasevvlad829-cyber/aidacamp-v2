---
import { YANDEX_METRIKA_ID, MAILRU_PIXEL_ID } from '../data/tracking';
import { PHONE_MAIN, PHONE_MAIN_HREF, PHONE_MOBILE, PHONE_MOBILE_HREF, WHATSAPP_URL, TELEGRAM_URL } from '../data/contacts';
const sections = [
  { label: 'О лагере', href: '#about' },
  { label: 'Смены', href: '#shifts' },
  { label: 'Фото', href: '#gallery' },
  { label: 'Видео', href: '#videos' },
  { label: 'Отзывы', href: '#reviews' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Контакты', href: '#contacts' },
];

const documents = [
  { label: 'Политика конфиденциальности', href: '/legal#privacy' },
  { label: 'Пользовательское соглашение', href: '/legal#terms' },
  { label: 'Договор оферты', href: '/legal#offer' },
  { label: 'Образовательная лицензия', href: '/legal#license' },
  { label: 'Реестр туроператоров', href: '/legal#touroperator' },
  { label: 'Реквизиты', href: '/legal#requisites' },
];

const socials = [
  { label: 'VK', href: 'https://vk.com/aidacamp' },
  { label: 'Telegram', href: TELEGRAM_URL },
  { label: 'YouTube', href: 'https://www.youtube.com/@aidacamp' },
];
---

<footer class="mx-auto max-w-[1312px] px-[2px] pb-4 pt-4 md:pb-6 md:pt-6 md:px-4">
  <div class="border-t border-slate-200 bg-white p-[18px] pt-5 text-sm text-slate-500 md:pt-8">
    <!-- Mobile: compact layout -->
    <div class="md:hidden">
      <div class="flex gap-2 mb-3">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" class="rounded-lg border border-slate-200 px-3 py-1.5 text-[13px] text-slate-600 hover:text-slate-700">
            {s.label}
          </a>
        ))}
      </div>
      <div class="grid grid-cols-2 gap-3">
        <details>
          <summary class="cursor-pointer text-[13px] font-semibold text-slate-900">Документы ▾</summary>
          <div class="mt-1.5 space-y-1">
            {documents.map((d) => (
              <a href={d.href} class="block text-[12px] text-slate-500 hover:text-slate-700">{d.label}</a>
            ))}
          </div>
        </details>
        <details>
          <summary class="cursor-pointer text-[13px] font-semibold text-slate-900">Разделы ▾</summary>
          <div class="mt-1.5 space-y-1">
            {sections.map((s) => (
              <a href={s.href} class="block text-[12px] text-slate-500 hover:text-slate-700">{s.label}</a>
            ))}
          </div>
        </details>
      </div>
    </div>

    <!-- Desktop: full 3-col layout -->
    <div class="hidden md:grid md:grid-cols-3 md:gap-6">
      <div>
        <p class="font-semibold text-slate-900">Документы</p>
        <div class="mt-2 space-y-1.5">
          {documents.map((d) => (
            <a href={d.href} class="block text-slate-500 hover:text-slate-700">{d.label}</a>
          ))}
        </div>
      </div>
      <div>
        <p class="font-semibold text-slate-900">Разделы</p>
        <div class="mt-2 space-y-1.5">
          {sections.map((s) => (
            <a href={s.href} class="block text-slate-500 hover:text-slate-700">{s.label}</a>
          ))}
        </div>
      </div>
      <div>
        <p class="font-semibold text-slate-900">Соцсети</p>
        <div class="mt-2 flex gap-2">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" class="rounded-lg border border-slate-200 px-3 py-1.5 text-[13px] text-slate-600 hover:text-slate-700">
              {s.label}
            </a>
          ))}
        </div>
        <div class="mt-4 space-y-1">
          <a href={PHONE_MAIN_HREF} class="block text-slate-500 hover:text-slate-700">{PHONE_MAIN}</a>
          <a href={PHONE_MOBILE_HREF} class="block text-slate-500 hover:text-slate-700">{PHONE_MOBILE}</a>
          <div class="flex gap-2 pt-1">
            <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="text-slate-500 hover:text-slate-700">WhatsApp</a>
            <span>·</span>
            <a href={TELEGRAM_URL} target="_blank" rel="noopener" class="text-slate-500 hover:text-slate-700">Telegram</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal -->
    <div class="mt-6 border-t border-slate-100 pt-4 text-[13px] leading-[1.6] text-slate-500">
      <p>&copy; 2019–2026 ООО «ВОИП КОННЕКТ»</p>
      <p>ИНН 7729713637 · Реестровый номер туроператора РТО 025773</p>
      <p>Образовательная лицензия Л035-01298-77/01082973</p>
    </div>
  </div>

  <!-- Analytics pixels -->
  <img src={`https://mc.yandex.ru/watch/${YANDEX_METRIKA_ID}`} class="absolute -left-[9999px]" alt="" width="1" height="1" />
  <img src={`https://top-fwz1.mail.ru/counter?id=${MAILRU_PIXEL_ID};js=na`} class="absolute -left-[9999px]" alt="" width="1" height="1" />
</footer>
