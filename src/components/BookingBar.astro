---
interface Props {
  headline: string;
  id: string;
}

const { headline, id } = Astro.props;
---

<section class="mx-auto max-w-[1312px] px-[2px] py-6 md:px-4" data-booking-bar={id}>
  <div class="rounded-[18px] bg-[#f5f4f0] p-5 md:p-6">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-center lg:gap-0">
      <div class="lg:border-r lg:border-slate-200 lg:pr-8">
        <p class="text-[17px] font-semibold text-slate-900 leading-[1.3]">{headline}</p>
        <p class="mt-1 text-[12px] text-slate-400" data-response-time-steps>Оставьте заявку → свяжемся с 11 до 20 МСК → забронируем место</p>
      </div>
      <div class="flex flex-col gap-2 lg:pl-8">
        <form
          data-form={`bar_${id}`}
          class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3"
          novalidate
        >
          <input type="hidden" name="age" value="" data-age-input />
          <input
            type="tel"
            name="phone"
            placeholder="+7 (___) ___-__-__"
            autocomplete="tel"
            class="h-11 w-full rounded-[12px] bg-white border border-slate-200 px-4 text-[15px] text-slate-800 placeholder:text-slate-300 outline-none focus:border-orange-400 transition sm:w-[210px]"
            data-phone-input
          />
          <button
            type="submit"
            disabled
            class="h-11 w-full sm:w-auto shrink-0 rounded-[12px] bg-[#ec7c00] hover:bg-[#d46e00] px-6 text-[14px] font-semibold text-white transition-all duration-200 hover:-translate-y-[1px] hover:shadow-[0_4px_16px_rgba(236,124,0,0.25)] disabled:opacity-40 disabled:hover:translate-y-0 disabled:hover:shadow-none"
            data-submit-btn
          >
            Перезвоните мне
          </button>
        </form>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="consent" data-bar-consent required
                 class="h-3.5 w-3.5 shrink-0 rounded border border-slate-300 accent-[#ec7c00]" />
          <span class="text-[11px] text-slate-400 leading-tight">
            Согласен(а) на <a href="/legal#privacy" class="underline text-slate-400">обработку персональных данных</a>
          </span>
        </label>
        <p class="text-[11px] text-slate-400/70 leading-tight">Позвоним один раз. Если не дозвонимся — напишем в мессенджер.</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { initPhoneInput, isPhoneValid } from '../scripts/phone';
  import { submitLead } from '../scripts/form-submit';
  import { trackGoal } from '../scripts/analytics';

  function initBookingBar() {
    document.querySelectorAll<HTMLElement>('[data-booking-bar]').forEach((root) => {
      const form = root.querySelector<HTMLFormElement>('form');
      if (!form || form.dataset.initialized) return;
      form.dataset.initialized = 'true';

      const phoneInput = form.querySelector<HTMLInputElement>('[data-phone-input]');
      const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit-btn]');
      const ageInput = form.querySelector<HTMLInputElement>('[data-age-input]');
      const consent = root.querySelector<HTMLInputElement>('[data-bar-consent]');
      if (!phoneInput || !submitBtn) return;

      // Auto-fill age from localStorage
      const savedAge = localStorage.getItem('user_age_group');
      if (savedAge && ageInput) {
        ageInput.value = savedAge;
      }

      initPhoneInput(phoneInput);

      function updateSubmit() {
        submitBtn.disabled = !(isPhoneValid(phoneInput.value) && consent?.checked);
      }

      phoneInput.addEventListener('input', updateSubmit);
      consent?.addEventListener('change', updateSubmit);

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!isPhoneValid(phoneInput.value)) return;

        submitBtn.disabled = true;
        submitBtn.textContent = 'Отправка...';

        try {
          await submitLead({
            phone: phoneInput.value,
            age: ageInput?.value || '',
            source: `bar_${root.dataset.bookingBar}`,
          });
          trackGoal('lead_submit');
          submitBtn.textContent = 'Отправлено ✓';
          phoneInput.value = '';
        } catch {
          submitBtn.textContent = 'Ошибка, попробуйте ещё';
          submitBtn.disabled = false;
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initBookingBar);
  initBookingBar();
</script>
