---
interface Props {
  title?: string;
  pages: Array<{
    title: string;
    description: string;
    url: string;
    icon: string;
  }>;
}

const { title = "Подберите лагерь по интересам", pages } = Astro.props;
---

<section class="mx-auto max-w-[1312px] px-4 mt-8 mb-4">
  <div class="bg-[#f7f5f2] rounded-[24px] p-[18px] md:p-8">

    <!-- Title with stripe -->
    <div class="flex items-center gap-2 mb-6">
      <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
      <h2 class="text-[20px] md:text-[22px] font-bold text-slate-900">
        {title}
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4">
      {pages.map((page) => (
        <a
          href={page.url}
          class="group flex flex-col rounded-[16px] border border-slate-100 bg-white p-4 transition hover:border-orange-200 hover:shadow-[0_2px_12px_rgba(249,115,22,0.08)]"
        >
          <span class="flex h-9 w-9 items-center justify-center rounded-[10px] bg-orange-50 text-orange-500"><i class={`bi ${page.icon} text-[18px]`}></i></span>
          <span class="mt-3 text-[15px] font-semibold text-slate-900 leading-[1.3]">
            {page.title}
          </span>
          <span class="mt-1 text-[13px] text-slate-500 leading-[1.4] flex-1">
            {page.description}
          </span>
          <span class="mt-3 text-[13px] font-medium text-orange-500 group-hover:translate-x-0.5 transition-transform">
            Подробнее &rarr;
          </span>
        </a>
      ))}
    </div>

  </div>
</section>
