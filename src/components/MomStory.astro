---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<section class={compact ? '' : 'mx-auto max-w-[1312px] px-[2px] pt-8 md:px-4'}>
  <div class="bg-surface-warm p-4 md:p-5 rounded-[18px]">
    <div class="flex flex-col items-center text-center gap-3 md:flex-row md:items-start md:text-left md:gap-5">
      <!-- Photo -->
      <div class="shrink-0">
        <img
          src="/images/team/team-daria-main-01.avif"
          alt="Дарья Афанасьева"
          class="h-16 w-16 rounded-full object-cover object-top mx-auto md:h-24 md:w-24"
          width="96"
          height="96"
          loading="lazy"
        />
      </div>

      <!-- Quote -->
      <div>
        <span class="hidden text-xl font-serif leading-none text-orange-400 mb-[-8px] md:block">&laquo;</span>
        <p class="text-[13px] leading-[1.6] text-slate-700 md:text-[15px]">
          Я сама мама подростка. Объездила разные лагеря, смотрела программы, читала отзывы. Везде было одно и то же&nbsp;&mdash; всё решено заранее, ребёнок просто проходит программу. Тогда я решила сделать лагерь таким, каким сама хотела бы видеть обучение своего ребёнка.
        </p>
        <div class="mt-2">
          <p class="text-[14px] font-semibold text-slate-900">&mdash; Дарья Афанасьева</p>
          <p class="text-[12px] text-slate-500">основатель АйДаКемп и мама подростка</p>
        </div>
      </div>
    </div>
  </div>
</section>
