---
import { PHONE_MAIN, PHONE_MAIN_HREF, PHONE_MOBILE, PHONE_MOBILE_HREF, WHATSAPP_URL, TELEGRAM_URL } from '../data/contacts';
const navItems = [
  { label: 'О лагере', href: '#about' },
  { label: 'Смены 2026', href: '/lager-na-leto-2026' },
  { label: 'Фото', href: '#gallery' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Команда', href: '#team' },
];

const moreItems = [
  { label: 'Программа', href: '#journey' },
  { label: 'Видео', href: '#videos' },
  { label: 'Отзывы', href: '#reviews' },
  { label: 'Размещение', href: '#stay' },
  { label: 'Контакты', href: '#contacts' },
];

const allNavItems = [...navItems, ...moreItems];
---

<header class="absolute inset-x-0 top-0 z-40">
  <!-- Desktop Header -->
  <div class="mx-auto hidden h-16 max-w-[1440px] items-center justify-between px-6 md:flex">
    <!-- Logo + Brand -->
    <a href="#hero" class="flex items-center gap-3">
      <img
        src="/assets/icons/aida-logo-original.svg"
        alt=""
        aria-hidden="true"
        class="h-10 w-10"
        width="40"
        height="40"
      />
      <span class="text-[13px] font-medium leading-tight text-white [text-shadow:0px_1px_2px_rgba(0,0,0,0.45)]">
        АйТи-лагерь · 7–14 лет
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="flex items-center gap-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-[13px] border border-white/18 bg-[rgba(43,51,61,0.58)] px-3 py-1.5 text-[14px] font-semibold leading-[15px] text-white/86 backdrop-blur-sm transition hover:-translate-y-0.5 [text-shadow:0px_1px_2px_rgba(0,0,0,0.35)]"
          data-analytics-goal="nav_click"
          data-analytics-label={item.label}
        >
          {item.label}
        </a>
      ))}

      <!-- More dropdown -->
      <details class="group relative" data-nav-more-root>
        <summary class="flex cursor-pointer items-center gap-1 rounded-[13px] border border-white/18 bg-[rgba(43,51,61,0.58)] px-3 py-1.5 text-[14px] font-semibold leading-[15px] text-white/86 backdrop-blur-sm transition [text-shadow:0px_1px_2px_rgba(0,0,0,0.35)] list-none [&::-webkit-details-marker]:hidden">
          <span>···</span>
          <svg class="h-3 w-3 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 12 12">
            <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </summary>
        <div
          id="nav-more-menu"
          class="invisible absolute right-0 top-[calc(100%+10px)] z-50 grid min-w-[220px] gap-1 rounded-2xl border border-white/16 bg-[rgba(7,14,26,0.92)] p-2 opacity-0 shadow-[0_20px_44px_rgba(2,8,20,0.46)] backdrop-blur-[10px] transition-all group-open:visible group-open:translate-y-0 group-open:opacity-100"
        >
          {moreItems.map((item) => (
            <a
              href={item.href}
              class="rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:-translate-y-0.5 hover:bg-white/10"
              data-analytics-goal="nav_click"
              data-analytics-label={item.label}
            >
              {item.label}
            </a>
          ))}
        </div>
      </details>
    </nav>

    <!-- Phone Dropdown (Desktop) — centered over booking card -->
    <div class="flex shrink-0 justify-center mr-[36px]">
    <details class="group relative" data-hero-phone-dropdown="desktop">
      <summary class="inline-flex h-9 cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-3xl border border-white/42 bg-white/11 px-3 py-1.5 text-[13px] font-semibold text-white backdrop-blur-sm [text-shadow:0px_1px_2px_rgba(0,0,0,0.35)] list-none [&::-webkit-details-marker]:hidden">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        +7 (495) 128-44-29
      </summary>
      <div class="invisible absolute right-0 top-[calc(100%+10px)] z-50 grid min-w-[220px] gap-1 rounded-2xl border border-white/16 bg-[rgba(7,14,26,0.92)] p-2 opacity-0 shadow-[0_20px_44px_rgba(2,8,20,0.46)] backdrop-blur-[10px] transition-all group-open:visible group-open:translate-y-0 group-open:opacity-100">
        <a href={PHONE_MAIN_HREF} class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="phone_click" data-analytics-label="call_495">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          +7 (495) 128-44-29
        </a>
        <a href={PHONE_MOBILE_HREF} class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="phone_click" data-analytics-label="call_968">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          +7 (968) 808-64-55
        </a>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="messenger_click" data-analytics-label="whatsapp">
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.335 0-4.512-.654-6.379-1.786l-.446-.277-3.088 1.034 1.034-3.088-.277-.446A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          WhatsApp
        </a>
        <a href={TELEGRAM_URL} target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="messenger_click" data-analytics-label="telegram">
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Telegram
        </a>
      </div>
    </details>
    </div>
  </div>

  <!-- Mobile Header -->
  <div class="flex h-14 items-center justify-between px-4 md:hidden">
    <!-- Burger -->
    <button
      type="button"
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-xl text-white"
      aria-label="Открыть меню"
    >
      <svg id="burger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Logo -->
    <a href="#hero" class="flex items-center gap-2">
      <img
        src="/assets/icons/aida-logo-original.svg"
        alt=""
        aria-hidden="true"
        class="h-9 w-9"
        width="36"
        height="36"
      />
      <span class="text-xs font-semibold leading-tight text-white [text-shadow:0px_1px_2px_rgba(0,0,0,0.45)]">
        АйТи-лагерь<br />#АйДаКемп
      </span>
    </a>

    <!-- Phone (Mobile) -->
    <details class="group relative" data-hero-phone-dropdown="mobile">
      <summary class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-xl border border-white/30 bg-white/10 text-white backdrop-blur-sm list-none [&::-webkit-details-marker]:hidden">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </summary>
      <div class="invisible absolute right-0 top-[calc(100%+8px)] z-50 grid min-w-[200px] gap-1 rounded-2xl border border-white/16 bg-[rgba(7,14,26,0.92)] p-2 opacity-0 shadow-[0_20px_44px_rgba(2,8,20,0.46)] backdrop-blur-[10px] transition-all group-open:visible group-open:translate-y-0 group-open:opacity-100">
        <a href={PHONE_MAIN_HREF} class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="phone_click">{PHONE_MAIN}</a>
        <a href={PHONE_MOBILE_HREF} class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="phone_click">{PHONE_MOBILE}</a>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="messenger_click">WhatsApp</a>
        <a href={TELEGRAM_URL} target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl px-3 py-2 text-[13px] font-medium text-white/90 transition hover:bg-white/10" data-analytics-goal="messenger_click">Telegram</a>
      </div>
    </details>
  </div>

  <!-- Mobile Menu Overlay -->
  <nav
    id="mobile-menu"
    class="fixed inset-0 z-50 hidden flex-col bg-[rgba(7,14,26,0.96)] backdrop-blur-lg"
  >
    <div class="flex h-14 items-center justify-between px-4">
      <button
        type="button"
        id="mobile-menu-close"
        class="flex h-10 w-10 items-center justify-center rounded-xl text-white"
        aria-label="Закрыть меню"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <span class="text-sm font-semibold text-white">Меню</span>
      <div class="w-10"></div>
    </div>
    <div class="flex flex-1 flex-col gap-1 overflow-y-auto p-4">
      {allNavItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link rounded-xl px-4 py-4 text-[22px] font-semibold text-white/90 transition hover:bg-white/10"
          data-analytics-goal="nav_click"
          data-analytics-label={item.label}
        >
          {item.label}
        </a>
      ))}
    </div>
    <div class="border-t border-white/10 p-4">
      <a href={PHONE_MAIN_HREF} class="mb-2 block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white">
        +7 (495) 128-44-29
      </a>
      <div class="flex gap-2">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex-1 rounded-xl border border-white/20 py-2.5 text-center text-sm font-medium text-white/90">WhatsApp</a>
        <a href={TELEGRAM_URL} target="_blank" rel="noopener" class="flex-1 rounded-xl border border-white/20 py-2.5 text-center text-sm font-medium text-white/90">Telegram</a>
      </div>
    </div>
  </nav>
</header>

<script>
  import { trackGoal } from '../scripts/analytics';

  // Contact link tracking
  document.querySelectorAll<HTMLAnchorElement>('header a[href^="tel:"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('phone_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('header a[href*="wa.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('whatsapp_click'));
  });
  document.querySelectorAll<HTMLAnchorElement>('header a[href*="t.me"]').forEach((a) => {
    a.addEventListener('click', () => trackGoal('telegram_click'));
  });

  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('burger-icon');
  const closeIcon = document.getElementById('close-icon');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    burgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    burgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);

  // Close on nav link click
  menu?.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close details on click outside
  document.addEventListener('click', (e) => {
    document.querySelectorAll('header details[open]').forEach((d) => {
      if (!d.contains(e.target as Node)) {
        d.removeAttribute('open');
      }
    });
  });
</script>
