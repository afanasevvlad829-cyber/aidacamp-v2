---
const members = [
  {
    name: 'Дарья Афанасьева',
    role: 'основатель и вдохновитель АйДаКемп',
    photo: '/images/team/team-daria-main-01.png',
    bio: 'предприниматель в сфере детского IT-образования и мама подростка, которая строит лагерь таким, каким сама хотела бы видеть обучение своего ребёнка.',
  },
  {
    name: 'Никита Брагин',
    role: 'преподаватель Scratch, Minecraft и Python',
    photo: '/images/team/team-nikita-main-01.png',
    bio: 'автор учебника по разработке игр; специализируется на геймдеве и помогает детям создавать собственные игровые миры.',
  },
  {
    name: 'Александр Ташкин',
    role: 'преподаватель Scratch, Minecraft и Python',
    photo: '/images/team/team-alex-main-01.png',
    bio: 'соавтор учебника по разработке игр; умеет зажигать интерес к программированию через практические задачи и командные проекты.',
  },
  {
    name: 'Омар Алхамви',
    role: 'преподаватель Python и нейросетей',
    photo: '/images/team/team-omar-main-01.png',
    bio: 'работает со старшими и продвинутыми группами, часть занятий ведёт на английском и показывает, как применять AI в реальных проектах.',
  },
  {
    name: 'Дарья Воронцова',
    role: 'преподаватель Python и Scratch',
    photo: '/images/team/team-daria-vorontsova-main-01.png',
    bio: 'помогает детям легко войти в программирование через игры, логику и первые самостоятельные программы.',
  },
];
---

<section id="team" class="mx-auto max-w-[1312px] px-[2px] pt-6 md:px-4">
  <div class="bg-white p-[18px]">
    <div class="flex items-center gap-2 mb-1"><div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div><h2 class="text-[22px] font-bold leading-[1.1] tracking-[-0.02em] text-slate-900 md:text-[28px]">Команда</h2></div>

    <p class="mt-3 max-w-[800px] text-[15px] leading-[1.6] text-slate-600">
      Наши преподаватели — авторы собственной книги по Python для детей.
    </p>

    <div class="mt-5 flex flex-col gap-5 md:flex-row md:gap-6">
      <!-- Left: Book card -->
      <div class="w-full shrink-0 md:w-[35%]">
        <div class="flex h-full flex-col rounded-[18px] border border-slate-200 bg-slate-50 p-5">
          <img src="/images/team/team-book-main-01.webp" alt="Книга по Python" class="mx-auto h-auto w-full max-w-[200px] rounded-lg object-cover shadow-md" loading="lazy" />
          <p class="mt-4 text-[15px] font-semibold text-slate-900">Собственная книга по Python</p>
          <p class="mt-2 text-[13px] leading-[1.5] text-slate-600">Команда не только ведёт занятия, но и написала книгу по Python для детей — тираж 2000 экз.</p>
          <button type="button" data-book-open class="mt-4 inline-flex w-full items-center justify-center rounded-[12px] bg-[#ec7c00] px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0">
            Смотреть книгу
          </button>
        </div>
      </div>

      <!-- Right: Teachers grid (desktop) / swipe carousel (mobile) -->
      <div class="relative w-full md:flex md:w-[65%] md:flex-col">
        <!-- Desktop: top row fixed (2) + bottom row carousel (3) -->
        <div class="hidden md:flex md:h-full md:flex-col md:gap-4">
          <!-- Top row: Afanasyeva + Bragin (fixed) -->
          <div class="grid flex-1 grid-cols-2 gap-4" data-team-top-row>
            {members.slice(0, 2).map((m) => (
              <article class="flex flex-col items-center rounded-[22px] bg-white p-5 shadow-[0_2px_12px_rgba(15,23,42,0.06)]">
                <img src={m.photo} alt={m.name} class="mx-auto h-16 w-16 rounded-full object-cover object-top ring-2 ring-white" width="64" height="64" loading="lazy" />
                <h3 class="mt-3 text-center text-[16px] font-semibold text-slate-900">{m.name}</h3>
                <p class="mt-1 text-center text-[13px] font-medium text-slate-500">{m.role}</p>
                <p class="mt-2 text-center text-[13px] leading-[1.55] text-slate-500">{m.bio}</p>
              </article>
            ))}
          </div>

          <!-- Bottom row: carousel of remaining 3 -->
          <div class="relative flex flex-1 items-stretch gap-4">
            <button type="button" data-team-prev aria-label="Назад" class="absolute -left-5 top-1/2 z-10 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-400 shadow-sm transition hover:bg-slate-50">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <div data-team-bottom-row class="grid flex-1 grid-cols-2 gap-4">
              <!-- JS populates 2 visible from bottom pool -->
            </div>
            <button type="button" data-team-next aria-label="Вперёд" class="absolute -right-5 top-1/2 z-10 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-400 shadow-sm transition hover:bg-slate-50">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </button>
          </div>
        </div>

        <!-- Mobile: horizontal scroll carousel -->
        <p class="text-[11px] text-slate-400 mb-1 md:hidden">&larr; свайп &rarr;</p>
        <div class="flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden md:hidden" data-team-mobile-track>
          {members.map((m) => (
            <article class="min-w-[72%] snap-start rounded-[22px] bg-white p-5 shadow-[0_2px_12px_rgba(15,23,42,0.06)]">
              <img src={m.photo} alt={m.name} class="mx-auto h-16 w-16 rounded-full object-cover object-top ring-2 ring-white" width="64" height="64" loading="lazy" />
              <h3 class="mt-3 text-center text-[16px] font-semibold text-slate-900">{m.name}</h3>
              <p class="mt-1 text-center text-[13px] font-medium text-slate-500">{m.role}</p>
              <p class="mt-2 text-center text-[13px] leading-[1.55] text-slate-500">{m.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Book modal -->
<dialog id="teamBookModal" class="m-0 h-full w-full max-w-none border-0 outline-none bg-black/50 p-4 backdrop:bg-black/50">
  <div class="flex h-full items-center justify-center">
    <div class="relative w-full max-w-[420px] rounded-[20px] bg-white p-5 shadow-[0_20px_50px_rgba(15,23,42,0.25)]">
      <button type="button" data-book-close aria-label="Закрыть" class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 text-slate-500">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>

      <div class="flex gap-4">
        <img src="/images/team/team-book-main-01.webp" alt="Книга по Python" class="h-[160px] w-[110px] shrink-0 rounded-lg object-cover shadow-md" />
        <div>
          <h3 class="text-[16px] font-semibold leading-[1.3] text-slate-900">Python для детей. Играем, чтобы программировать</h3>
          <p class="mt-1.5 text-[13px] text-slate-500">Владимир Афанасьев, Никита Брагин</p>
          <p class="mt-2 text-[13px] leading-[1.5] text-slate-600">Книга команды #АйДаКодить — тираж 2000 экз., для детей которые хотят начать Python и сделать первую игру.</p>
        </div>
      </div>

      <div class="mt-4 grid gap-2">
        <a href="https://www.ozon.ru/product/python-dlya-detey-igraem-chtoby-programmirovat-afanasev-vladimir-vladimirovich-3487599843/" target="_blank" rel="noopener" class="inline-flex items-center justify-center rounded-[12px] bg-[#ec7c00] px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_4px_16px_rgba(249,115,22,0.35)] hover:-translate-y-[1px] active:translate-y-0">
          Купить на Ozon
        </a>
        <a href="https://bombora.ru/book/180272/" target="_blank" rel="noopener" class="inline-flex items-center justify-center rounded-[12px] border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
          Читать фрагмент
        </a>
      </div>

      <p class="mt-3 text-center text-[12px] text-slate-400">Также доступно: Book24, Читай-город, Яндекс Маркет, ЛитРес</p>
    </div>
  </div>
</dialog>

<script>
  function initTeam() {
    // Book modal
    const modal = document.getElementById('teamBookModal') as HTMLDialogElement | null;
    document.querySelector('[data-book-open]')?.addEventListener('click', () => modal?.showModal());
    modal?.querySelector('[data-book-close]')?.addEventListener('click', () => modal.close());
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

    // Desktop: bottom row carousel (3 members, show 2 at a time)
    const bottomRow = document.querySelector<HTMLElement>('[data-team-bottom-row]');
    if (!bottomRow) return;

    const bottomMembers = [
      {
        name: 'Александр Ташкин',
        role: 'преподаватель Scratch, Minecraft и Python',
        photo: '/images/team/team-alex-main-01.png',
        bio: 'соавтор учебника по разработке игр; умеет зажигать интерес к программированию через практические задачи и командные проекты.',
      },
      {
        name: 'Омар Алхамви',
        role: 'преподаватель Python и нейросетей',
        photo: '/images/team/team-omar-main-01.png',
        bio: 'работает со старшими и продвинутыми группами, часть занятий ведёт на английском и показывает, как применять AI в реальных проектах.',
      },
      {
        name: 'Дарья Воронцова',
        role: 'преподаватель Python и Scratch',
        photo: '/images/team/team-daria-vorontsova-main-01.png',
        bio: 'помогает детям легко войти в программирование через игры, логику и первые самостоятельные программы.',
      },
    ];

    let offset = 0;
    const total = bottomMembers.length;

    function renderBottomRow() {
      bottomRow!.innerHTML = '';
      for (let i = 0; i < 2; i++) {
        const m = bottomMembers[(offset + i) % total];
        const card = document.createElement('article');
        card.className = 'flex flex-col items-center rounded-[22px] bg-white p-5 shadow-[0_2px_12px_rgba(15,23,42,0.06)]';
        card.innerHTML = `
          <img src="${m.photo}" alt="${m.name}" class="mx-auto h-16 w-16 rounded-full object-cover object-top ring-2 ring-white" width="64" height="64" loading="lazy" />
          <h3 class="mt-3 text-center text-[16px] font-semibold text-slate-900">${m.name}</h3>
          <p class="mt-1 text-center text-[13px] font-medium text-slate-500">${m.role}</p>
          <p class="mt-2 text-center text-[13px] leading-[1.55] text-slate-500">${m.bio}</p>
        `;
        bottomRow!.appendChild(card);
      }
    }

    renderBottomRow();

    document.querySelector('[data-team-prev]')?.addEventListener('click', () => {
      offset = (offset - 1 + total) % total;
      renderBottomRow();
    });

    document.querySelector('[data-team-next]')?.addEventListener('click', () => {
      offset = (offset + 1) % total;
      renderBottomRow();
    });
  }

  document.addEventListener('astro:page-load', initTeam);
  initTeam();
</script>
