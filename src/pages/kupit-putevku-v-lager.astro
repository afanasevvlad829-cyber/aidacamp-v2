---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Как купить путёвку в детский лагерь АйДаКемп",
    text: "Процесс простой: оставьте заявку на сайте, менеджер свяжется в течение 10 минут (в рабочее время 11–20 МСК) и ответит на все вопросы. После выбора смены подписываем договор — оферта публична, никаких устных обещаний. Оплата по договору, квитанция и путёвка — официальные документы.",
    list: [
      "Оставьте заявку — ответим за 10 минут",
      "Выберите смену и возраст ребёнка",
      "Подпишем договор и выставим счёт",
      "Получите путёвку и документы"
    ]
  },
  {
    h2: "Стоимость путёвок в лагерь на лето 2026",
    text: "Стоимость путёвки зависит от продолжительности смены. В цену включены проживание в санатории «Изумруд» (Наро-Фоминский район), 5-разовое питание, полная IT-программа (Python, AI, Minecraft), спортивные активности и бассейн.",
    list: [
      "Смена 2.1 — 7 дней, 10–16 июня — от 48 000 ₽",
      "Смена 1 — 10 дней, 30 мая–8 июня — 74 900 ₽",
      "Смена 2.2 — 8 дней, 16–23 июня — 65 000 ₽",
      "Смена 3 — 13 дней, 3–15 августа — 89 400 ₽",
      "Смена 4 — 10 дней, 17–26 августа — 69 600 ₽",
      "Смена 2 — 14 дней, 10–23 июня — 95 000 ₽ (самая популярная)"
    ]
  },
  {
    h2: "Что входит в путёвку",
    text: "Путёвка в АйДаКемп — это не просто место в лагере. Ребёнок уедет с готовым IT-проектом, который он создал сам и защитил на итоговом хакатоне. Программу ведут преподаватели-практики, авторы книги по Python для детей (тираж 2 000 экз.).",
    list: [
      "Проживание 2–4 человека в комнате с санузлом",
      "5-разовое питание, учёт аллергий",
      "Полная IT-программа: Python, AI, Minecraft, веб-дизайн",
      "Бассейн с ионизированной водой, спортплощадки",
      "Охрана 24/7, медработник на территории",
      "Ежедневные фото и новости в родительском канале",
      "Итоговый хакатон и готовый проект"
    ]
  },
  {
    h2: "Гарантии при покупке путёвки",
    text: "АйДаКемп — лицензированный туроператор (РТО 025773), ООО «ВОИП КОННЕКТ», ИНН 7729713637. Работаем официально с 2019 года, более 1 200 детей прошли через наш лагерь. Если ребёнку не понравится в первые 3 дня — вернём 50% стоимости путёвки без вопросов.",
    list: [
      "Договор оферты — публичный, никаких устных условий",
      "Образовательная лицензия Л035-01298-77/01082973",
      "Реестр туроператоров РТО 025773",
      "Страхование детей включено",
      "Возврат 50% за первые 3 дня — гарантия качества",
      "Фиксация цены на 72 часа после заявки"
    ]
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "66 км от Москвы" },
  { title: "Смены лета 2026", url: "/lager-na-leto-2026", icon: "bi-calendar-event", description: "Все даты и цены" },
  { title: "IT-программа", url: "/kompyuternyy-lager", icon: "bi-laptop", description: "Python, AI, Minecraft" },
  { title: "Детский лагерь", url: "/detskiy-lager", icon: "bi-house-heart", description: "О формате подробно" },
];
---

<LandingLayout
  title="Купить путёвку в детский лагерь 2026 — от 48 000 ₽ | АйДаКемп"
  description="Купить путёвку в IT-лагерь для детей 7–14 лет. Подмосковье, 66 км от Москвы. Смены лето 2026 от 48 000 ₽. Договор, лицензия туроператора, возврат 50% за 3 дня."
  h1="Купить путёвку в детский лагерь 2026"
  canonical="https://aidacamp.ru/kupit-putevku-v-lager"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Главная", "item": "https://aidacamp.ru/"},
      {"@type": "ListItem", "position": 2, "name": "Купить путёвку в лагерь"}
    ]
  })} />
  <LandingHero
    h1="Купить путёвку в детский лагерь 2026"
    subtitle="IT-лагерь АйДаКемп, Подмосковье. Путёвки для детей 7–14 лет на лето 2026. От 48 000 ₽ за 7 дней. Договор, страховка, лицензия туроператора РТО 025773."
    breadcrumb="Купить путёвку"
    keywords={["Официальный договор и лицензированный туроператор РТО 025773", "Возврат 50% стоимости путёвки если не понравится в первые 3 дня", "Фиксация цены на 72 часа после заявки — без скрытых доплат"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
