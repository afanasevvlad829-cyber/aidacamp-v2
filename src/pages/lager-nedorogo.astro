---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Цены на лагерь в Подмосковье — лето 2026",
    text: "Стоимость путёвки в АйДаКемп зависит от длины смены. Все цены окончательные — питание, проживание и IT-программа включены. Скрытых доплат нет.",
    list: [
      "Смена 2.1 — 7 дней, 10–16 июня — 48 000 ₽ (6 857 ₽/день) — самая короткая",
      "Смена 1 — 10 дней, 30 мая–8 июня — 74 900 ₽ (7 490 ₽/день)",
      "Смена 2.2 — 8 дней, 16–23 июня — 65 000 ₽ (8 125 ₽/день)",
      "Смена 4 — 10 дней, 17–26 августа — 69 600 ₽ (6 960 ₽/день)",
      "Смена 3 — 13 дней, 3–15 августа — 89 400 ₽ (6 877 ₽/день)",
      "Смена 2 — 14 дней, 10–23 июня — 95 000 ₽ (6 786 ₽/день) — самая выгодная по дню"
    ]
  },
  {
    h2: "Что входит в стоимость путёвки",
    text: "Цена смены АйДаКемп — это полная стоимость без сюрпризов.",
    list: [
      "Проживание в корпусе — комнаты по 2–4 человека с санузлом",
      "Питание 5 раз в день — завтрак, 2й завтрак, обед, полдник, ужин",
      "Полная IT-программа — Python, AI, Minecraft по возрасту",
      "Бассейн, спорт, командные активности каждый день",
      "Охрана 24/7, медработник на смене",
      "Ежедневные фото и новости в родительском канале",
      "Итоговый хакатон — защита проекта перед родителями"
    ]
  },
  {
    h2: "Налоговый вычет 13% за лагерь",
    text: "Путёвка в детский лагерь входит в категорию расходов на образование и оздоровление ребёнка. Родители вправе оформить социальный налоговый вычет 13% от стоимости — если ребёнку не исполнилось 18 лет.",
    list: [
      "Вычет 13% — с путёвки за 48 000 ₽ вернёте 6 240 ₽",
      "Мы предоставляем все документы: договор, чек, акт",
      "Оформить через налоговую онлайн на сайте ФНС или через Госуслуги",
      "Максимальная база для вычета — 120 000 ₽ в год на все социальные расходы"
    ]
  },
  {
    h2: "Компенсация за лагерь от работодателя и Москвы",
    text: "Стоимость путёвки можно снизить несколькими способами: через работодателя, городские программы поддержки семей или налоговый вычет.",
    list: [
      "Работодатель — многие московские компании компенсируют 30–100% стоимости путёвки. Выставляем счёт на юрлицо с полным пакетом документов",
      "Субсидия Москвы — в 2026 году действует программа частичной компенсации путёвок для малообеспеченных семей. Информация на mos.ru",
      "Профсоюз — если вы член профсоюза, уточните у профорга — часто покрывают 20–50% стоимости",
      "ФСС — для отдельных категорий сотрудников возможна частичная оплата через Фонд социального страхования"
    ]
  },
  {
    h2: "Почему АйДаКемп выгоднее",
    text: "Средняя цена загородного лагеря в Подмосковье — 7 000–12 000 ₽ в день. В АйДаКемп стоимость дня начинается от 6 786 ₽ при длинной смене. При этом в цену входит IT-программа, которую в других лагерях платят отдельно.",
    list: [
      "Нет доплат за кружки и мастер-классы — всё включено",
      "Нет доплат за питание — 5-разовое питание включено",
      "Возврат 50% стоимости если не понравилось в первые 3 дня",
      "Фиксация цены на 72 часа — бронируете сейчас, платите после подтверждения"
    ]
  },
  {
    h2: "Как купить путёвку в лагерь",
    text: "Оставьте заявку на сайте — перезвоним в течение 10 минут в рабочее время (11:00–20:00 МСК). Обсудим возраст ребёнка, выберем смену, зафиксируем место. Оплата по договору — безопасно и прозрачно. Работаем как лицензированный туроператор (РТО 025773)."
  }
];

const relatedPages = [
  { title: "Купить путёвку", url: "/kupit-putevku-v-lager", icon: "bi-cart-check", description: "Онлайн-бронирование" },
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "О месте и условиях" },
  { title: "Для компаний", url: "/dlya-kompaniy", icon: "bi-building", description: "Корпоративные путёвки" },
];
---

<LandingLayout
  title="Цены на летний лагерь в Подмосковье 2026 — от 48 000 ₽ | АйДаКемп"
  description="Цены на детский лагерь в Подмосковье 2026: смены от 48 000 ₽. Что входит в стоимость, налоговый вычет 13%, компенсация от работодателя и Москвы. АйДаКемп."
  h1="Цены на летний лагерь в Подмосковье 2026"
  canonical="https://aidacamp.ru/lager-nedorogo"
>
  <LandingHero
    h1="Цены на летний лагерь в Подмосковье 2026"
    subtitle="Цены на детский лагерь 2026: от 48 000 ₽ за смену. Проживание, питание и IT-программа включены. Налоговый вычет 13%, компенсация от работодателя."
    breadcrumb="Цены и путёвки"
    keywords={["От 48 000 ₽ за смену — проживание, питание, программа включены", "Смены от 7 до 14 дней — выбери подходящую", "Фиксация цены на 72 часа — возврат если не понравится"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
