---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Чем летняя IT-школа отличается от курсов",
    text: "Онлайн-курс даёт теорию. Кружок — 1–2 часа в неделю. Летняя IT-школа — это 7–14 дней полного погружения: занятия каждый день, преподаватель рядом, живое общение с такими же детьми. За это время ребёнок проходит путь от первого кода до готового проекта. Это невозможно в онлайне."
  },
  {
    h2: "Программа летней IT-школы",
    text: "Программа построена по принципу «от простого к сложному» внутри каждой смены.",
    list: [
      "День 1–2: знакомство, базовые концепции, первые шаги",
      "День 3–5: основной учебный блок, работа над проектом",
      "День 6–8: углубление, доработка, помощь преподавателя",
      "Финал: хакатон — защита проекта перед всеми"
    ]
  },
  {
    h2: "Преподаватели IT-школы",
    text: "Команда АйДаКемп работает с детьми с 2019 года. Через офлайн-школу #АйДаКодить прошли более 1200 учеников. Никита Брагин и Александр Ташкин — авторы учебника по Python для детей (тираж 2000 экз., продаётся в магазинах)."
  }
];

const relatedPages = [
  { title: "Лагерь программирования", description: "От первого кода до своего проекта", url: "/lager-programmirovaniya", icon: "bi-keyboard" },
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft с проживанием", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Лагерь для подростков", description: "Отдельная программа 12–16 лет", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff" },
];
---

<LandingLayout
  title="Летняя IT-школа для детей 2026 в Подмосковье — АйДаКемп"
  description="Летняя IT-школа с проживанием в Подмосковье. Программирование, AI, Minecraft для детей 7–14 лет. Авторская программа, преподаватели с опытом 6 лет. От 48 000 ₽."
  h1="Летняя IT-школа для детей в Подмосковье"
  canonical="https://aidacamp.ru/letnyaya-it-shkola"
>
  <LandingHero
    h1="Летняя IT-школа для детей в Подмосковье"
    subtitle="Летняя IT-школа с проживанием в Подмосковье. Авторская программа, малые группы, реальный проект за смену."
    breadcrumb="Летняя IT-школа"
    keywords={["Авторская программа по Python, AI, Minecraft", "Преподаватели-практики с 6-летним опытом", "Загородный формат с проживанием и бассейном"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
