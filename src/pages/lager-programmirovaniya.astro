---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Как устроен лагерь программирования",
    text: "АйДаКемп — загородный лагерь с IT-программой, где программирование — не факультатив, а основа каждого дня. Утром дети работают над проектом под руководством преподавателей. Днём — бассейн, спорт, командные игры. В конце смены — хакатон: каждый защищает свой проект перед всей группой."
  },
  {
    h2: "Курсы программирования в лагере",
    text: "Программа разделена по возрасту и уровню подготовки. Новички начинают со Scratch и визуального кодинга, продвинутые — работают с Python, API и нейросетями.",
    list: [
      "Scratch — визуальное программирование для 7–9 лет",
      "Python — основной язык для 10–14 лет",
      "AI и нейросети — практика с реальными инструментами",
      "Minecraft Education — программирование через игру",
      "Веб и дизайн — HTML, CSS, Figma"
    ]
  },
  {
    h2: "Преподаватели лагеря программирования",
    text: "Занятия ведут авторы учебника по Python для детей (тираж 2000 экз.). Команда преподавателей работает с детьми с 2019 года — через школу #АйДаКодить прошли более 1200 учеников. Соотношение преподавателей к детям — 1:6."
  },
  {
    h2: "Расположение и условия",
    text: "Лагерь находится в Московской области, Наро-Фоминский район, территория санатория «Изумруд» — 66 км от Москвы по Калужскому шоссе. Комнаты по 2–4 человека, 5-разовое питание, бассейн с ионизированной водой, охрана 24/7."
  }
];

const relatedPages = [
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft с проживанием", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Летняя IT-школа", description: "Загородный формат с программой", url: "/letnyaya-it-shkola", icon: "bi-mortarboard" },
  { title: "Лагерь для подростков", description: "Отдельная программа 12–16 лет", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff" },
];
---

<LandingLayout
  title="Лагерь программирования для детей 2026 — Python, AI | АйДаКемп"
  description="Лагерь программирования для детей 7–14 лет в Подмосковье. От Scratch и Minecraft до Python и AI. Проект за смену. 66 км от Москвы, от 48 000 ₽."
  h1="Лагерь программирования для детей"
  canonical="https://aidacamp.ru/lager-programmirovaniya"
>
  <LandingHero
    h1="Лагерь программирования для детей"
    subtitle="От первого кода до собственного проекта за смену. Python, AI, боты — программа подбирается по возрасту."
    breadcrumb="Лагерь программирования"
    keywords={["Python, AI, Scratch — от первых шагов до своего проекта", "Преподаватели — авторы книги по Python для детей", "Смены 7–14 дней с проживанием в Подмосковье"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
