---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Где находится лагерь в Подмосковье",
    text: "АйДаКемп расположен в Московской области — в Наро-Фоминском районе, на территории санатория «Изумруд». До лагеря 66 км от МКАД по Калужскому шоссе, около часа езды на машине. Это загородная территория вдали от города: лес, чистый воздух, закрытая охраняемая территория."
  },
  {
    h2: "Почему родители выбирают лагерь в Подмосковье",
    text: "Подмосковье — оптимальный выбор для московских семей: близко, но уже по-настоящему за городом. Ребёнок в безопасности, родители в доступности. В АйДаКемп дети не просто отдыхают — они создают IT-проекты под руководством преподавателей-практиков, авторов книги по Python для детей.",
    list: [
      "Закрытая территория санатория, охрана 24/7, медработник",
      "Комнаты по 2–4 человека с санузлом, 5-разовое питание",
      "Бассейн с ионизированной водой, спортплощадки",
      "Ежедневные фото и связь с родителями",
      "Договор, страховка, лицензия туроператора РТО 025773"
    ]
  },
  {
    h2: "Детские лагеря Подмосковья: чем АйДаКемп отличается",
    text: "В Подмосковье десятки лагерей. Большинство — спортивные или общего профиля. АйДаКемп — один из немногих с полноценной IT-программой: Python, AI, Minecraft, веб-дизайн. Занятия ведут преподаватели с опытом 6+ лет, авторы учебника по программированию для детей. Результат смены — готовый проект, который ребёнок защищает на итоговом хакатоне."
  },
  {
    h2: "Смены в Подмосковье летом 2026",
    text: "Лагерь работает с конца мая по август 2026. Продолжительность смен — от 7 до 14 дней. Стоимость от 48 000 ₽ включает проживание, питание, полную IT-программу и активности.",
    list: [
      "Смена 1 — 30 мая–8 июня, 10 дней, 74 900 ₽",
      "Смена 2 — 10–23 июня, 14 дней, 95 000 ₽ (популярная)",
      "Смена 3 — 3–15 августа, 13 дней, 89 400 ₽",
      "Смена 4 — 17–26 августа, 10 дней, 69 600 ₽",
      "Короткие смены 2.1 и 2.2 — от 7 дней, от 48 000 ₽"
    ]
  },
  {
    h2: "Как добраться до лагеря в Подмосковье",
    text: "Лагерь расположен в Наро-Фоминском районе Московской области — на территории санатория «Изумруд». Большинство семей добираются на личном автомобиле по Калужскому шоссе (A-101).",
    list: [
      "Из Наро-Фоминска — 20 минут",
      "Из Апрелевки, Кубинки, Селятино, Голицыно — 40–50 минут",
      "Из Обнинска, Балабаново — 30 минут",
      "Из Подольска, Троицка, Щербинки — около часа",
      "Из юго-западных районов Москвы (Тёплый Стан, Ясенево, Кунцево) — 1–1.5 часа",
      "Из центра Москвы — около 1.5 часов"
    ]
  },
  {
    h2: "Адрес и координаты лагеря",
    text: "Адрес: Московская область, Наро-Фоминский городской округ, санаторий «Изумруд». Координаты: 55.265643, 36.724185."
  }
];

const relatedPages = [
  { title: "Лагерь в Москве", url: "/lager-v-moskve", icon: "bi-geo-alt", description: "Как добраться из Москвы" },
  { title: "Детский лагерь", url: "/detskiy-lager", icon: "bi-house-heart", description: "Формат и возраст" },
  { title: "Детский лагерь Подмосковье", url: "/detskiy-lager-podmoskove", icon: "bi-tree", description: "Условия, проживание, питание" },
  { title: "Лагерь на август", url: "/lager-na-avgust-podmoskove", icon: "bi-sun", description: "Смены августа 2026" },
  { title: "Лагерь программирования", url: "/lager-programmirovaniya", icon: "bi-keyboard", description: "IT-программа подробно" },
];
---

<LandingLayout
  title="Лагерь в Подмосковье 2026 — детский IT, от 48 000 ₽ | АйДаКемп"
  description="Лагерь в Подмосковье для детей 7–14 лет — 66 км от Москвы по Калужскому шоссе. Python, AI, Minecraft, бассейн. Смены 2026, от 48 000 ₽. Питание включено."
  h1="Лагерь в Подмосковье для детей 2026"
  canonical="https://aidacamp.ru/lager-v-podmoskove"
>
  <LandingHero
    h1="Лагерь в Подмосковье для детей 2026"
    subtitle="66 км от Москвы по Калужскому шоссе. Детский летний лагерь с IT-программой, бассейном и 5-разовым питанием."
    breadcrumb="Лагерь в Подмосковье"
    keywords={["66 км от Москвы, Наро-Фоминский район, Санаторий Изумруд", "IT-программа: Python, AI, Minecraft — проект за смену", "Бассейн, охрана 24/7, лицензированный туроператор"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
