---
import '../../styles/global.css';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const relatedPages = [
  { title: "IT-программа лагеря", url: "/kompyuternyy-lager", icon: "bi-laptop", description: "Чему учат детей" },
  { title: "Детский лагерь", url: "/detskiy-lager", icon: "bi-houses", description: "О формате" },
  { title: "Внутренняя экономика", url: "/stati/vnutrennyaya-ekonomika-v-lagere", icon: "bi-coin", description: "Похожая статья" },
];
---

<Base
  title="Хакатон в детском лагере: как за 10 часов ребёнок создаёт стартап | АйДаКемп"
  description="Хакатон «Стартап из будущего» в IT-лагере АйДаКемп — 10 часов от идеи до питча перед инвесторами. Роли, бюджет, ИИ-инструменты. Дети 7–14 лет."
>
  <Header />
  <main class="mx-auto max-w-[860px] px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-[13px] text-slate-400 mb-6">
      <a href="/" class="hover:text-primary-light transition">Главная</a>
      <span class="mx-1">&rarr;</span>
      <a href="/stati/zavisimost-ot-kompyuternyh-igr" class="hover:text-primary-light transition">Статьи</a>
      <span class="mx-1">&rarr;</span>
      <span class="text-slate-600">Хакатон в детском лагере</span>
    </nav>

    <!-- H1 -->
    <h1 class="text-[32px] md:text-[40px] font-bold leading-[1.15] tracking-[-0.03em] text-slate-900 mb-4">
      Хакатон в детском лагере: как за 10 часов ребёнок проживает путь от идеи до питча
    </h1>

    <p class="text-[16px] text-slate-500 mb-10">
      Почему soft skills нельзя «преподать» на уроке — но можно прожить на хакатоне.
    </p>

    <!-- Article content -->
    <article>

      <!-- Intro -->
      <div class="mb-10">
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px]">
          Научить ребёнка программировать — не самая сложная задача. Есть Scratch, есть Python, есть тысяча курсов. А вот научить договариваться, распределять роли, укладываться в дедлайн и защищать свою работу перед незнакомыми людьми — это другой уровень. И обычно этому не учат нигде.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mt-4">
          В АйДаКемп мы решили это изменить. В финале каждой смены проходит хакатон «Стартап из будущего» — и это самый интенсивный день за все десять.
        </p>
      </div>

      <!-- Section 1 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Не олимпиада и не конкурс поделок
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Хакатон — это не «кто быстрее напишет код». И не выставка проектов, где все получают грамоты за участие. Это симуляция настоящего стартапа: с ролями, бюджетом, инвесторами и жёстким таймингом.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Каждая команда получает стартовый капитал в специальных фишках. Фишки тратятся на «покупку» консультаций у менторов, доступ к технологиям, дополнительные ресурсы. Кончились фишки — работаешь с тем, что есть. Или идёшь договариваться с другой командой.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px]">
          Роли распределены как в реальной компании:
        </p>
        <ul class="flex flex-col gap-2 mt-4">
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700"><strong>Хакер</strong> — техническая реализация</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700"><strong>Дизайнер</strong> — интерфейс и визуал</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700"><strong>Маркетолог</strong> — название, слоган, продвижение</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700"><strong>Финансовый директор</strong> — бюджет и ресурсы</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700"><strong>Стратег</strong> — общее видение и питч</span></li>
        </ul>
      </div>

      <!-- Section 2 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            10 часов от нуля до питча
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Тайминг жёсткий. За 8–10 часов команда должна пройти полный цикл:
        </p>
        <ul class="flex flex-col gap-4">
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Генерация идей.</strong> Первый час — мозговой штурм. Дети придумывают приложение, сервис или продукт, который решает реальную проблему. Не «ещё одна игра», а что-то, что можно объяснить инвестору.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Паспорт приложения.</strong> Второй час — формализация. Кто целевая аудитория? Какую проблему решаем? Чем отличаемся от конкурентов? Для одиннадцатилетнего сформулировать ценностное предложение — уже подвиг.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Прототип.</strong> Три-четыре часа — на создание рабочего прототипа. Кто-то делает в Figma, кто-то пишет бота, кто-то собирает лендинг. ИИ-инструменты используются открыто: генерация логотипов, маркетинговых текстов, названий.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Презентация.</strong> Последние два часа — подготовка питча. Слайды, речь, демонстрация. Репетиция. Паника. Ещё одна репетиция.</span>
          </li>
        </ul>
      </div>

      <!-- Section 3 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Два раунда инвестиций
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Посередине хакатона — первый раунд инвестиций. Команды представляют промежуточные результаты жюри. Жюри задаёт вопросы и распределяет дополнительные фишки. Кто убедительнее — тот получает больше ресурсов на вторую половину.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px]">
          Финальный питч — второй раунд. Здесь уже полноценная защита: три минуты на презентацию, две минуты на вопросы. Оценивается не только продукт, но и то, как команда его подаёт. Дети, которые утром стеснялись говорить вслух, к вечеру стоят перед аудиторией и защищают свой стартап. Это происходит каждую смену.
        </p>
      </div>

      <!-- Section 4 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Почему это развивает больше, чем кружок программирования
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Кружок учит писать код. Хакатон учит всему остальному.
        </p>
        <ul class="flex flex-col gap-4">
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Работа в команде.</strong> Нельзя быть «самым умным» и тянуть одеяло. У дизайнера нет доступа к коду, у хакера нет навыков презентации. Приходится доверять.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Управление ресурсами.</strong> Фишки кончаются. Время кончается. Нужно решать: потратить на консультацию или сэкономить на финал? Инвестировать в дизайн или в функциональность?</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Переговоры.</strong> Между командами идёт обмен: «мы поможем вам с дизайном, а вы нам — с кодом». Иногда команды сливаются. Иногда — разваливаются и собираются заново.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Публичные выступления.</strong> Три минуты перед жюри — это стресс. Но стресс управляемый, в безопасной среде. После первого питча второй даётся легче.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span class="text-[15px] text-slate-700"><strong>Работа с обратной связью.</strong> Жюри не ставит оценки — оно задаёт вопросы. Дети учатся отвечать на неудобные вопросы, а не обижаться на них.</span>
          </li>
        </ul>
      </div>

      <!-- Section 5 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Что это даёт за пределами лагеря
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Родители часто ждут от лагеря «навыков программирования». И дети правда их получают — за десять дней каждый собирает проект, будь то бот, игра или сайт. Но хакатон даёт другое — опыт, который пригодится независимо от того, станет ребёнок программистом или нет.
        </p>
        <ul class="flex flex-col gap-2">
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700">Умение формулировать идею так, чтобы её поняли другие</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700">Умение работать в команде, где не все согласны</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700">Умение принимать решения в условиях ограниченного времени и ресурсов</span></li>
          <li class="flex items-start gap-2.5"><span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span class="text-[15px] text-slate-700">Умение проигрывать — и пробовать снова</span></li>
        </ul>
      </div>

      <!-- Section 6 -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Хакатон + внутренняя экономика = двойной опыт
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px]">
          В АйДаКемп хакатон не существует в вакууме. Всю смену ребёнок живёт в системе внутренней экономики — управляет личным бюджетом, принимает решения о тратах, участвует в коллективных покупках. А на хакатоне он управляет ресурсами стартапа. Получается два экономических опыта за одну смену: ежедневный — про личные финансы, и интенсивный — про бизнес. Один учит считать, другой учит рисковать. Вместе — учат думать.
        </p>
      </div>

      <!-- CTA -->
      <div class="mb-10 border-t border-slate-100 pt-10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h2 class="text-[20px] md:text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-slate-900">
            Для кого это
          </h2>
        </div>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          АйДаКемп — выездной IT-лагерь в Подмосковье для детей 7–14 лет. 66 км от Москвы, смены от 7 до 14 дней. Бассейн, 5-разовое питание, образовательная лицензия (налоговый вычет 13%).
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-4">
          Четыре трека обучения: Python, AI, дроны, 3D-моделирование. Итог смены — собственный проект и хакатон.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-600 max-w-[720px] mb-6">
          Если ваш ребёнок умеет кодить — отлично, он углубит навыки. Если не умеет — тоже отлично, он начнёт. Но в любом случае он уедет с опытом, который не даст ни одна школа: опытом настоящего дела от идеи до результата.
        </p>
        <p class="text-[15px] md:text-[16px] leading-[1.7] text-slate-500 italic">
          Смены лета 2026: с 30 мая по 26 августа. Забронировать место: <a href="https://aidacamp.ru" class="text-primary-light hover:underline">aidacamp.ru</a>
        </p>
      </div>

    </article>
  </main>
  <RelatedPages pages={relatedPages} />
  <Footer />
</Base>
