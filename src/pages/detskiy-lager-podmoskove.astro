---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Где находится лагерь",
    text: "АйДаКемп расположен в Наро-Фоминском районе Московской области, на территории санатория «Изумруд». До лагеря 66 км от МКАД по Калужскому шоссе — около часа езды."
  },
  {
    h2: "Условия проживания и питания",
    text: "Дети живут в корпусах санатория: светлые комнаты по 2–4 человека, раздельное проживание мальчиков и девочек. Питание 5 раз в день — завтрак, второй завтрак, обед, полдник, ужин. На территории: бассейн с ионизированной водой, спортивные площадки, зоны отдыха.",
    list: [
      "Комнаты по 2–4 человека, раздельное проживание",
      "Бассейн с ионизированной водой (без хлора)",
      "5-разовое питание, учёт аллергий",
      "Охрана территории 24/7",
      "Медработник на протяжении всей смены"
    ]
  },
  {
    h2: "Безопасность и документы",
    text: "АйДаКемп работает как лицензированный туроператор детского отдыха (реестровый номер РТО 025773). Родители получают договор, страховку и полный пакет документов. На смене дежурит медработник, охрана работает круглосуточно. Связь с ребёнком — ежедневно."
  },
  {
    h2: "Как добраться из Москвы",
    text: "Адрес: Московская область, Наро-Фоминский городской округ, территория «Санаторий Изумруд». Координаты: 55.265643, 36.724185. На машине: по Калужскому шоссе, 66 км от МКАД."
  }
];

const relatedPages = [
  { title: "Детский лагерь", description: "Формат и возраст 7–14 лет", url: "/detskiy-lager", icon: "bi-house-heart" },
  { title: "Цены и путёвки", description: "От 48 000 ₽ за смену", url: "/lager-nedorogo", icon: "bi-tag" },
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft с проживанием", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Лагерь для подростков", description: "Отдельная программа 12–16 лет", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff" },
  { title: "Тематический лагерь", description: "Каждая смена — своя тема", url: "/tematicheskiy-lager", icon: "bi-bullseye" },
];
---

<LandingLayout
  title="Детский лагерь в Подмосковье с проживанием 2026 — АйДаКемп"
  description="Детский лагерь в Подмосковье, 66 км от Москвы. Проживание в корпусе, бассейн, 5-разовое питание, IT-программа, охрана 24/7. Детские лагеря Подмосковья, от 48 000 ₽."
  h1="Детский лагерь в Подмосковье с проживанием"
  canonical="https://aidacamp.ru/detskiy-lager-podmoskove"
>
  <LandingHero
    h1="Детский лагерь в Подмосковье с проживанием"
    subtitle="Детские лагеря Подмосковья — 66 км от Москвы. Проживание, бассейн, питание и IT-проект за смену."
    breadcrumb="Детский лагерь Подмосковье"
    keywords={["66 км от Москвы по Калужскому шоссе, Санаторий Изумруд", "Бассейн, 5-разовое питание, комнаты 2–4 человека", "Охрана 24/7, медработник, лицензированный туроператор"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
