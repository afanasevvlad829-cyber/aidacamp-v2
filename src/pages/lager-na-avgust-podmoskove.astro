---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Августовские смены АйДаКемп 2026",
    text: "В августе 2026 проходят две смены АйДаКемп в Подмосковье. Смена 3 — с 3 по 15 августа, 13 дней, стоимость 89 400 ₽. Смена 4 — с 17 по 26 августа, 10 дней, стоимость 69 600 ₽. В обеих сменах — полная IT-программа, бассейн, 5-разовое питание и проживание."
  },
  {
    h2: "Почему стоит выбрать августовскую смену",
    text: "Август — особое время. Дети ещё в летнем настроении, но уже готовы к учёбе. Августовская смена помогает плавно войти в новый учебный год: ребёнок заряжается, создаёт проект и возвращается домой с уверенностью в себе. Многие дети, побывавшие в июне, просятся ещё раз именно в августе.",
    list: [
      "Смена 3: 3–15 августа, 13 дней — 89 400 ₽",
      "Смена 4: 17–26 августа, 10 дней — 69 600 ₽",
      "В цену включено: проживание, питание, программа, активности"
    ]
  },
  {
    h2: "Программа в августе",
    text: "Программа августовских смен не отличается от летних — полный IT-курс по возрасту. Дети 7–10 лет работают со Scratch и Minecraft. Дети 10–12 лет изучают Python и основы AI. Подростки 13–14 лет — Python Advanced, боты, работа с API и нейросетями. Финал — хакатон: каждый защищает свой проект."
  },
  {
    h2: "Расположение: Подмосковье, 66 км от Москвы",
    text: "Лагерь находится в Наро-Фоминском районе Московской области, на территории санатория «Изумруд». 66 км от МКАД по Калужскому шоссе. Охраняемая территория, бассейн с ионизированной водой, комнаты по 2–4 человека."
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Все смены и условия" },
  { title: "Детский лагерь Подмосковье", url: "/detskiy-lager-podmoskove", icon: "bi-houses", description: "Проживание и питание" },
  { title: "Лагерь для подростков", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff", description: "Программа 12–16 лет" },
];
---

<LandingLayout
  title="Лагерь на август в Подмосковье 2026 — IT-смены | АйДаКемп"
  description="Детский лагерь в Подмосковье в августе 2026. IT-программа, Python, AI, Minecraft. 66 км от Москвы, смены 3–15 августа и 17–26 августа. От 69 600 ₽."
  h1="Лагерь на август в Подмосковье"
  canonical="https://aidacamp.ru/lager-na-avgust-podmoskove"
>
  <LandingHero
    h1="Лагерь на август в Подмосковье"
    subtitle="Две смены в августе 2026 — 3–15 и 17–26 августа. IT-проект за смену, бассейн, Подмосковье."
    breadcrumb="Лагерь на август"
    keywords={["Смены: 3–15 августа (13 дней) и 17–26 августа (10 дней)", "IT-программа: Python, AI, Minecraft — свой проект на выходе", "66 км от Москвы, бассейн, питание, охрана 24/7"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
