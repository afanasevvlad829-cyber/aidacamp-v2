---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Что такое образовательный лагерь",
    text: "Образовательный лагерь — это формат, где обучение и отдых неразделимы. АйДаКемп — один из немногих лагерей в Подмосковье, где образовательная программа выстроена как полноценный курс: с прогрессией, проектной работой и итоговой защитой. Ребёнок не «проходит» темы — он создаёт продукт."
  },
  {
    h2: "Образовательная программа по направлениям",
    text: "Программа разделена по возрасту и уровню подготовки.",
    list: [
      "Scratch (7–9 лет) — визуальное программирование, первые проекты",
      "Python (10–14 лет) — основной язык, от синтаксиса до рабочей программы",
      "AI и нейросети (12–14 лет) — ChatGPT API, обучение моделей",
      "Minecraft Education (7–12 лет) — программирование через игру",
      "Дизайн и анимация (8–14 лет) — Figma, графика, интерфейсы"
    ]
  },
  {
    h2: "Кто ведёт занятия",
    text: "Преподаватели АйДаКемп работают с детьми с 2019 года через офлайн-школу программирования #АйДаКодить. Никита Брагин и Александр Ташкин — авторы учебника по Python для детей, тираж 2000 экземпляров. Соотношение преподавателей к детям — 1:6, занятия в малых группах."
  },
  {
    h2: "Итог образовательной смены — хакатон",
    text: "Каждая смена заканчивается хакатоном: дети представляют свои проекты перед всей группой. Это не экзамен — это праздник. Ребёнок уезжает домой с готовым проектом, который можно показать друзьям, выложить в сеть или продолжить развивать. Родители видят конкретный результат, а не просто «провели время»."
  }
];

const relatedPages = [
  { title: "Лагерь программирования", url: "/lager-programmirovaniya", icon: "bi-keyboard", description: "Программа IT-обучения" },
  { title: "Летняя IT-школа", url: "/letnyaya-it-shkola", icon: "bi-mortarboard", description: "Школьный формат" },
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Условия и расположение" },
];
---

<LandingLayout
  title="Образовательный лагерь для детей 2026 — IT Подмосковье | АйДаКемп"
  description="IT-образовательный лагерь для детей 7–14 лет. Python, AI, Minecraft — реальный проект за смену. 66 км от Москвы, лицензированный туроператор. От 48 000 ₽."
  h1="Образовательный лагерь для детей в Подмосковье"
  canonical="https://aidacamp.ru/obrazovatelnyy-lager"
>
  <LandingHero
    h1="Образовательный лагерь для детей в Подмосковье"
    subtitle="Не просто отдых — каждая смена заканчивается проектом. IT-образование в загородном формате."
    breadcrumb="Образовательный лагерь"
    keywords={["Авторская программа: Python, AI, Minecraft, дизайн", "Преподаватели — авторы учебника по Python для детей", "Результат смены — готовый проект с презентацией"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
