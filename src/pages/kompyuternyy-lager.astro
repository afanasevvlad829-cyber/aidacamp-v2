---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Что такое компьютерный лагерь АйДаКемп",
    text: "Компьютерный лагерь — это не «сидеть за экраном весь день». Это место, где ребёнок создаёт собственный проект: игру, бота, анимацию или нейросетевой эксперимент. За каждую смену дети проходят путь от идеи до готового результата, который можно показать родителям. Лагерь находится в Подмосковье, в 66 км от Москвы по Калужскому шоссе — на территории санатория «Изумруд» с бассейном и 5-разовым питанием."
  },
  {
    h2: "Программа компьютерного лагеря",
    text: "Занятия адаптированы под возраст — группы 7–10, 10–12 и 13–14 лет. Направления: Python, AI и нейросети, Minecraft-разработка, Scratch, веб и дизайн.",
    list: [
      "Python и основы программирования — с нуля до рабочего проекта",
      "AI и нейросети — практика с ChatGPT и реальными инструментами",
      "Minecraft — создание собственных миров и модов",
      "Дизайн и анимация — Figma, графика, интерфейсы"
    ]
  },
  {
    h2: "Чем компьютерный лагерь отличается от кружка",
    text: "В отличие от недельных курсов, лагерь даёт полное погружение: утром занятия, днём активности (бассейн, спорт, командные игры), вечером — работа над проектом. Здесь нет смартфонов в кармане — экранное время зарабатывается за участие и помощь другим. Это учит ценить время и работать осознанно."
  },
  {
    h2: "Стоимость и смены компьютерного лагеря",
    text: "Смены проходят с июня по август 2026 года. Продолжительность — от 7 до 14 дней. В стоимость включены: проживание, питание (5 раз в день), полная IT-программа и активности. Цены — от 48 000 ₽ за 7-дневную смену."
  }
];

const relatedPages = [
  { title: "Детский лагерь", description: "Формат и возраст 7–14 лет", url: "/detskiy-lager", icon: "bi-house-heart" },
  { title: "Лагерь для школьников", description: "1–8 класс, IT-проект", url: "/lager-dlya-shkolnikov", icon: "bi-backpack" },
  { title: "Лагерь программирования", description: "От первого кода до своего проекта", url: "/lager-programmirovaniya", icon: "bi-keyboard" },
  { title: "Лагерь Майнкрафт", description: "Создание миров и модов", url: "/minecraft-lager", icon: "bi-controller" },
  { title: "Летняя IT-школа", description: "Загородный формат с программой", url: "/letnyaya-it-shkola", icon: "bi-mortarboard" },
];
---

<LandingLayout
  title="Компьютерный лагерь для детей 2026 — IT, Python, AI | АйДаКемп"
  description="IT и компьютерный лагерь для детей 7–14 лет в Подмосковье. Python, AI, Minecraft — проект за смену. 66 км от Москвы, бассейн. Смены 2026, от 48 000 ₽."
  h1="Компьютерный лагерь для детей в Подмосковье"
  canonical="https://aidacamp.ru/kompyuternyy-lager"
>
  <LandingHero
    h1="Компьютерный лагерь для детей в Подмосковье"
    subtitle="IT и компьютерный лагерь с проживанием. Дети создают Python-проекты, AI-боты и Minecraft-миры за одну смену."
    breadcrumb="Компьютерный лагерь"
    keywords={["Python, AI, Minecraft — реальный проект за смену", "Без телефонов: экранное время зарабатывается", "66 км от Москвы, бассейн, 5-разовое питание"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <div class="mx-auto max-w-[860px] px-4 mt-6">
    <div class="rounded-[16px] bg-slate-50 p-5">
      <p class="text-[13px] font-semibold uppercase tracking-wide text-slate-400 mb-3">Читайте по теме</p>
      <div class="space-y-2">
        <a href="/stati/hakaton-v-detskom-lagere" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Хакатон в детском лагере: как за 10 часов ребёнок создаёт стартап
        </a>
        <a href="/stati/zavisimost-ot-kompyuternyh-igr" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Зависимость от компьютерных игр у детей — признаки и как бороться
        </a>
      </div>
    </div>
  </div>
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
