---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Что такое тематический лагерь",
    text: "Тематический лагерь — это когда у каждой смены есть своя сквозная идея. В АйДаКемп темы связаны с IT: одна смена сфокусирована на AI и нейросетях, другая — на Minecraft и разработке игр, третья — на питоне и командных проектах. Внутри смены — тематические дни, эвенты и итоговый хакатон."
  },
  {
    h2: "Тематические смены в АйДаКемп 2026",
    text: "Каждая смена в АйДаКемп — отдельная IT-тема. Ребёнок не просто «учится программировать» — он погружается в конкретный мир и создаёт внутри него свой проект.",
    list: [
      "AI и Python — создают игры и приложения с искусственным интеллектом, 10–14 лет",
      "Minecraft и геймдев — разрабатывают моды и карты, изучают геймдизайн, 7–12 лет",
      "Веб и интерфейсы — создают сайты и мобильные прототипы, 11–14 лет",
      "Хакатон-смена — командная разработка с защитой перед жюри, 12–14 лет"
    ]
  },
  {
    h2: "Тематические дни в лагере",
    text: "Помимо основной темы смены, каждый день в лагере имеет свой тематический акцент — это делает программу разнообразной и не даёт детям скучать.",
    list: [
      "День хакатона — командное соревнование по разработке",
      "День презентации — дети защищают проекты перед аудиторией",
      "Спортивный день — турниры, бассейн, командные игры",
      "День экономики — внутренняя валюта лагеря, бизнес-симуляция"
    ]
  }
];

const relatedPages = [
  { title: "Лагерь Майнкрафт", description: "Создание миров и модов", url: "/minecraft-lager", icon: "bi-controller" },
  { title: "Лагерь программирования", description: "От первого кода до своего проекта", url: "/lager-programmirovaniya", icon: "bi-keyboard" },
  { title: "Детский лагерь Подмосковье", description: "66 км от Москвы, бассейн, питание", url: "/detskiy-lager-podmoskove", icon: "bi-tree" },
];
---

<LandingLayout
  title="Тематический лагерь в Подмосковье 2026 — IT темы, АйДаКемп"
  description="Тематический лагерь для детей 7–14 лет в Подмосковье. Темы: AI, Minecraft, геймдев, веб. Тематические дни и хакатон. От 48 000 ₽, смены 2026."
  h1="Тематический лагерь для детей в Подмосковье"
  canonical="https://aidacamp.ru/tematicheskiy-lager"
>
  <LandingHero
    h1="Тематический лагерь для детей в Подмосковье"
    subtitle="Тематический лагерь: каждая смена — своя IT-тема. Python, AI, Minecraft — ребёнок выбирает направление."
    breadcrumb="Тематический лагерь"
    keywords={["Каждая смена — своя тема и направление", "Тематические дни и итоговый хакатон", "IT-тематика: AI, Python, Minecraft, дизайн"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
