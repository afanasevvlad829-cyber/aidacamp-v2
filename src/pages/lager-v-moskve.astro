---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Летний лагерь рядом с Москвой",
    text: "АйДаКемп — загородный IT-лагерь в Подмосковье, который выбирают московские семьи. До лагеря 66 км от МКАД по Калужскому шоссе — около часа езды на машине. Это достаточно близко чтобы приехать на выходных, и достаточно далеко чтобы ребёнок был по-настоящему «в лагере» — в лесу, без городской суеты."
  },
  {
    h2: "Почему московские родители выбирают АйДаКемп",
    text: "Летних лагерей вокруг Москвы много. Мы отличаемся тем, что у нас есть конкретный образовательный результат: ребёнок уезжает с IT-проектом, который сам придумал и сделал за смену. Python, AI, Minecraft — программа адаптирована под возраст от 7 до 14 лет.",
    list: [
      "Авторская IT-программа — Python, AI, Minecraft, дизайн",
      "Преподаватели — авторы учебника по Python для детей",
      "Хакатон в финале — каждый защищает свой проект",
      "Без телефонов — экранное время зарабатывается",
      "Бассейн, спорт, 5-разовое питание, охрана 24/7"
    ]
  },
  {
    h2: "Как добраться из Москвы",
    text: "Адрес: Московская область, Наро-Фоминский городской округ, территория «Санаторий Изумруд». Координаты: 55.265643, 36.724185. На машине из Москвы: по Калужскому шоссе (A-101) на юго-запад, 66 км от МКАД. Время в пути — 50–70 минут в зависимости от пробок."
  },
  {
    h2: "Летний лагерь в Москве — сравнение форматов",
    text: "Городские дневные лагеря в Москве — удобно, но ребёнок каждый вечер дома. Загородный лагерь в Подмосковье — это полное погружение: новые друзья, режим, природа и занятия без отвлечений на привычную среду. Большинство детей после первых двух дней адаптации не хотят уезжать."
  },
  {
    h2: "Летний лагерь в Москве — цены 2026",
    text: "Московские дневные лагеря стоят 3 000–8 000 ₽ в день, загородные форматы — от 48 000 ₽ за смену. АйДаКемп — один из немногих IT-лагерей Подмосковья с фиксированной ценой без скрытых доплат: питание, проживание и полная IT-программа включены.",
    list: [
      "Смена 7 дней — от 48 000 ₽ (6 857 ₽/день)",
      "Смена 10 дней — 74 900 ₽ (7 490 ₽/день)",
      "Смена 14 дней — 95 000 ₽ (6 786 ₽/день) — выгоднее всего",
      "Компенсация через работодателя — до 50% стоимости"
    ]
  },
  {
    h2: "Компенсация за лагерь от работодателя",
    text: "Многие московские компании частично или полностью компенсируют путёвки в летний лагерь для детей сотрудников. АйДаКемп работает с юридическими лицами: предоставляем договор, закрывающие документы и чеки для бухгалтерии.",
    list: [
      "Договор с ООО или ИП — выставляем счёт на юрлицо",
      "Закрывающие документы — акты, счета-фактуры",
      "Групповые условия при бронировании от 3 путёвок"
    ]
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Расположение, смены, цены" },
  { title: "Детский лагерь Подмосковье", url: "/detskiy-lager-podmoskove", icon: "bi-house-heart", description: "Условия проживания" },
  { title: "Лагерь для подростков", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff", description: "Программа 12–16 лет" },
];
---

<LandingLayout
  title="Летний лагерь в Москве 2026 — недорого, цены, IT | АйДаКемп"
  description="Летний лагерь в Москве и Подмосковье — 66 км от МКАД. От 48 000 ₽ за смену, всё включено. Компенсация от работодателя. IT-программа: Python, AI, Minecraft."
  h1="Летний лагерь в Москве — 66 км от МКАД"
  canonical="https://aidacamp.ru/lager-v-moskve"
>
  <LandingHero
    h1="Летний лагерь в Москве — 66 км от МКАД"
    subtitle="Летний детский лагерь рядом с Москвой. 66 км по Калужскому шоссе, около часа езды."
    breadcrumb="Лагерь в Москве"
    keywords={["66 км от Москвы — около часа езды по Калужскому шоссе", "Большинство семей добираются на машине по Калужскому шоссе (A-101)", "IT-программа, бассейн, питание — всё включено"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
