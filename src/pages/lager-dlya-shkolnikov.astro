---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Летний лагерь для школьников — чем отличается АйДаКемп",
    text: "Большинство летних лагерей для школьников — это развлечения и «занять время». В АйДаКемп иначе: каждый школьник создаёт собственный IT-проект за смену и защищает его на финальном хакатоне. Родители видят конкретный результат, а не просто «хорошо провёл время»."
  },
  {
    h2: "Программа для школьников разных классов",
    text: "Программа делится по возрасту: младшие школьники (1–4 класс, 7–10 лет) работают в Scratch и Minecraft. Средние (5–7 класс, 10–13 лет) — Python, телеграм-боты, веб. Старшие (8 класс, 13–14 лет) — Python Advanced, AI, работа с реальными данными.",
    list: [
      "1–4 класс (7–10 лет) — Scratch, Minecraft, логика",
      "5–7 класс (10–13 лет) — Python, боты, веб-разработка",
      "8 класс (13–14 лет) — Python Advanced, AI, API"
    ]
  },
  {
    h2: "Что делают школьники помимо IT",
    text: "Летний лагерь — это не только занятия. После обеда: бассейн с ионизированной водой, спорт, командные игры на улице. Каждый вечер — работа над проектом и внутренняя «валюта» лагеря, которую зарабатывают за активность. Смартфоны сданы, скуки нет."
  },
  {
    h2: "Когда и как записать школьника",
    text: "Смены проходят с конца мая по август 2026. Оставьте заявку — перезвоним в течение 10 минут и поможем выбрать подходящую смену по возрасту и расписанию. Места ограничены — не более 45 детей на смену."
  }
];

const relatedPages = [
  { title: "Детский лагерь", url: "/detskiy-lager", icon: "bi-house-heart", description: "Подробно о формате" },
  { title: "Лагерь программирования", url: "/lager-programmirovaniya", icon: "bi-keyboard", description: "IT-программа" },
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Расположение, цены" },
];
---

<LandingLayout
  title="Летний лагерь для школьников 2026 в Подмосковье — IT | АйДаКемп"
  description="Летний лагерь для школьников 1–8 класса в Подмосковье. IT-проект за смену: Python, AI, Minecraft. Летний школьный лагерь 66 км от Москвы. Смены 2026, от 48 000 ₽."
  h1="Летний лагерь для школьников в Подмосковье"
  canonical="https://aidacamp.ru/lager-dlya-shkolnikov"
>
  <LandingHero
    h1="Летний лагерь для школьников в Подмосковье"
    subtitle="Летний школьный лагерь для детей 1–8 класса. IT-проект за смену, бассейн, природа — никаких телефонов."
    breadcrumb="Лагерь для школьников"
    keywords={["Для школьников 1–8 класса, группы по возрасту", "IT-проект за смену: Python, AI, Minecraft", "Подмосковье, 66 км от Москвы, смены июнь–август"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
