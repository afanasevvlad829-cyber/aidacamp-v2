---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Как работает лагерь без телефонов",
    text: "В первый день смены все смартфоны сдаются на хранение. Вместо этого в лагере действует собственная внутренняя валюта — её зарабатывают за участие в активностях, помощь другим, прогресс в IT-проекте. На накопленную валюту можно получить «телефонное время» — строго по правилам. Это не запрет, а осознанный выбор: дети сами видят ценность времени."
  },
  {
    h2: "Почему это работает",
    text: "Большинство родителей боятся, что ребёнок будет страдать без телефона. На практике происходит иначе: за первые 2–3 дня дети полностью включаются в жизнь лагеря. Без телефона в кармане — больше живого общения, больше концентрации на проекте, больше командной работы. Многие дети сами говорят, что не скучали по смартфону.",
    list: [
      "День 1–2: непривычно, но дети быстро адаптируются",
      "День 3–5: полное включение, лагерная жизнь захватывает",
      "Финал смены: большинство не хотят уезжать"
    ]
  },
  {
    h2: "Это не обычный лагерь без гаджетов",
    text: "Важный нюанс: в АйДаКемп дети проводят время за компьютером — но это учёба и работа над проектом, а не бесконтрольный скроллинг. IT-занятия проходят по расписанию, с преподавателем и конкретной целью. Ребёнок учится использовать технологии осознанно — это и есть главный навык современности."
  },
  {
    h2: "Для кого подходит такой формат",
    text: "Лагерь без телефонов особенно подходит детям, которые «залипают» в экраны дома и теряют интерес к живому общению. Родители, которые сами устали от бесконечных переговоров про телефон, находят в АйДаКемп союзника: здесь правила одинаковы для всех, и ребёнок принимает их как данность, а не как личное ограничение.",
    list: [
      "Дети 7–14 лет с любым уровнем «телефонной зависимости»",
      "Те, кто хочет IT-проект, а не просто «выключить» ребёнка",
      "Семьи, которым важна безопасная цифровая среда"
    ]
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Все смены и условия" },
  { title: "Лагерь для подростков", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff", description: "Программа 12–16 лет" },
  { title: "IT-лагерь Подмосковье", url: "/detskiy-lager-podmoskove", icon: "bi-houses", description: "Условия проживания" },
];
---

<LandingLayout
  title="Детский лагерь без телефонов 2026 — Подмосковье | АйДаКемп"
  description="Детский лагерь без телефонов и гаджетов в Подмосковье. Смартфоны сдаются с первого дня — экранное время зарабатывается. IT-программа, 66 км от Москвы."
  h1="Детский лагерь без телефонов в Подмосковье"
  canonical="https://aidacamp.ru/lager-bez-telefonov"
>
  <LandingHero
    h1="Детский лагерь без телефонов в Подмосковье"
    subtitle="Смартфоны сдаются в первый день. Вместо них — внутренняя валюта, IT-проекты и живое общение."
    breadcrumb="Лагерь без телефонов"
    keywords={["Смартфоны сдаются на хранение с первого дня смены", "Экранное время зарабатывается — за участие и помощь другим", "Большинство детей перестают скучать по телефону за 2–3 дня"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <div class="mx-auto max-w-[860px] px-4 mt-6">
    <div class="rounded-[16px] bg-slate-50 p-5">
      <p class="text-[13px] font-semibold uppercase tracking-wide text-slate-400 mb-3">Читайте по теме</p>
      <div class="space-y-2">
        <a href="/stati/zavisimost-ot-telefona-u-podrostkov" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Зависимость от телефона у подростков — признаки и как помочь
        </a>
        <a href="/stati/detskiy-lager-bez-telefonov" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Детский лагерь без телефонов — как дети сами выбирают реальную жизнь
        </a>
      </div>
    </div>
  </div>
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
