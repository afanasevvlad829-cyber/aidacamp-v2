---
import '../styles/global.css';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MomStory from '../components/MomStory.astro';
import About from '../components/About.astro';
import Shifts from '../components/Shifts.astro';
import Gallery from '../components/Gallery.astro';
import Videos from '../components/Videos.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import Team from '../components/Team.astro';
import Stay from '../components/Stay.astro';
import Journey from '../components/Journey.astro';
import Economy from '../components/Economy.astro';
import Hackathon from '../components/Hackathon.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
import RelatedPages from '../components/RelatedPages.astro';
import ShiftOccupancy from '../components/ShiftOccupancy.astro';
import AgeOnboarding from '../components/AgeOnboarding.astro';
import BookingBar from '../components/BookingBar.astro';
import SummerCta from '../components/SummerCta.astro';

const eventsJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {
      "@type": "Event",
      "name": "Смена 1 — АйДаКемп 2026",
      "startDate": "2026-05-30",
      "endDate": "2026-06-08",
      "location": {"@type":"Place","name":"Санаторий Изумруд","address":"Московская область, Наро-Фоминский район"},
      "organizer": {"@type":"Organization","name":"АйДаКемп"},
      "offers": {"@type":"Offer","price":"74900","priceCurrency":"RUB"}
    },
    {
      "@type": "Event",
      "name": "Смена 2 — АйДаКемп 2026",
      "startDate": "2026-06-10",
      "endDate": "2026-06-23",
      "location": {"@type":"Place","name":"Санаторий Изумруд"},
      "offers": {"@type":"Offer","price":"95000","priceCurrency":"RUB"}
    }
  ]
};

const allLandingPages = [
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Лагерь программирования", description: "От кода до проекта", url: "/lager-programmirovaniya", icon: "bi-keyboard" },
  { title: "Лагерь для подростков", description: "Программа 12–16 лет", url: "/lager-dlya-podrostkov", icon: "bi-rocket-takeoff" },
  { title: "Лагерь в Подмосковье", description: "66 км от Москвы", url: "/lager-v-podmoskove", icon: "bi-tree" },
  { title: "Детский лагерь Подмосковье", description: "Проживание и питание", url: "/detskiy-lager-podmoskove", icon: "bi-houses" },
  { title: "Лагерь без телефонов", description: "Жизнь без гаджетов", url: "/lager-bez-telefonov", icon: "bi-phone-x" },
  { title: "Лагерь Майнкрафт", description: "Создание миров и модов", url: "/minecraft-lager", icon: "bi-controller" },
  { title: "Тематический лагерь", description: "Каждая смена — тема", url: "/tematicheskiy-lager", icon: "bi-bullseye" },
  { title: "Летняя IT-школа", description: "Загородный формат", url: "/letnyaya-it-shkola", icon: "bi-mortarboard" },
  { title: "Лагерь на август", description: "Смены августа 2026", url: "/lager-na-avgust-podmoskove", icon: "bi-sun" },
  { title: "Образовательный лагерь", description: "Учёба + результат", url: "/obrazovatelnyy-lager", icon: "bi-book" },
  { title: "Для компаний", description: "Путёвки для сотрудников", url: "/dlya-kompaniy", icon: "bi-building" },
  { title: "Лагерь в Москве", description: "66 км от МКАД", url: "/lager-v-moskve", icon: "bi-geo-alt" },
  { title: "Детский лагерь", description: "Для детей 7–14 лет", url: "/detskiy-lager", icon: "bi-house-heart" },
  { title: "Цены и путёвки", description: "От 48 000 ₽ за смену", url: "/lager-nedorogo", icon: "bi-tag" },
  { title: "Лагерь для школьников", description: "1–8 класс, IT-проект", url: "/lager-dlya-shkolnikov", icon: "bi-backpack" },
];
---

<Base
  title="Летний лагерь в Подмосковье 2026 — IT для детей | АйДаКемп"
  description="Летний лагерь в Подмосковье, 66 км от Москвы. Детям 7–14 лет: Python, AI, Minecraft — уедет с проектом. Смены июнь–август 2026, от 48 000 ₽. Питание и проживание включены."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(eventsJsonLd)} />
  </Fragment>
  <Header />
  <main class="pb-20 md:pb-0">
    <Hero />
    <div class="mx-auto max-w-[1312px] px-[2px] pt-8 md:px-4 lg:pt-12">
      <div class="flex flex-col gap-8 lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start">
        <ShiftOccupancy />
        <MomStory compact />
      </div>
    </div>
    <About />
    <Journey />
    <Economy />
    <BookingBar headline="Понравился подход? Расскажем подробнее" id="after-economy" />
    <Shifts />
    <BookingBar headline="Выбрали смену? Забронируем за 10 минут" id="after-shifts" />
    <SummerCta />
    <Hackathon />
    <Gallery />
    <Videos />
    <Reviews />
    <FAQ />
    <Team />
    <Stay />
    <Contacts />
    <RelatedPages pages={allLandingPages} />
    <AgeOnboarding />
  </main>
  <Footer />
  <StickyCta />
</Base>
