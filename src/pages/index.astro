---
import '../styles/global.css';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MomStory from '../components/MomStory.astro';
import About from '../components/About.astro';
import Shifts from '../components/Shifts.astro';
import Gallery from '../components/Gallery.astro';
import Videos from '../components/Videos.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import Team from '../components/Team.astro';
import Stay from '../components/Stay.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
---

<Base title="АйДаКемп — IT-лагерь 7–14 лет">
