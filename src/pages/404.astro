---
import Base from '../layouts/Base.astro';
---

<Base title="Страница не найдена — АйДаКемп">
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-[80px] font-bold leading-none text-slate-200">404</p>
    <h1 class="mt-4 text-[24px] font-bold text-slate-900">Страница не найдена</h1>
    <p class="mt-2 text-[15px] text-slate-500">Возможно, она была удалена или вы перешли по неверной ссылке</p>
    <a href="/" class="mt-6 rounded-xl bg-[#ec7c00] px-6 py-3 text-[15px] font-semibold text-white transition hover:shadow-lg">
      На главную
    </a>
  </div>
</Base>
