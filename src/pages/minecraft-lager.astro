---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Чем лагерь Майнкрафт отличается от домашней игры",
    text: "В АйДаКемп Minecraft — это не просто игра, а инструмент обучения. Дети работают с Minecraft Education Edition: создают архитектурные проекты, программируют поведение персонажей, строят механизмы с редстоуном. Каждый ребёнок уезжает с собственным миром, который можно запустить дома."
  },
  {
    h2: "Программа Minecraft в лагере",
    text: "",
    list: [
      "Строительство и архитектура — от хижины до города",
      "Редстоун — схемы, механизмы, логика",
      "Создание модов — введение в программирование через игру",
      "Командная работа — совместные проекты и презентации"
    ]
  },
  {
    h2: "Возраст и группы",
    text: "Minecraft подходит детям 7–12 лет. Младшие (7–9) занимаются в Scratch и Minecraft параллельно — это идеальный старт для тех, кто ещё не готов к тексту кода. Старшие (10–12) переходят к программированию модов на Python."
  }
];

const relatedPages = [
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft с проживанием", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Тематический лагерь", description: "Каждая смена — своя тема", url: "/tematicheskiy-lager", icon: "bi-bullseye" },
  { title: "Детский лагерь Подмосковье", description: "66 км от Москвы, бассейн, питание", url: "/detskiy-lager-podmoskove", icon: "bi-tree" },
];
---

<LandingLayout
  title="Детский лагерь Майнкрафт — летний лагерь Minecraft 2026 | АйДаКемп"
  description="Лагерь Майнкрафт для детей 7–14 лет в Подмосковье. Minecraft Education — создание миров, модов и программирование. 66 км от Москвы, от 48 000 ₽."
  h1="Детский лагерь Майнкрафт в Подмосковье"
  canonical="https://aidacamp.ru/minecraft-lager"
>
  <LandingHero
    h1="Детский лагерь Майнкрафт в Подмосковье"
    subtitle="Майнкрафт-лагерь: создание миров, модов и программирование через Minecraft Education. Проект за смену."
    breadcrumb="Лагерь Майнкрафт"
    keywords={["Minecraft Education — официальная образовательная версия", "Создание миров, модов и мини-игр с нуля", "7–14 лет, загородный лагерь с проживанием"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
