---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Почему подросткам нравится АйДаКемп",
    text: "Большинство лагерей не рассчитаны на подростков — там скучно, потому что программа одинакова для всех. В АйДаКемп подростки 13–14 лет занимаются отдельно: более сложные проекты, больше самостоятельности, часть занятий на английском. Нет принудительных активностей — есть свобода выбора в рамках дня."
  },
  {
    h2: "Механика без телефонов: как это работает",
    text: "Смартфоны сдаются на хранение в первый день. Вместо них — внутренняя валюта лагеря, которую зарабатывают за участие в активностях, помощь другим и прогресс в проекте. На неё можно «купить» экранное время или привилегии. Большинство подростков через 2–3 дня перестают скучать по телефону."
  },
  {
    h2: "Программа для подростков 12–16 лет",
    text: "Старшая группа работает с Python, AI-инструментами и реальными задачами.",
    list: [
      "Python Advanced — функции, классы, API, базы данных",
      "AI-проекты — обучение моделей, работа с ChatGPT API",
      "Telegram-боты — создание и публикация рабочего бота",
      "3D и дизайн — моделирование, прототипирование интерфейсов"
    ]
  },
  {
    h2: "Смены и цены для подростков",
    text: "Для подростков подходят смены от 10 дней — за это время успевает сложиться команда и получается полноценный проект. Смена 2 (14 дней, июнь) особенно подходит для тех, кто хочет максимального результата."
  }
];

const relatedPages = [
  { title: "Компьютерный лагерь", description: "Python, AI, Minecraft с проживанием", url: "/kompyuternyy-lager", icon: "bi-laptop" },
  { title: "Лагерь программирования", description: "От первого кода до своего проекта", url: "/lager-programmirovaniya", icon: "bi-keyboard" },
  { title: "Детский лагерь Подмосковье", description: "66 км от Москвы, бассейн, питание", url: "/detskiy-lager-podmoskove", icon: "bi-tree" },
];
---

<LandingLayout
  title="Летний лагерь для подростков 2026 Подмосковье — IT | АйДаКемп"
  description="Лагерь для подростков 10–14 лет в Подмосковье. IT-проект за смену, Python, AI. Без телефонов — экранное время зарабатывается. 66 км от Москвы, от 48 000 ₽."
  h1="Летний лагерь для подростков в Подмосковье"
  canonical="https://aidacamp.ru/lager-dlya-podrostkov"
>
  <LandingHero
    h1="Летний лагерь для подростков в Подмосковье"
    subtitle="Лагерь для подростков 10–14 лет. IT-проект за смену, без телефонов — экранное время зарабатывается."
    breadcrumb="Лагерь для подростков"
    keywords={["Проект за смену — не задание, а личный результат", "Среда без телефонов — экранное время зарабатывается", "Группы 10–12 и 13–14 лет с отдельной программой"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <div class="mx-auto max-w-[860px] px-4 mt-6">
    <div class="rounded-[16px] bg-slate-50 p-5">
      <p class="text-[13px] font-semibold uppercase tracking-wide text-slate-400 mb-3">Читайте по теме</p>
      <div class="space-y-2">
        <a href="/stati/podrostok-ne-hochet-uchitsya" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Подросток не хочет учиться — что делать
        </a>
        <a href="/stati/zavisimost-ot-telefona-u-podrostkov" class="flex items-center gap-2 text-[14px] text-slate-700 hover:text-orange-500 transition-colors">
          → Зависимость от телефона у подростков
        </a>
      </div>
    </div>
  </div>
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
