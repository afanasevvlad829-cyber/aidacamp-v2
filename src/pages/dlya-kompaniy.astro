---
import '../styles/global.css';
import { EMAIL } from '../data/contacts';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Почему компании выбирают АйДаКемп",
    text: "Летний отдых детей — одна из самых востребованных льгот в корпоративном соцпакете. АйДаКемп работает с юридическими лицами: договор, акт, счёт-фактура. Компания может компенсировать сотруднику стоимость путёвки полностью или частично. Это и забота о команде, и реальная польза для детей.",
    list: [
      "Договор с ООО/ИП, все закрывающие документы",
      "Счёт и акт выполненных работ",
      "Групповые условия от 3 путёвок — уточняйте при запросе",
      "Возможность оформить как подарок к Новому году или 1 июня"
    ]
  },
  {
    h2: "Что получают дети сотрудников",
    text: "Полноценная IT-смена в Подмосковье: Python, AI, Minecraft, дизайн. Проживание в комнатах по 2–4 человека, 5-разовое питание, бассейн, охрана 24/7. Ребёнок уезжает с готовым IT-проектом и новыми друзьями.",
    list: [
      "7–14 дней в загородном лагере в Подмосковье",
      "IT-программа по возрасту: 7–10, 10–12, 13–14 лет",
      "Проживание, питание, программа включены в стоимость",
      "Результат — проект, который ребёнок защищает на хакатоне"
    ]
  },
  {
    h2: "Как оформить путёвки для сотрудников",
    text: `Напишите нам в WhatsApp или на ${EMAIL} с пометкой «корпоративный запрос». Укажите количество детей, возраст и желаемые смены. Мы подготовим коммерческое предложение, договор и счёт в течение одного рабочего дня.`
  },
  {
    h2: "Корпоративные подарки детям сотрудников",
    text: "Путёвка в IT-лагерь — один из самых ценных корпоративных подарков для семей с детьми 7–14 лет. Это не просто отдых — ребёнок уедет с навыками программирования и готовым проектом.",
    list: [
      "Подарочный сертификат на любую смену — оформляем под корпоративный стиль",
      "Счёт на юрлицо, договор, акты — полный пакет для бухгалтерии",
      "Групповые условия от 3 путёвок — скидка и приоритетный выбор смен",
      "Новогодние корпоративные подарки детям — бронируем осенью со скидкой"
    ]
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Все смены и условия" },
  { title: "Смены и цены", url: "/#shifts", icon: "bi-calendar-event", description: "Актуальные смены 2026" },
  { title: "Контакты", url: "/#contacts", icon: "bi-telephone", description: "Написать напрямую" },
];
---

<LandingLayout
  title="Корпоративные путёвки в лагерь — подарки детям сотрудников | АйДаКемп"
  description="Корпоративные подарки детям сотрудников — путёвки в IT-лагерь АйДаКемп. Договор с юрлицом, закрывающие документы. Подмосковье, лето 2026. Групповые условия."
  h1="Путёвки в лагерь для детей сотрудников"
  canonical="https://aidacamp.ru/dlya-kompaniy"
>
  <LandingHero
    h1="Путёвки в лагерь для детей сотрудников"
    subtitle="Помогите сотрудникам решить вопрос летнего отдыха детей — с договором, закрывающими документами и групповыми условиями."
    breadcrumb="Для компаний"
    keywords={["Договор с юридическим лицом, закрывающие документы", "Групповые условия от 3 путёвок", "Частичная компенсация сотруднику через соцпакет"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
