---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Летний лагерь АйДаКемп — смены 2026",
    text: "АйДаКемп — выездной IT-лагерь для детей 7–14 лет в Подмосковье, 66 км от Москвы. Смены с 30 мая по 26 августа. За каждую смену ребёнок создаёт собственный IT-проект: бот, игру, сайт или приложение. Программа подбирается по возрасту: Scratch и Minecraft для младших, Python и AI для старших."
  },
  {
    h2: "Смены 2026 — даты и цены",
    text: "Четыре смены на лето 2026. Каждая смена — полноценная IT-программа с хакатоном в финале.",
    list: [
      "Смена 1: 30 мая – 12 июня, 14 дней — 95 000 ₽",
      "Смена 2: 16 – 28 июня, 13 дней — 89 400 ₽",
      "Смена 3: 3 – 15 августа, 13 дней — 89 400 ₽",
      "Смена 4: 17 – 26 августа, 10 дней — 69 600 ₽",
      "В стоимость включено: проживание, 5-разовое питание, IT-программа, бассейн"
    ]
  },
  {
    h2: "Что нового в программе лагеря 2026",
    text: "В 2026 году мы обновили программу. Добавлены модули по работе с нейросетями и AI-инструментами: дети учатся использовать AI для генерации изображений, текстов и кода. Хакатон «Стартап из будущего» стал ещё масштабнее — с двумя раундами инвестиций и ролевой системой. Внутренняя экономика лагеря теперь включает коллективные покупки и торги между группами."
  },
  {
    h2: "Как записаться на лето 2026",
    text: "Оставьте заявку на сайте — мы перезвоним в течение 10 минут и подберём смену. Бронирование фиксирует цену на 72 часа. Доступна рассрочка без переплаты. Образовательная лицензия позволяет оформить налоговый вычет 13%. Если ребёнку не понравится в первые два дня — вернём деньги."
  }
];

const relatedPages = [
  { title: "Цены и путёвки", url: "/lager-nedorogo", icon: "bi-tag", description: "Подробно о стоимости" },
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Расположение, условия" },
  { title: "IT-программа", url: "/kompyuternyy-lager", icon: "bi-laptop", description: "Чему учат детей" },
];
---

<LandingLayout
  title="Летний лагерь на лето 2026 — IT Подмосковье | АйДаКемп"
  description="Детский летний лагерь 2026 в Подмосковье. Смены июнь–август: от 48 000 ₽. Python, AI, Minecraft — проект за смену. 66 км от Москвы. Запись открыта."
  h1="Летний лагерь на лето 2026"
  canonical="https://aidacamp.ru/lager-na-leto-2026"
>
  <LandingHero
    h1="Летний лагерь на лето 2026"
    subtitle="Смены июнь–август 2026 в Подмосковье. IT-программа, бассейн, питание. Места заканчиваются."
    breadcrumb="Лагерь на лето 2026"
    keywords={["Смены открыты: июнь, август 2026 — места ограничены", "IT-программа 2026: Python, AI, Minecraft — проект за смену", "66 км от Москвы, от 48 000 ₽, проживание и питание включены"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
