---
import '../styles/global.css';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import LandingContent from '../components/LandingContent.astro';
import Shifts from '../components/Shifts.astro';
import FAQ from '../components/FAQ.astro';
import RelatedPages from '../components/RelatedPages.astro';
import LeadForm from '../components/LeadForm.astro';

const sections = [
  {
    h2: "Какой это детский лагерь",
    text: "АйДаКемп — загородный детский лагерь с IT-направлением в Подмосковье. Дети 7–14 лет живут в корпусах санатория «Изумруд», занимаются программированием, купаются в бассейне, играют в командные игры и в конце каждой смены защищают собственный проект на хакатоне. Это не просто «отдых» и не просто «учёба» — это место, где ребёнок взрослеет за 7–14 дней."
  },
  {
    h2: "Для детей какого возраста",
    text: "Лагерь принимает детей от 7 до 14 лет. Группы формируются по возрасту: 7–10, 10–12 и 13–14 лет. У каждой группы своя программа и свои преподаватели.",
    list: [
      "7–10 лет — Scratch, Minecraft, основы логики и алгоритмов",
      "10–12 лет — Python, создание игр и ботов",
      "13–14 лет — Python Advanced, AI, работа с API"
    ]
  },
  {
    h2: "Чем занимаются дети в лагере",
    text: "День в АйДаКемп устроен так: утром IT-занятия по программе, после обеда — бассейн, спорт, командные активности, вечером — работа над проектом. Смартфоны сданы на хранение: вместо них внутренняя валюта лагеря, которую зарабатывают за участие и помощь. Экранное время становится наградой, а не фоном.",
    list: [
      "Утро: IT-занятия в малых группах (до 8 человек)",
      "День: бассейн, спорт, активности на воздухе",
      "Вечер: проект, внутренняя экономика, свободное время",
      "Финал смены: хакатон — защита проекта перед всеми"
    ]
  },
  {
    h2: "Условия в детском лагере",
    text: "Лагерь работает на базе санатория «Изумруд» в Наро-Фоминском районе Московской области. Комнаты по 2–4 человека с санузлом, 5-разовое питание, бассейн с ионизированной водой, охраняемая территория. Медработник на смене круглосуточно. Работаем как лицензированный туроператор (РТО 025773)."
  }
];

const relatedPages = [
  { title: "Лагерь в Подмосковье", url: "/lager-v-podmoskove", icon: "bi-tree", description: "Расположение, смены, цены" },
  { title: "Лагерь без телефонов", url: "/lager-bez-telefonov", icon: "bi-phone-x", description: "Как работает наша механика" },
  { title: "Компьютерный лагерь", url: "/kompyuternyy-lager", icon: "bi-laptop", description: "IT-программа подробно" },
];
---

<LandingLayout
  title="Детский лагерь в Подмосковье 2026 — IT для детей 7–14 | АйДаКемп"
  description="Детский летний лагерь в Подмосковье для детей 7–14 лет. Python, Minecraft, AI — уедет с проектом. 66 км от Москвы, бассейн, питание. Смены 2026, от 48 000 ₽."
  h1="Детский лагерь в Подмосковье для детей"
  canonical="https://aidacamp.ru/detskiy-lager"
>
  <LandingHero
    h1="Детский лагерь в Подмосковье для детей"
    subtitle="Детский летний лагерь где дети 7–14 лет создают IT-проекты, купаются в бассейне и учатся жить без телефонов."
    breadcrumb="Детский лагерь"
    keywords={["Для детей 7–14 лет, группы по возрасту", "IT-проект за каждую смену — не курс, а результат", "Подмосковье, 66 км от Москвы, смены июнь–август"]}
  />
  <LandingContent sections={sections} />
  <Shifts />
  <FAQ />
  <RelatedPages pages={relatedPages} />
  <section id="lead-form" class="mx-auto max-w-[1312px] px-4 py-10">
    <LeadForm variant="mobile" />
  </section>
</LandingLayout>
