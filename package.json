{
  "name": "aidacamp",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node -e \"const fs=require('fs'),p='dist/client/';if(fs.existsSync(p+'sitemap-0.xml')){fs.copyFileSync(p+'sitemap-0.xml',p+'sitemap.xml');fs.unlinkSync(p+'sitemap-0.xml');fs.unlinkSync(p+'sitemap-index.xml');console.log('sitemap.xml ready')}\"",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2"
  }
}
